@* ── SCRIPT FAQ accordion (dán 1 lần, đặt trước </body> hoặc cuối file) ── *@
<script>
function toggleFaq(btn) {
  var body  = btn.nextElementSibling;
  var icon  = btn.querySelector('.faq-icon svg');
  var iconWrap = btn.querySelector('.faq-icon');
  var isOpen = !body.classList.contains('hidden');

  // close all
  document.querySelectorAll('.faq-body').forEach(function(b) { b.classList.add('hidden'); });
  document.querySelectorAll('.faq-icon svg').forEach(function(s) { s.style.transform = ''; });
  document.querySelectorAll('.faq-icon').forEach(function(w) { w.style.borderColor = ''; w.style.background = ''; });

  // open clicked if it was closed
  if (!isOpen) {
    body.classList.remove('hidden');
    icon.style.transform = 'rotate(180deg)';
    iconWrap.style.borderColor = '#00b14f';
    iconWrap.style.background  = '#e6f9ef';
  }
}
</script>
