@{
    ViewData["Title"] = "Dịch vụ tìm việc";
}

<div class="min-h-screen bg-white">

    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-[#00b14f] via-[#009b44] to-[#007a36] py-24">
        <div class="absolute top-[-80px] left-[-80px] w-[400px] h-[400px] rounded-full bg-green-300 opacity-10 blur-3xl"></div>
        <div class="absolute bottom-[-100px] right-[-60px] w-[350px] h-[350px] rounded-full bg-emerald-300 opacity-10 blur-3xl"></div>
        <div class="relative max-w-6xl mx-auto px-6 text-center">
            <span class="inline-block bg-white/10 border border-white/20 text-green-100 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-6 backdrop-blur-sm">
                🚀 Nền tảng tuyển dụng #1 Việt Nam
            </span>
            <h1 class="text-5xl md:text-6xl font-black text-white leading-tight mb-6">
                Dịch vụ tìm việc <br>
                <span class="text-yellow-300">
                    thông minh &amp; hiệu quả
                </span>
            </h1>
            <p class="text-green-100 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
                Kết nối ứng viên tài năng với nhà tuyển dụng uy tín. Tìm việc nhanh hơn, thông minh hơn với hệ thống gợi ý tiên tiến.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-4">
                <a href="/register" class="bg-white hover:bg-green-50 text-green-700 font-black px-8 py-4 rounded-2xl shadow-xl hover:shadow-2xl transition-all hover:-translate-y-1 text-sm">
                    Đăng ký miễn phí →
                </a>
                <a href="/" class="bg-white/10 hover:bg-white/20 border border-white/30 text-white font-bold px-8 py-4 rounded-2xl backdrop-blur-sm transition-all text-sm">
                    Xem việc làm
                </a>
            </div>
            <div class="grid grid-cols-3 gap-6 max-w-2xl mx-auto mt-16 pt-10 border-t border-white/20">
                <div>
                    <div class="text-3xl font-black text-yellow-300">41K+</div>
                    <div class="text-green-100 text-xs mt-1">Việc làm đang tuyển</div>
                </div>
                <div>
                    <div class="text-3xl font-black text-yellow-300">5K+</div>
                    <div class="text-green-100 text-xs mt-1">Doanh nghiệp uy tín</div>
                </div>
                <div>
                    <div class="text-3xl font-black text-yellow-300">98%</div>
                    <div class="text-green-100 text-xs mt-1">Ứng viên hài lòng</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="max-w-6xl mx-auto px-6 py-20">
        <div class="text-center mb-14">
            <span class="text-green-600 text-sm font-bold uppercase tracking-widest">Dịch vụ nổi bật</span>
            <h2 class="text-4xl font-black text-gray-900 mt-2 mb-4">Tất cả những gì bạn cần</h2>
            <p class="text-gray-500 max-w-xl mx-auto">Chúng tôi cung cấp đầy đủ công cụ giúp bạn tìm được công việc mơ ước một cách dễ dàng nhất</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Card 1 -->
            <div class="group bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden">
                <div class="p-8">
                    <div class="w-14 h-14 bg-green-100 rounded-2xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform duration-300">🔍</div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">Tìm việc thông minh</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-6">Hệ thống gợi ý việc làm phù hợp dựa trên kỹ năng, kinh nghiệm và sở thích của bạn.</p>
                    <ul class="space-y-2.5 text-sm text-gray-600 mb-8">
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-bold flex-shrink-0">✓</span>Lọc theo kỹ năng, mức lương, địa điểm</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-bold flex-shrink-0">✓</span>Gợi ý việc làm phù hợp tự động</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-bold flex-shrink-0">✓</span>Thông báo việc làm mới mỗi ngày</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-bold flex-shrink-0">✓</span>Lưu việc làm yêu thích</li>
                    </ul>
                    <a href="/" class="w-full block text-center bg-green-600 hover:bg-green-700 text-white py-3 rounded-xl font-bold text-sm transition-all shadow-md hover:shadow-lg">Tìm việc ngay</a>
                </div>
            </div>
            <!-- Card 2 - Featured -->
            <div class="group relative bg-gradient-to-br from-green-600 via-emerald-600 to-teal-600 rounded-3xl shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden">
                <div class="absolute top-5 right-5 bg-yellow-400 text-yellow-900 text-xs font-black px-3 py-1 rounded-full">⭐ Phổ biến nhất</div>
                <div class="p-8">
                    <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform duration-300">📄</div>
                    <h3 class="text-xl font-bold text-white mb-3">Tạo CV chuyên nghiệp</h3>
                    <p class="text-green-100 text-sm leading-relaxed mb-6">Tạo CV đẹp, chuyên nghiệp trong vài phút với hàng chục mẫu thiết kế hiện đại.</p>
                    <ul class="space-y-2.5 text-sm text-green-100 mb-8">
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">✓</span>Hàng chục mẫu CV đẹp, hiện đại</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">✓</span>Tùy chỉnh màu sắc, font chữ, layout</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">✓</span>Xuất PDF chất lượng cao miễn phí</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">✓</span>Lưu và chỉnh sửa bất kỳ lúc nào</li>
                    </ul>
                    <a href="/Create_CV/All_CV_Style" class="w-full block text-center bg-white hover:bg-yellow-50 text-green-700 py-3 rounded-xl font-bold text-sm transition-all shadow-md hover:shadow-lg">Tạo CV ngay</a>
                </div>
            </div>
            <!-- Card 3 -->
            <div class="group bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden">
                <div class="p-8">
                    <div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform duration-300">🎯</div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">Ứng tuyển siêu tốc</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-6">Nộp hồ sơ chỉ với 1 click và theo dõi toàn bộ quá trình ứng tuyển một cách dễ dàng.</p>
                    <ul class="space-y-2.5 text-sm text-gray-600 mb-8">
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-bold flex-shrink-0">✓</span>Nộp hồ sơ chỉ với 1 click</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-bold flex-shrink-0">✓</span>Theo dõi trạng thái đơn ứng tuyển</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-bold flex-shrink-0">✓</span>Nhận thông báo phản hồi từ NTD</li>
                        <li class="flex items-center gap-2.5"><span class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-bold flex-shrink-0">✓</span>Lịch sử ứng tuyển chi tiết</li>
                    </ul>
                    <a href="/Candidate/Index" class="w-full block text-center bg-emerald-600 hover:bg-emerald-700 text-white py-3 rounded-xl font-bold text-sm transition-all shadow-md hover:shadow-lg">Bắt đầu ngay</a>
                </div>
            </div>
        </div>
    </section>

    <!-- How it works -->
    <section class="bg-green-50 py-20">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center mb-14">
                <span class="text-green-600 text-sm font-bold uppercase tracking-widest">Quy trình</span>
                <h2 class="text-4xl font-black text-gray-900 mt-2 mb-4">Chỉ 3 bước đơn giản</h2>
                <p class="text-gray-500 max-w-xl mx-auto">Bắt đầu hành trình tìm việc của bạn ngay hôm nay</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <a href="/register" class="text-center group block hover:-translate-y-2 transition-all duration-300">
                    <div class="relative inline-block mb-5">
                        <div class="w-20 h-20 bg-gradient-to-br from-green-500 to-emerald-400 rounded-3xl flex items-center justify-center text-3xl shadow-lg group-hover:shadow-xl transition-all">📝</div>
                        <div class="absolute -top-2 -right-2 w-7 h-7 bg-green-600 text-white text-xs font-black rounded-full flex items-center justify-center">1</div>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-green-600 transition-colors">Tạo hồ sơ</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">Đăng ký tài khoản và tạo hồ sơ cá nhân với CV chuyên nghiệp</p>
                </a>
                <a href="/home" class="text-center group block hover:-translate-y-2 transition-all duration-300">
                    <div class="relative inline-block mb-5">
                        <div class="w-20 h-20 bg-gradient-to-br from-emerald-500 to-teal-400 rounded-3xl flex items-center justify-center text-3xl shadow-lg group-hover:shadow-xl transition-all">🔍</div>
                        <div class="absolute -top-2 -right-2 w-7 h-7 bg-emerald-600 text-white text-xs font-black rounded-full flex items-center justify-center">2</div>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-emerald-600 transition-colors">Tìm kiếm việc làm</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">Khám phá hàng ngàn cơ hội việc làm phù hợp với bạn</p>
                </a>
                <a href="/Candidate/Index" class="text-center group block hover:-translate-y-2 transition-all duration-300">
                    <div class="relative inline-block mb-5">
                        <div class="w-20 h-20 bg-gradient-to-br from-teal-500 to-cyan-400 rounded-3xl flex items-center justify-center text-3xl shadow-lg group-hover:shadow-xl transition-all">🎉</div>
                        <div class="absolute -top-2 -right-2 w-7 h-7 bg-teal-600 text-white text-xs font-black rounded-full flex items-center justify-center">3</div>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-teal-600 transition-colors">Ứng tuyển &amp; nhận việc</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">Nộp đơn và theo dõi kết quả, nhận thông báo từ nhà tuyển dụng</p>
                </a>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="max-w-6xl mx-auto px-6 py-20">
        <div class="text-center mb-14">
            <span class="text-green-600 text-sm font-bold uppercase tracking-widest">Đánh giá</span>
            <h2 class="text-4xl font-black text-gray-900 mt-2 mb-4">Ứng viên nói gì về chúng tôi</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-7 hover:shadow-md hover:border-green-200 transition">
                <div class="text-yellow-400 mb-4 text-lg">★★★★★</div>
                <p class="text-gray-600 text-sm leading-relaxed mb-5">"Tôi tìm được việc làm mơ ước chỉ sau 2 tuần sử dụng dịch vụ. Giao diện dễ dùng, gợi ý việc làm rất chính xác!"</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-green-400 to-emerald-400 flex items-center justify-center text-white font-bold text-sm">N</div>
                    <div>
                        <p class="font-bold text-gray-900 text-sm">Nguyễn Văn A</p>
                        <p class="text-gray-400 text-xs">Software Engineer</p>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-7 hover:shadow-md hover:border-green-200 transition">
                <div class="text-yellow-400 mb-4 text-lg">★★★★★</div>
                <p class="text-gray-600 text-sm leading-relaxed mb-5">"CV builder rất tiện lợi và đẹp. Nhà tuyển dụng ấn tượng với CV của tôi ngay lần đầu nhìn thấy."</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-400 to-teal-400 flex items-center justify-center text-white font-bold text-sm">T</div>
                    <div>
                        <p class="font-bold text-gray-900 text-sm">Trần Thị B</p>
                        <p class="text-gray-400 text-xs">Marketing Manager</p>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-7 hover:shadow-md hover:border-green-200 transition">
                <div class="text-yellow-400 mb-4 text-lg">★★★★★</div>
                <p class="text-gray-600 text-sm leading-relaxed mb-5">"Hệ thống theo dõi ứng tuyển rất tiện. Tôi biết chính xác đơn của mình đang ở bước nào."</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-teal-400 to-cyan-400 flex items-center justify-center text-white font-bold text-sm">L</div>
                    <div>
                        <p class="font-bold text-gray-900 text-sm">Lê Văn C</p>
                        <p class="text-gray-400 text-xs">Product Designer</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-gradient-to-r from-green-600 via-emerald-600 to-teal-600 py-20">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-4xl font-black text-white mb-4">Sẵn sàng bắt đầu?</h2>
            <p class="text-green-100 text-lg mb-10 max-w-xl mx-auto">Đăng ký miễn phí ngay hôm nay và khám phá hàng ngàn cơ hội việc làm đang chờ bạn.</p>
            <div class="flex flex-wrap items-center justify-center gap-4">
                <a href="/register" class="bg-white hover:bg-yellow-50 text-green-700 font-black px-10 py-4 rounded-2xl shadow-xl hover:shadow-2xl transition-all hover:-translate-y-1 text-sm">
                    🚀 Đăng ký miễn phí
                </a>
                <a href="/" class="bg-white/10 hover:bg-white/20 border border-white/30 text-white font-bold px-10 py-4 rounded-2xl backdrop-blur-sm transition-all text-sm">
                    Xem việc làm ngay
                </a>
            </div>
        </div>
    </section>

</div>
