@{
    ViewData["Title"] = "Trung Tâm Dịch Vụ - Zelon Developer";
}

<link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>

<section class="w-full bg-[#004d25] font-sans pb-24 relative overflow-hidden"
         style="background-image: linear-gradient(150deg, #004d25 0%, #002d16 100%);">
    
    <div class="absolute inset-0 pointer-events-none opacity-10">
        <div class="absolute left-0 top-0 h-full w-80"
             style="background: repeating-linear-gradient(45deg, #ffffff, #ffffff 1px, transparent 1px, transparent 25px);">
        </div>
        <div class="absolute right-0 top-0 h-full w-80"
             style="background: repeating-linear-gradient(-45deg, #ffffff, #ffffff 1px, transparent 1px, transparent 25px);">
        </div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 pt-16">
        
        <div class="text-center mb-16">
            <h1 class="text-[#00ff88] text-4xl md:text-5xl font-black mb-4 tracking-tight uppercase shadow-sm">
                Trung Tâm Dịch Vụ Nhân Sự
            </h1>
            <div class="h-1.5 w-32 bg-[#00ff88] mx-auto rounded-full mb-6 shadow-[0_0_15px_rgba(0,255,136,0.5)]"></div>
            <p class="text-white/80 text-lg max-w-2xl mx-auto font-light leading-relaxed">
                Cung cấp các giải pháp tối ưu cho ứng viên và doanh nghiệp thông qua hệ thống quản lý hồ sơ thông minh
                tích hợp công nghệ mã hóa AES-256.
            </p>
        </div>

        <div class="grid grid-cols-12 gap-8 items-start">
            
            <div class="col-span-12 lg:col-span-4 space-y-6">
                <div class="rounded-3xl shadow-2xl overflow-hidden border border-white/10"
                     style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px);">
                    
                    <div class="p-6 border-b border-white/10 flex items-center gap-3"
                         style="background: rgba(0, 0, 0, 0.2);">
                        <div class="w-3 h-3 rounded-full bg-[#00ff88] animate-pulse"></div>
                        <span class="font-bold text-white uppercase tracking-wider text-sm">Gói dịch vụ ứng viên</span>
                    </div>

                    <ul class="divide-y divide-white/5">
                        <li onclick="location.href='/Service/CVDesign'"
                            class="p-5 flex items-start gap-4 hover:bg-white/5 transition-all cursor-pointer group">
                            <div
                                class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-[#00ff88] text-2xl shadow-inner group-hover:scale-110 transition-transform">
                                <i class='bx bx-file-blank'></i>
                            </div>
                            <div>
                                <h4
                                    class="font-bold text-white group-hover:text-[#00ff88] transition-colors leading-tight">
                                    Thiết kế CV chuẩn ATS</h4>
                                    <p class="text-[10px] text-white/50 mt-1 uppercase tracking-tighter">Tối ưu từ khóa vượt
                                        bộ lọc</p>
                                    </div>
                                </li>

                                <li onclick="location.href='/Service/Premium'"
                                    class="p-5 flex items-start gap-4 hover:bg-white/5 transition-all cursor-pointer group">
                                    <div
                                        class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-[#00ff88] text-2xl shadow-inner group-hover:scale-110 transition-transform">
                                        <i class='bx bx-rocket'></i>
                                    </div>
                                    <div>
                                        <h4
                                            class="font-bold text-white group-hover:text-[#00ff88] transition-colors leading-tight">
                                            Đẩy hồ sơ ưu tiên</h4>
                                            <p class="text-[10px] text-white/50 mt-1 uppercase tracking-tighter">Top đầu kết quả tìm
                                                kiếm</p>
                                            </div>
                                        </li>

                                        <li onclick="location.href='/Service/AIAnalytics'"
                                            class="p-5 flex items-start gap-4 hover:bg-white/5 transition-all cursor-pointer group">
                                            <div
                                                class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-[#00ff88] text-2xl shadow-inner group-hover:scale-110 transition-transform">
                                                <i class='bx bx-bot'></i>
                                            </div>
                                            <div>
                                                <h4
                                                    class="font-bold text-white group-hover:text-[#00ff88] transition-colors leading-tight">
                                                    Phân tích năng lực AI</h4>
                                                    <p class="text-[10px] text-white/50 mt-1 uppercase tracking-tighter">Gợi ý lộ trình dựa
                                                        trên kỹ năng</p>
                                                    </div>
                                                </li>
                                            </ul>
                                        </div>

                                        <div class="bg-white/5 backdrop-blur-md p-8 rounded-3xl border border-white/10 text-center group">
                                            <div class="text-[#00ff88] text-5xl mb-4 group-hover:rotate-12 transition-transform inline-block">
                                                <i class='bx bx-shield-quarter'></i>
                                            </div>
                                            <p class="text-[#00ff88] text-4xl font-black mb-2">100%</p>
                                            <p class="text-white font-bold text-sm uppercase tracking-widest">Bảo mật dữ liệu</p>
                                            <p class="text-white/40 text-[11px] mt-3 leading-relaxed">
                                                Hệ thống lưu trữ hồ sơ đạt chuẩn mã hóa AES-256 bảo vệ thông tin tuyệt đối.
                                            </p>
                                        </div>
                                    </div>

                                    <div class="col-span-12 lg:col-span-8 space-y-8">
                                        <div
                                            class="relative bg-gradient-to-br from-[#0d3b26] to-[#1a5c3d] rounded-[2.5rem] p-8 md:p-14 overflow-hidden border border-white/10 shadow-2xl min-h-[500px] flex flex-col justify-center">
                    
                                            <div class="relative z-10">
                                                <span
                                                    class="bg-[#00ff88] text-[#004d25] px-4 py-1.5 rounded-full text-[10px] font-black uppercase mb-8 inline-block tracking-widest">
                                                    Professional Service
                                                </span>
                                                <h2 class="text-white text-4xl md:text-6xl font-black mb-6 leading-[1.1]">
                                                    Nộp hồ sơ trực tuyến<br>
                                                    <span class="text-[#00ff88]">Nhận việc trao tay</span>
                                                </h2>
                                                <p class="text-gray-300 text-lg mb-10 max-w-lg leading-relaxed font-light">
                                                    Quy trình dịch vụ khép kín từ khâu tiếp nhận hồ sơ, sàng lọc AI đến khi kết nối thành công
                                                    với mạng lưới 500+ doanh nghiệp đối tác.
                                                </p>
                        
                                                <div class="flex flex-wrap gap-4">
                                                    <a href="/Service/Apply"
                                                           class="bg-white text-[#004d25] px-10 py-5 rounded-2xl font-black hover:bg-[#00ff88] transition-all transform hover:-translate-y-1 flex items-center gap-2 shadow-xl">
                                                        <i class='bx bx-edit-alt text-xl'></i> ĐĂNG KÝ DỊCH VỤ NGAY
                                                    </a>
                                                    <a href="/Service/Pricing"
                                                           class="bg-transparent border-2 border-white/20 text-white px-10 py-5 rounded-2xl font-bold hover:bg-white/5 transition-all flex items-center gap-2">
                                                        <i class='bx bx-info-circle text-xl'></i> XEM BÁO GIÁ
                                                    </a>
                                                </div>
                                            </div>

                                            <div
                                                class="absolute right-[-20px] bottom-[-20px] h-[85%] w-1/2 bg-[url('https://static.topcv.vn/v4/image/welcome-onboard.png')] bg-contain bg-no-repeat bg-right-bottom opacity-80 hidden md:block">
                                            </div>
                                        </div>

                                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                                            <div
                                                class="bg-[#023a1c] p-6 rounded-2xl border border-white/5 text-center flex flex-col items-center gap-1 hover:border-[#00ff88]/50 transition-colors">
                                                <i class='bx bx-time-five text-white/40 text-lg mb-1'></i>
                                                <p class="text-gray-400 text-[10px] font-bold uppercase tracking-tighter">Hỗ trợ</p>
                                                <p class="text-white text-2xl font-black">24/7</p>
                                            </div>
                                            <div
                                                class="bg-[#023a1c] p-6 rounded-2xl border border-white/5 text-center flex flex-col items-center gap-1 hover:border-[#00ff88]/50 transition-colors">
                                                <i class='bx bx-timer text-[#00ff88]/40 text-lg mb-1'></i>
                                                <p class="text-gray-400 text-[10px] font-bold uppercase tracking-tighter">Phản hồi</p>
                                                <p class="text-[#00ff88] text-2xl font-black">&lt; 2h</p>
                                            </div>
                                            <div
                                                class="bg-[#023a1c] p-6 rounded-2xl border border-white/5 text-center flex flex-col items-center gap-1 hover:border-[#00ff88]/50 transition-colors">
                                                <i class='bx bx-buildings text-white/40 text-lg mb-1'></i>
                                                <p class="text-gray-400 text-[10px] font-bold uppercase tracking-tighter">Đối tác</p>
                                                <p class="text-white text-2xl font-black">500+</p>
                                            </div>
                                            <div
                                                class="bg-[#023a1c] p-6 rounded-2xl border border-white/5 text-center flex flex-col items-center gap-1 hover:border-[#00ff88]/50 transition-colors">
                                                <i class='bx bx-trending-up text-[#00ff88]/40 text-lg mb-1'></i>
                                                <p class="text-gray-400 text-[10px] font-bold uppercase tracking-tighter">Thành công</p>
                                                <p class="text-[#00ff88] text-2xl font-black">92%</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-24 relative z-10 border-t border-white/5 pt-20">
                                    <h3 class="text-center text-white text-2xl font-black mb-16 uppercase tracking-[0.3em]">
                                        Quy trình triển khai dịch vụ
                                    </h3>
                                    <div class="grid md:grid-cols-3 gap-12 text-center">
                                        <div class="relative px-4">
                                            <div
                                                class="w-16 h-16 bg-[#00ff88] text-[#004d25] rounded-2xl flex items-center justify-center text-2xl font-black mx-auto shadow-[0_10px_30px_rgba(0,255,136,0.3)] rotate-3 mb-8">
                                                01
                                            </div>
                                            <h5 class="text-white font-bold text-lg mb-3">Gửi Yêu Cầu</h5>
                                            <p class="text-white/40 text-sm leading-relaxed">
                                                Ứng viên cung cấp thông tin cơ bản và tải hồ sơ gốc thông qua cổng bảo mật AES.
                                            </p>
                                        </div>
                                        <div class="relative px-4">
                                            <div
                                                class="w-16 h-16 bg-[#00ff88] text-[#004d25] rounded-2xl flex items-center justify-center text-2xl font-black mx-auto shadow-[0_10px_30px_rgba(0,255,136,0.3)] -rotate-3 mb-8">
                                                02
                                            </div>
                                            <h5 class="text-white font-bold text-lg mb-3">Tối Ưu Hồ Sơ</h5>
                                            <p class="text-white/40 text-sm leading-relaxed">
                                                Hệ thống sàng lọc AI đánh giá năng lực và chuẩn hóa hồ sơ theo tiêu chuẩn ATS.
                                            </p>
                                        </div>
                                        <div class="relative px-4">
                                            <div
                                                class="w-16 h-16 bg-[#00ff88] text-[#004d25] rounded-2xl flex items-center justify-center text-2xl font-black mx-auto shadow-[0_10px_30px_rgba(0,255,136,0.3)] rotate-3 mb-8">
                                                03
                                            </div>
                                            <h5 class="text-white font-bold text-lg mb-3">Kết Nối Việc Làm</h5>
                                            <p class="text-white/40 text-sm leading-relaxed">
                                                Chuyên viên Zelon trực tiếp kết nối ứng viên với các doanh nghiệp phù hợp nhất.
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
<section class="w-full bg-[#f0faf4] py-20 relative overflow-hidden">
  <!-- decorative blobs-->
  <div class="absolute top-0 left-0 w-72 h-72 bg-[#00ff88]/10 rounded-full -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-[#004d25]/8 rounded-full translate-x-1/3 translate-y-1/3 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <!-- heading-->
    <div class="text-center mb-14">
      <span class="inline-block px-4 py-1.5 bg-[#004d25] text-[#00ff88] text-xs font-bold uppercase tracking-widest rounded-full mb-4">Vì sao chúng tôi?</span>
      <h2 class="text-3xl md:text-4xl font-bold text-[#004d25] mb-4">Tại sao chọn <span class="text-[#00b14f]">chúng tôi?</span></h2>
      <p class="text-gray-500 max-w-xl mx-auto text-sm leading-relaxed">Nền tảng tuyển dụng công nghệ thế hệ mới — nơi ứng viên và doanh nghiệp tìm thấy nhau chính xác nhất.</p>
    </div>

    <!-- grid 4 cards-->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <div class="group bg-white rounded-2xl p-7 border border-[#c3e9d5] hover:border-[#00b14f] hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
        <div class="w-14 h-14 bg-[#e6f9ef] rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#004d25] transition-colors">
          <svg class="w-7 h-7 text-[#00b14f] group-hover:text-[#00ff88] transition-colors" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01"/>
          </svg>
        </div>
        <h3 class="font-bold text-[#004d25] text-base mb-2">Công nghệ AI vượt trội</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Hệ thống AI tự động phân tích hồ sơ, đánh giá năng lực và gợi ý việc làm phù hợp nhất với từng ứng viên.</p>
      </div>

      <div class="group bg-white rounded-2xl p-7 border border-[#c3e9d5] hover:border-[#00b14f] hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
        <div class="w-14 h-14 bg-[#e6f9ef] rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#004d25] transition-colors">
          <svg class="w-7 h-7 text-[#00b14f] group-hover:text-[#00ff88] transition-colors" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="font-bold text-[#004d25] text-base mb-2">Hỗ trợ 24/7 chuyên nghiệp</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Đội ngũ chuyên gia nhân sự luôn sẵn sàng hỗ trợ bạn mọi lúc — từ tư vấn CV đến phỏng vấn thực chiến.</p>
      </div>

      <div class="group bg-white rounded-2xl p-7 border border-[#c3e9d5] hover:border-[#00b14f] hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
        <div class="w-14 h-14 bg-[#e6f9ef] rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#004d25] transition-colors">
          <svg class="w-7 h-7 text-[#00b14f] group-hover:text-[#00ff88] transition-colors" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h3 class="font-bold text-[#004d25] text-base mb-2">Chi phí tối ưu</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Gói dịch vụ linh hoạt, minh bạch — từ miễn phí đến cao cấp, phù hợp với mọi quy mô doanh nghiệp và ngân sách.</p>
      </div>

      <div class="group bg-white rounded-2xl p-7 border border-[#c3e9d5] hover:border-[#00b14f] hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
        <div class="w-14 h-14 bg-[#e6f9ef] rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#004d25] transition-colors">
          <svg class="w-7 h-7 text-[#00b14f] group-hover:text-[#00ff88] transition-colors" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 class="font-bold text-[#004d25] text-base mb-2">Bảo mật tuyệt đối</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Dữ liệu hồ sơ được mã hóa chuẩn AES-256. Thông tin cá nhân của bạn được bảo vệ ở mức độ doanh nghiệp.</p>
      </div>

    </div>
  </div>
</section>


@* ──────────────────────────────────────────────────────
   SECTION 2: ĐÁNH GIÁ TỪ NGƯỜI DÙNG
────────────────────────────────────────────────────── *@
<section class="w-full bg-[#004d25] py-20 relative overflow-hidden">
  <!-- pattern bg-->
  <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image:repeating-linear-gradient(45deg,#00ff88 0,#00ff88 1px,transparent 0,transparent 50%);background-size:20px 20px;"></div>
  <div class="absolute top-10 right-10 w-64 h-64 bg-[#00ff88]/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-10 left-10 w-48 h-48 bg-[#00ff88]/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-4 py-1.5 bg-[#00ff88]/15 text-[#00ff88] text-xs font-bold uppercase tracking-widest rounded-full border border-[#00ff88]/30 mb-4">Testimonials</span>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Đánh giá từ <span class="text-[#00ff88]">người dùng</span></h2>
      <p class="text-white/50 max-w-xl mx-auto text-sm leading-relaxed">Hàng nghìn ứng viên và doanh nghiệp đã tin tưởng và đạt được mục tiêu cùng Zeion Developer.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      @foreach (var review in new[] {
        new { Init="NA", Name="Nguyễn Văn A", Title="CEO · TechCorp", Stars=5,
              Quote="Dịch vụ tuyệt vời! Hệ thống AI của Zeion giúp tôi lọc ra ứng viên phù hợp nhanh gấp 3 lần so với cách làm thủ công trước đây.",
              Tag="Doanh nghiệp", Color="#00ff88", Bg="rgba(0,255,136,0.08)" },
        new { Init="BT", Name="Trần Thị Bình", Title="Senior Frontend Dev", Stars=5,
              Quote="Nhờ Zeion, tôi tìm được công việc mơ ước chỉ sau 2 tuần. CV được AI tối ưu và đội hỗ trợ cực kỳ tận tâm, phản hồi siêu nhanh.",
              Tag="Ứng viên", Color="#38bdf8", Bg="rgba(56,189,248,0.08)" },
        new { Init="MC", Name="Lê Minh Châu", Title="HR Manager · FPT", Stars=5,
              Quote="Nền tảng dễ dùng, giao diện thân thiện. Chúng tôi đã tuyển thành công 12 kỹ sư trong 1 tháng nhờ tính năng tìm kiếm ứng viên thông minh.",
              Tag="Doanh nghiệp", Color="#a78bfa", Bg="rgba(167,139,250,0.08)" },
      })
      {
      <div class="relative rounded-2xl p-7 border border-white/10 backdrop-blur-sm hover:border-[#00ff88]/40 hover:-translate-y-1 transition-all duration-200" style="background: @review.Bg;">
        <!-- quote icon-->
        <div class="absolute top-5 right-6 text-5xl font-serif leading-none opacity-20" style="color:@review.Color;">"</div>

        <!-- stars-->
        <div class="flex gap-1 mb-4">
          @for (int i = 0; i < review.Stars; i++) {
            <svg class="w-4 h-4 text-[#00ff88] fill-[#00ff88]" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/></svg>
          }
        </div>

        <p class="text-white/75 text-sm leading-relaxed mb-6 italic">"@review.Quote"</p>

        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0" style="background:@review.Color;color:#004d25;">@review.Init</div>
          <div>
            <div class="text-white font-semibold text-sm">@review.Name</div>
            <div class="text-white/40 text-xs">@review.Title</div>
          </div>
          <span class="ml-auto text-xs font-semibold px-2.5 py-1 rounded-full border" style="color:@review.Color;border-color:@review.Color;background:rgba(0,0,0,0.2);">@review.Tag</span>
        </div>
      </div>
      }

    </div>

    <!-- rating summary row-->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-10 border-t border-white/10 pt-10">
      <div class="text-center">
        <div class="text-4xl font-bold text-[#00ff88]">4.9<span class="text-xl">/5</span></div>
        <div class="text-white/50 text-xs mt-1">Đánh giá trung bình</div>
      </div>
      <div class="w-px h-10 bg-white/10 hidden md:block"></div>
      <div class="text-center">
