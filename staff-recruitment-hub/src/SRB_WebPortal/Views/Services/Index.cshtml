          new { Q="Doanh nghiệp đăng tin tuyển dụng như thế nào?",
                A="Sau khi đăng ký tài khoản doanh nghiệp, bạn vào mục 'Quản lý tin đăng' → 'Tạo tin mới', điền thông tin vị trí và xuất bản. Tin sẽ được duyệt và hiển thị trong vòng 30 phút." },
          new { Q="Có hỗ trợ tư vấn phỏng vấn không?",
                A="Có. Gói Pro trở lên được hỗ trợ luyện phỏng vấn 1-1 với chuyên gia nhân sự, mock interview và phản hồi chi tiết để tăng tỉ lệ trúng tuyển." },
        };
