<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@1,600&display=swap" rel="stylesheet">

<style>
    /* 1. PHÁ VỠ MỌI KHUNG MẶC ĐỊNH CỦA HỆ THỐNG */
    /* Đoạn này quan trọng nhất để đẩy bay cái khoảng trắng 2 bên lề */
    html, body, 
    main, .container, 
    .body-content, 
    #zeion-contact-page {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
        overflow-x: hidden !important;
        background-color: #f0f7f2;
    }

    :root {
        --green-dark: #0d3d2e;
        --green-accent: #2ec97e;
    }

    /* 2. BANNER XANH TRÀN 100% (image_417a7d.png) */
    .contact-banner {
        width: 100vw !important; /* Sử dụng viewport width để đảm bảo tràn hết màn hình */
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw !important;
        margin-right: -50vw !important;
        background: var(--green-dark);
        padding: 100px 0 140px;
        text-align: center;
        color: #fff;
    }

    .banner-heading h1 {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        margin: 0;
    }

    .banner-heading h1 em {
        font-family: 'Playfair Display', serif;
        color: var(--green-accent);
        font-style: italic;
    }

    /* 3. LAYOUT NỘI DUNG (DỮ NGUYÊN GIAO DIỆN ĐẸP) */
    .section-wrap {
        max-width: 1200px;
        margin: -100px auto 60px;
        padding: 0 20px;
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 30px;
        position: relative;
        z-index: 10;
    }

    .form-card {
        background: #fff;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    }
    
    .form-row { display: flex; gap: 20px; margin-bottom: 20px; }
    
    input, textarea {
        width: 100%; padding: 15px;
        border: 1.5px solid #eef2f0;
        border-radius: 12px; outline: none;
        box-sizing: border-box;
    }

    .submit-btn {
        width: 100%; padding: 18px;
        background: var(--green-accent);
        border: none; border-radius: 15px;
        color: #fff; font-weight: 800;
        cursor: pointer; margin-top: 15px;
        transition: 0.3s;
    }
    .submit-btn:hover { background: #26b16e; transform: translateY(-2px); }

    .info-item {
        background: #fff; padding: 25px;
        border-radius: 20px; margin-bottom: 15px;
        display: flex; align-items: center; gap: 20px;
        border: 1px solid #eee;
    }

    /* 4. FIX LỖI RAZOR @@MEDIA (image_4172c0.png) */
    @@media (max-width: 900px) {
        .section-wrap { grid-template-columns: 1fr; margin-top: -60px; }
        .form-row { flex-direction: column; }
    }
</style>

<div id="zeion-contact-page">
    <header class="contact-banner">
        <div class="banner-heading">
            <h1>Liên hệ <em>Zeion</em></h1>
        </div>
        <p style="opacity: 0.8; margin-top: 15px; font-size: 18px;">Chúng tôi luôn lắng nghe và hỗ trợ bạn 24/7</p>
    </header>

    <div class="section-wrap">
        <div class="form-card">
            <h2 style="margin-bottom: 30px; color: var(--green-dark);">Gửi lời nhắn trực tuyến</h2>
            <div class="form-row">
                <div style="flex:1">
                    <label style="font-weight:700; font-size:12px; display:block; margin-bottom:8px;">HỌ VÀ TÊN</label>
                    <input type="text" placeholder="Nguyễn Văn A">
                </div>
                <div style="flex:1">
                    <label style="font-weight:700; font-size:12px; display:block; margin-bottom:8px;">ĐỊA CHỈ EMAIL</label>
                    <input type="email" placeholder="name@company.com">
                </div>
            </div>
            <div style="margin-top:20px">
                <label style="font-weight:700; font-size:12px; display:block; margin-bottom:8px;">NỘI DUNG CẦN TƯ VẤN</label>
                <textarea placeholder="Bạn cần hỗ trợ điều gì?" style="height: 160px; resize: none;"></textarea>
            </div>
            <button class="submit-btn">ĐĂNG KÝ TƯ VẤN NGAY 🚀</button>
        </div>

        <div>
            <div class="info-item">
                <div style="font-size:24px">📍</div>
                <div>
                    <span style="font-size: 11px; font-weight: 800; color: var(--green-accent); text-transform: uppercase;">Văn phòng chính</span>
                    <div style="font-weight: 700;">Quận 7, TP. Hồ Chí Minh</div>
                </div>
            </div>
            <div class="info-item">
                <div style="font-size:24px">📞</div>
                <div>
                    <span style="font-size: 11px; font-weight: 800; color: var(--green-accent); text-transform: uppercase;">Hotline hỗ trợ</span>
                    <div style="font-weight: 700;">+84 (028) 1234 5678</div>
                </div>
            </div>
            <div style="background: var(--green-dark); color: #fff; padding: 40px; border-radius: 24px; text-align: center;">
                <h3 style="margin: 0; font-size: 22px;">Phản hồi trong 2h</h3>
                <p style="font-size: 14px; opacity: 0.7; margin-top: 15px;">Cam kết giải quyết thắc mắc nhanh nhất.</p>
            </div>
        </div>
    </div>
</div>