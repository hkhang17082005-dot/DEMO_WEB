@{
   ViewData["Title"] = "Top tất cả mẫu CV xin việc tiếng Việt chuẩn 2026";
}

<!-- PAGE BACKGROUND -->
<div class="relative min-h-screen overflow-hidden bg-linear-to-br from-emerald-50 via-white to-purple-100 rounded-3xl">

   <!-- Background Effects -->
   <div class="absolute rounded-full top-20 left-10 w-72 h-72 bg-emerald-400 opacity-20 blur-3xl -z-10"></div>
   <div class="absolute bg-purple-500 rounded-full bottom-20 right-10 w-72 h-72 opacity-20 blur-3xl -z-10"></div>
