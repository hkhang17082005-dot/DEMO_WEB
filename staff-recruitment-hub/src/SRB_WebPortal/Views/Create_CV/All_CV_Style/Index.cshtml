      <!-- Breadcrumb -->
      <div class="mb-4 text-sm text-gray-500">
         <span class="font-medium text-emerald-600">Trang chủ</span>
         >
         <span class="font-semibold text-gray-700">
            Top tất cả mẫu CV xin việc tiếng Việt chuẩn 2026
         </span>
      </div>

      <!-- TITLE -->
      <div class="flex items-center justify-between mb-8">

