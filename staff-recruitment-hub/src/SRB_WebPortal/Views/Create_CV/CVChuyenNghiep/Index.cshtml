                                                                     @* --- FAQ SCRIPT --- *@
                                                                     <script>
                                                                        function toggleFaqCV(btn) {
                                                                           var body = btn.nextElementSibling;
                                                                           var icon = btn.querySelector('.faq-icon');
                                                                           var isOpen = !body.classList.contains('hidden');
                                                                           document.querySelectorAll('#cvFaqList .faq-body').forEach(function (b) { b.classList.add('hidden'); });
                                                                           document.querySelectorAll('#cvFaqList .faq-icon').forEach(function (i) { i.textContent = '+'; });
                                                                           if (!isOpen) {
                                                                              body.classList.remove('hidden');
                                                                              icon.textContent = '−';
                                                                           }
                                                                        }
                                                                     </script>

