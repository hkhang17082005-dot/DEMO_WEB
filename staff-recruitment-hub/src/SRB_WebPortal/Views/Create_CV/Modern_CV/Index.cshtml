@{
   ViewData["Title"] = "Mẫu CV Hiện Đại";
}

<!-- Background Effects -->
<div class="absolute rounded-full pointer-events-none top-20 left-10 w-72 h-72 bg-emerald-400 opacity-20 blur-3xl">
</div>

<div class="absolute bg-purple-500 rounded-full pointer-events-none bottom-20 right-10 w-72 h-72 opacity-20 blur-3xl">
</div>
<div class="px-4 py-8 mx-auto max-w-7xl">

   <!-- Breadcrumb -->
   <div class="mb-4 text-sm text-gray-500">
      <span class="font-medium text-green-600">Trang chủ</span>
      >
      <span>Mẫu CV theo style</span>
      >
      <span class="font-semibold text-gray-700">
         Mẫu CV xin việc tiếng Việt Hiện đại chuẩn 2026
      </span>
   </div>

   <!-- TITLE -->
   <div class="flex items-center justify-between mb-6">

      <div>

         <h1 class="text-3xl font-bold text-gray-800">
            Mẫu CV xin việc tiếng Việt
            <span class="text-green-600">
               Hiện đại
            </span>
            chuẩn 2026
         </h1>

         <p class="max-w-2xl mt-2 text-gray-500">
            Tuyển chọn 21 mẫu CV tiếng Việt có thiết kế hiện đại, dễ đọc và dễ sử dụng.
            Phù hợp với ứng viên muốn tập trung vào nội dung hơn là trang trí.
         </p>

      </div>

      <!-- Robot -->
      <img src="https://cdn-icons-png.flaticon.com/512/4712/4712109.png" class="w-24">
   </div>

   <!-- FILTER -->
   <div class="flex flex-wrap gap-3 mb-8">

      <a href="/Create_CV/All_CV_Style"
         class="px-4 py-2 transition duration-300 bg-gray-200 rounded-full hover:bg-emerald-500 hover:text-white hover:-translate-y-1">
         Tất cả
      </a>

      <a href="/Create_CV/Simple_CV"
         class="px-4 py-2 transition duration-300 bg-gray-200 rounded-full hover:bg-emerald-500 hover:text-white hover:-translate-y-1">
         Đơn giản
      </a>

      <a href="/Create_CV/CVChuyenNghiep"
         class="px-4 py-2 transition duration-300 bg-gray-200 rounded-full hover:bg-emerald-500 hover:text-white hover:-translate-y-1">
         Chuyên nghiệp
      </a>

      <a href="/Create_CV/Modern_CV"
         class="px-4 py-2 transition duration-300 rounded-full bg-emerald-500 hover:bg-emerald-500 hover:text-white hover:-translate-y-1">
         Hiện đại
      </a>

   </div>


   <!-- TEMPLATE GRID -->
   <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">

      <!-- CARD 1 -->
      <div class="p-4 transition bg-white shadow rounded-xl hover:shadow-2xl hover:-translate-y-2">

         <div class="relative overflow-hidden rounded-lg group">

            <img src="/images/cv4.jpg" class="w-full h-112.5 object-cover rounded-lg">

            <!-- Hover -->
            <div
               class="absolute inset-0 flex items-center justify-center transition opacity-0 bg-black/50 group-hover:opacity-100">

               <a href="/CV/Builder"
                  class="px-6 py-3 font-semibold text-white transition rounded-lg bg-linear-to-r from-emerald-500 to-purple-500 hover:scale-105">
                  Dùng mẫu
               </a>

            </div>

         </div>

         <!-- TAG -->
         <div class="flex gap-2 mt-3">

            <span class="px-2 py-1 text-xs text-white rounded-full bg-cyan-500">
               Hiện đại
            </span>

            <span class="px-2 py-1 text-xs text-purple-700 bg-purple-100 rounded-full">
               Chuyên nghiệp
            </span>

         </div>

      </div>
      <!-- CARD 2 -->
      <div class="p-4 transition bg-white shadow rounded-xl hover:shadow-2xl hover:-translate-y-2">

         <div class="relative overflow-hidden rounded-lg group">

            <img src="/images/cv5.jpg" class="w-full h-112.5 object-cover">

            <div
               class="absolute inset-0 flex items-center justify-center transition opacity-0 bg-black/50 group-hover:opacity-100">

               <a href="/CV/Builder"
                  class="px-6 py-3 font-semibold text-white transition rounded-lg bg-linear-to-r from-emerald-500 to-purple-500 hover:scale-105">
                  Dùng mẫu
               </a>

            </div>

         </div>

         <div class="flex gap-2 p-3">

            <span class="px-2 py-1 text-xs text-white rounded-full bg-cyan-500">
               Hiện đại
            </span>

            <span class="px-2 py-1 text-xs text-purple-700 bg-purple-100 rounded-full">
               Chuyên nghiệp
            </span>

         </div>

      </div>


      <!-- CARD 3 -->
      <div class="p-4 transition bg-white shadow rounded-xl hover:shadow-2xl hover:-translate-y-2">

         <div class="relative overflow-hidden rounded-lg group">

            <img src="/images/cv6.jpg" class="w-full h-112.5 object-cover">

            <div
               class="absolute inset-0 flex items-center justify-center transition opacity-0 bg-black/50 group-hover:opacity-100">

               <a href="/CV/Builder"
                  class="px-6 py-3 font-semibold text-white transition rounded-lg bg-linear-to-r from-emerald-500 to-purple-500 hover:scale-105">
                  Dùng mẫu
               </a>

            </div>

         </div>

         <div class="flex gap-2 p-3">

            <span class="px-2 py-1 text-xs rounded-full bg-emerald-100 text-emerald-700">
               Đơn giản
            </span>

            <span class="px-2 py-1 text-xs text-purple-700 bg-purple-100 rounded-full">
               Chuyên nghiệp
            </span>

         </div>

      </div>

   </div>

</div>
@* ===== DÁN PHẦN NÀY SAU PHẦN GRID MẪU CV (sau thẻ </div> cuối của grid cards) ===== *@

@* --- STATS BAR - Phong cách tối/dark hiện đại --- *@
<div class="bg-gray-900 py-8 px-4 mt-10">
   <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-gray-700">
         <div class="bg-gray-900 text-center py-6 px-4">
            <div class="text-3xl font-black text-emerald-400 mb-1 tracking-tight">21+</div>
            <div class="text-xs text-gray-400 uppercase tracking-widest">Mẫu hiện đại</div>
         </div>
         <div class="bg-gray-900 text-center py-6 px-4">
            <div class="text-3xl font-black text-emerald-400 mb-1 tracking-tight">100%</div>
            <div class="text-xs text-gray-400 uppercase tracking-widest">Miễn phí</div>
         </div>
         <div class="bg-gray-900 text-center py-6 px-4">
            <div class="text-3xl font-black text-emerald-400 mb-1 tracking-tight">ATS</div>
            <div class="text-xs text-gray-400 uppercase tracking-widest">Chuẩn lọc tự động</div>
         </div>
         <div class="bg-gray-900 text-center py-6 px-4">
            <div class="text-3xl font-black text-emerald-400 mb-1 tracking-tight">5 phút</div>
            <div class="text-xs text-gray-400 uppercase tracking-widest">Hoàn thành CV</div>
         </div>
      </div>
   </div>
</div>

@* --- CV HIỆN ĐẠI PHÙ HỢP VỚI AI --- *@
<div class="bg-gradient-to-br from-gray-50 to-slate-100 py-16 px-4">
   <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row items-center gap-10">
         <div class="flex-1">
            <span
               class="inline-block bg-emerald-100 text-emerald-700 text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">CV
               Hiện đại 2026</span>
               <h2 class="text-2xl md:text-3xl font-black text-gray-900 leading-tight mb-4">
                  CV hiện đại — <br />
                  <span class="text-emerald-500">Ấn tượng ngay</span> từ giây đầu tiên
               </h2>
               <p class="text-gray-500 text-sm leading-relaxed mb-6">
                  Thiết kế tối giản nhưng có chiều sâu, phù hợp với xu hướng tuyển dụng của các công ty công nghệ, startup
                  và doanh nghiệp quốc tế. Bố cục thông minh giúp nhà tuyển dụng nắm bắt thông tin trong vài giây.
               </p>
               <div class="flex flex-wrap gap-3">
                  <div
                     class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm text-gray-600 shadow-sm">
                     <span class="text-emerald-500">✓</span> Tối giản — chuyên nghiệp
                  </div>
                  <div
                     class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm text-gray-600 shadow-sm">
                     <span class="text-emerald-500">✓</span> Phù hợp ngành Tech & Creative
                  </div>
                  <div
                     class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm text-gray-600 shadow-sm">
                     <span class="text-emerald-500">✓</span> Nổi bật trong hàng trăm hồ sơ
                  </div>
               </div>
            </div>
            <div class="flex-shrink-0 w-full md:w-64">
               <div class="bg-gray-900 rounded-2xl p-6 text-center shadow-2xl">
                  <div
                     class="w-16 h-16 rounded-full bg-emerald-400 mx-auto mb-4 flex items-center justify-center text-gray-900 text-2xl font-black">
                     CV</div>
                     <div class="text-white font-bold text-base mb-1">Mẫu CV Hiện đại</div>
                     <div class="text-gray-400 text-xs mb-4">Chuẩn 2026 · ATS-friendly</div>
                     <div class="space-y-2">
                        <div class="h-2 bg-gray-700 rounded-full overflow-hidden">
                           <div class="h-full bg-emerald-400 rounded-full" style="width:90%"></div>
                        </div>
                        <div class="h-2 bg-gray-700 rounded-full overflow-hidden">
                           <div class="h-full bg-emerald-400 rounded-full" style="width:75%"></div>
                        </div>
                        <div class="h-2 bg-gray-700 rounded-full overflow-hidden">
                           <div class="h-full bg-emerald-400 rounded-full" style="width:85%"></div>
                        </div>
                     </div>
                     <div class="text-xs text-gray-500 mt-3">Điểm ATS: 95/100</div>
                  </div>
               </div>
            </div>
         </div>
      </div>

      @* --- NGÀNH NGHỀ PHÙ HỢP --- *@
      <div class="bg-white py-16 px-4">
         <div class="max-w-5xl mx-auto">
            <h2 class="text-2xl md:text-3xl font-black text-center text-gray-900 mb-2">
               Phù hợp với <span class="text-emerald-500">ngành nghề</span> nào?
            </h2>
            <p class="text-center text-gray-400 text-sm mb-10">CV hiện đại được thiết kế đặc biệt cho những lĩnh vực sáng tạo
               & công nghệ</p>

               <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
                  <div
                     class="group text-center p-5 rounded-2xl border border-gray-100 hover:border-emerald-300 hover:bg-emerald-50 transition-all duration-200 cursor-default">
                     <div class="text-3xl mb-2">💻</div>
                     <div class="text-xs font-semibold text-gray-700 group-hover:text-emerald-700">IT / Lập trình</div>
                  </div>
                  <div
                     class="group text-center p-5 rounded-2xl border border-gray-100 hover:border-emerald-300 hover:bg-emerald-50 transition-all duration-200 cursor-default">
                     <div class="text-3xl mb-2">🎨</div>
                     <div class="text-xs font-semibold text-gray-700 group-hover:text-emerald-700">Thiết kế / UX</div>
                  </div>
                  <div
                     class="group text-center p-5 rounded-2xl border border-gray-100 hover:border-emerald-300 hover:bg-emerald-50 transition-all duration-200 cursor-default">
                     <div class="text-3xl mb-2">📱</div>
                     <div class="text-xs font-semibold text-gray-700 group-hover:text-emerald-700">Marketing Digital</div>
                  </div>
                  <div
                     class="group text-center p-5 rounded-2xl border border-gray-100 hover:border-emerald-300 hover:bg-emerald-50 transition-all duration-200 cursor-default">
                     <div class="text-3xl mb-2">🚀</div>
                     <div class="text-xs font-semibold text-gray-700 group-hover:text-emerald-700">Startup / Product</div>
                  </div>
                  <div
                     class="group text-center p-5 rounded-2xl border border-gray-100 hover:border-emerald-300 hover:bg-emerald-50 transition-all duration-200 cursor-default">
                     <div class="text-3xl mb-2">📊</div>
                     <div class="text-xs font-semibold text-gray-700 group-hover:text-emerald-700">Data / AI</div>
                  </div>
                  <div
                     class="group text-center p-5 rounded-2xl border border-gray-100 hover:border-emerald-300 hover:bg-emerald-50 transition-all duration-200 cursor-default">
                     <div class="text-3xl mb-2">🌐</div>
                     <div class="text-xs font-semibold text-gray-700 group-hover:text-emerald-700">Công ty quốc tế</div>
                  </div>
               </div>
            </div>
         </div>

         @* --- 3 BƯỚC - DARK STYLE --- *@
         <div class="bg-gray-900 py-16 px-4">
            <div class="max-w-5xl mx-auto">
               <h2 class="text-2xl md:text-3xl font-black text-center text-white mb-2">
                  Tạo CV hiện đại <span class="text-emerald-400">siêu tốc</span>
               </h2>
               <p class="text-center text-gray-500 text-sm mb-12">3 bước — dưới 10 phút — không cần kỹ năng thiết kế</p>

               <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                  <div
                     class="relative border border-gray-700 rounded-2xl p-6 hover:border-emerald-500 transition-colors duration-300">
                     <div class="text-5xl font-black text-gray-800 mb-4 leading-none">01</div>
                     <div class="text-emerald-400 font-bold text-base mb-2">Chọn layout</div>
                     <div class="text-gray-400 text-sm leading-relaxed">Chọn bố cục hiện đại phù hợp với phong cách và lĩnh vực
                        của bạn.</div>
                        <div
                           class="absolute top-6 right-6 w-8 h-8 rounded-lg bg-emerald-400/10 flex items-center justify-center text-emerald-400 text-sm">
                           →</div>
                        </div>
                        <div class="relative border border-emerald-500 rounded-2xl p-6 bg-emerald-500/5">
                           <div class="text-5xl font-black text-cyan-900 mb-4 leading-none">02</div>
                           <div class="text-emerald-400 font-bold text-base mb-2">Điền thông tin</div>
                           <div class="text-gray-400 text-sm leading-relaxed">Nhập kinh nghiệm, kỹ năng và thành tích nổi bật theo gợi
                              ý thông minh.</div>
                              <div
                                 class="absolute top-6 right-6 w-8 h-8 rounded-lg bg-emerald-400/10 flex items-center justify-center text-emerald-400 text-sm">
                                 →</div>
                              </div>
                              <div
                                 class="relative border border-gray-700 rounded-2xl p-6 hover:border-emerald-500 transition-colors duration-300">
                                 <div class="text-5xl font-black text-gray-800 mb-4 leading-none">03</div>
                                 <div class="text-emerald-400 font-bold text-base mb-2">Export PDF</div>
                                 <div class="text-gray-400 text-sm leading-relaxed">Tải xuống PDF sắc nét, sẵn sàng gửi cho nhà tuyển dụng
                                    ngay lập tức.</div>
                                 </div>
                              </div>
                           </div>
                        </div>

                        @* --- SO SÁNH CV HIỆN ĐẠI VS TRUYỀN THỐNG --- *@
                        <div class="bg-slate-50 py-16 px-4">
                           <div class="max-w-4xl mx-auto">
                              <h2 class="text-2xl md:text-3xl font-black text-center text-gray-900 mb-2">
                                 CV hiện đại <span class="text-emerald-500">vượt trội</span> như thế nào?
                              </h2>
                              <p class="text-center text-gray-400 text-sm mb-10">So sánh với CV truyền thống để thấy sự khác biệt rõ ràng</p>

                              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                 @* CV Cũ *@
                                 <div class="bg-white border border-gray-200 rounded-2xl p-6">
                                    <div class="flex items-center gap-3 mb-5">
                                       <div
                                          class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center text-gray-400 text-sm font-bold">
                                          ✕</div>
                                          <div class="font-bold text-gray-500">CV truyền thống</div>
                                       </div>
                                       <div class="space-y-3">
                                          <div class="flex items-center gap-3 text-sm text-gray-400"><span class="text-red-400 text-base">✗</span>
                                             Bố cục đơn điệu, dễ bị bỏ qua</div>
                                             <div class="flex items-center gap-3 text-sm text-gray-400"><span class="text-red-400 text-base">✗</span>
                                                Không nổi bật trong hàng trăm hồ sơ</div>
                                                <div class="flex items-center gap-3 text-sm text-gray-400"><span class="text-red-400 text-base">✗</span>
                                                   Thông tin dày đặc, khó đọc nhanh</div>
                                                   <div class="flex items-center gap-3 text-sm text-gray-400"><span class="text-red-400 text-base">✗</span>
                                                      Không phù hợp ngành sáng tạo / tech</div>
                                                      <div class="flex items-center gap-3 text-sm text-gray-400"><span class="text-red-400 text-base">✗</span>
                                                         Mất nhiều giờ định dạng thủ công</div>
                                                      </div>
                                                   </div>
                                                   @* CV Hiện đại *@
                                                   <div class="bg-gray-900 border border-emerald-500/30 rounded-2xl p-6">
                                                      <div class="flex items-center gap-3 mb-5">
                                                         <div
                                                            class="w-8 h-8 rounded-lg bg-emerald-400/20 flex items-center justify-center text-emerald-400 text-sm font-bold">
                                                            ★</div>
                                                            <div class="font-bold text-white">CV Hiện đại SRB</div>
                                                         </div>
                                                         <div class="space-y-3">
                                                            <div class="flex items-center gap-3 text-sm text-gray-300"><span
                                                               class="text-emerald-400 text-base">✓</span> Bố cục trực quan, thu hút ngay ánh nhìn</div>
                                                               <div class="flex items-center gap-3 text-sm text-gray-300"><span
                                                                  class="text-emerald-400 text-base">✓</span> Thiết kế độc đáo, ghi dấu ấn mạnh mẽ</div>
                                                                  <div class="flex items-center gap-3 text-sm text-gray-300"><span
                                                                     class="text-emerald-400 text-base">✓</span> Phân cấp thông tin rõ ràng, dễ scan</div>
                                                                     <div class="flex items-center gap-3 text-sm text-gray-300"><span
                                                                        class="text-emerald-400 text-base">✓</span> Tối ưu cho ngành Tech, Design, Marketing</div>
                                                                        <div class="flex items-center gap-3 text-sm text-gray-300"><span
                                                                           class="text-emerald-400 text-base">✓</span> Hoàn thành trong 5 phút với template có sẵn</div>
                                                                        </div>
                                                                     </div>
                                                                  </div>
                                                               </div>
                                                            </div>

                                                            @* --- TIPS DÀNH RIÊNG CHO CV HIỆN ĐẠI --- *@
                                                            <div class="bg-white py-16 px-4">
                                                               <div class="max-w-5xl mx-auto">
                                                                  <h2 class="text-2xl md:text-3xl font-black text-center text-gray-900 mb-2">
                                                                     Mẹo tối ưu <span class="text-emerald-500">CV hiện đại</span>
                                                                  </h2>
                                                                  <p class="text-center text-gray-400 text-sm mb-10">Áp dụng những nguyên tắc thiết kế hiện đại để CV của bạn thực
                                                                     sự ấn tượng</p>

                                                                     <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                                                                        <div
                                                                           class="group p-5 rounded-2xl border border-gray-100 hover:border-emerald-200 hover:shadow-lg hover:shadow-cyan-50 transition-all duration-200">
                                                                           <div
                                                                              class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-xl mb-4 group-hover:bg-emerald-100 transition-colors">
                                                                              ⚡</div>
                                                                              <div class="font-bold text-gray-800 text-sm mb-2">Thông tin ở đầu — quan trọng nhất</div>
                                                                              <div class="text-xs text-gray-400 leading-relaxed">Nhà tuyển dụng chỉ nhìn CV 6-10 giây. Đặt thành tích nổi
                                                                                 bật nhất lên đầu trang.</div>
                                                                              </div>
                                                                              <div
                                                                                 class="group p-5 rounded-2xl border border-gray-100 hover:border-emerald-200 hover:shadow-lg hover:shadow-cyan-50 transition-all duration-200">
                                                                                 <div
                                                                                    class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-xl mb-4 group-hover:bg-emerald-100 transition-colors">
                                                                                    🎯</div>
                                                                                    <div class="font-bold text-gray-800 text-sm mb-2">Dùng thanh kỹ năng trực quan</div>
                                                                                    <div class="text-xs text-gray-400 leading-relaxed">CV hiện đại cho phép hiển thị mức độ thành thạo bằng
                                                                                       thanh progress bar thay vì liệt kê chữ.</div>
                                                                                    </div>
                                                                                    <div
                                                                                       class="group p-5 rounded-2xl border border-gray-100 hover:border-emerald-200 hover:shadow-lg hover:shadow-cyan-50 transition-all duration-200">
                                                                                       <div
                                                                                          class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-xl mb-4 group-hover:bg-emerald-100 transition-colors">
                                                                                          🌗</div>
                                                                                          <div class="font-bold text-gray-800 text-sm mb-2">Bố cục 2 cột tối ưu không gian</div>
                                                                                          <div class="text-xs text-gray-400 leading-relaxed">Chia sidebar cho kỹ năng, liên hệ — nội dung chính bên
                                                                                             phải giúp CV cân đối và hiện đại hơn.</div>
                                                                                          </div>
                                                                                          <div
                                                                                             class="group p-5 rounded-2xl border border-gray-100 hover:border-emerald-200 hover:shadow-lg hover:shadow-cyan-50 transition-all duration-200">
                                                                                             <div
                                                                                                class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-xl mb-4 group-hover:bg-emerald-100 transition-colors">
