                                                                                                                        <script>
                                                                                                                           function toggleModernFaq(btn) {
                                                                                                                              var body = btn.nextElementSibling;
                                                                                                                              var icon = btn.querySelector('.modern-faq-icon');
                                                                                                                              var isOpen = !body.classList.contains('hidden');
                                                                                                                              document.querySelectorAll('#modernFaqList .modern-faq-body').forEach(function (b) { b.classList.add('hidden'); });
                                                                                                                              document.querySelectorAll('#modernFaqList .modern-faq-icon').forEach(function (i) { i.textContent = '+'; });
                                                                                                                              if (!isOpen) {
                                                                                                                                 body.classList.remove('hidden');
                                                                                                                                 icon.textContent = '−';
                                                                                                                              }
                                                                                                                           }
                                                                                                                        </script>

