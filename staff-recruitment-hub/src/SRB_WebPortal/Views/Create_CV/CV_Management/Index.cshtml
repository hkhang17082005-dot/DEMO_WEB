@{
   ViewData["Title"] = "Quản lý CV";
   Layout = "~/Views/Shared/_Layout.cshtml";

   var userName = ViewBag.UserName ?? "Nguyễn Việt Quang";
   var isVerified = ViewBag.IsVerified ?? true;
   var cvCount = ViewBag.CVCount ?? 0;
   var openToWork = ViewBag.OpenToWork ?? false;
   var allowSearch = ViewBag.AllowSearch ?? false;
   var cvs = ViewBag.CVs as List<dynamic>;
}

<script>
   tailwind.config = {
      theme: {
         extend: {
            colors: {
               brand: '#00b14f',
               brandDark: '#009643',
               brandSoft: '#e8fff1',
               pageBg: '#f3fbf6'
            },
            boxShadow: {
               soft: '0 10px 30px rgba(2, 132, 77, 0.08)',
               softLg: '0 18px 40px rgba(2, 132, 77, 0.12)'
            }
         }
      }
   }
</script>

<main class="min-h-screen bg-pageBg py-8">
   <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">

         <!-- LEFT -->
         <div class="space-y-6 lg:col-span-2">

            <!-- HERO -->
            <section
               class="relative overflow-hidden rounded-[32px] bg-gradient-to-br from-emerald-500 via-emerald-600 to-green-700 px-8 py-10 text-white shadow-softLg">
               <div class="absolute -right-12 -top-12 h-44 w-44 rounded-full bg-white/10 blur-3xl"></div>
               <div class="absolute bottom-0 left-1/3 h-28 w-28 rounded-full bg-yellow-300/10 blur-2xl"></div>
               <div class="absolute -bottom-10 left-8 h-32 w-32 rounded-full bg-white/5 blur-2xl"></div>

               <div class="relative flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
                  <div class="max-w-2xl">
                     <div
                        class="mb-4 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm backdrop-blur">
                        <i class="fa-solid fa-folder-open"></i>
                        <span>Trang quản lý hồ sơ CV cá nhân</span>
                     </div>

                     <h1 class="text-4xl font-black leading-tight md:text-5xl">
                        Quản lý <span class="text-yellow-300">CV của bạn</span>
                     </h1>

                     <p class="mt-4 max-w-xl text-base leading-7 text-emerald-50 md:text-lg">
                        Theo dõi các CV đã tạo, chỉnh sửa nhanh, xem trước trước khi ứng tuyển và tối ưu hồ sơ để tăng
                        cơ hội được nhà tuyển dụng chú ý.
                     </p>

                     <div class="mt-6 flex flex-wrap gap-3">
                        <div class="rounded-full bg-white/15 px-4 py-2 text-sm backdrop-blur">
                           <span class="font-bold">@cvCount</span> CV trên hệ thống
                        </div>
                        <div class="rounded-full bg-white/15 px-4 py-2 text-sm backdrop-blur">
                           Chỉnh sửa nhanh
                        </div>
                        <div class="rounded-full bg-white/15 px-4 py-2 text-sm backdrop-blur">
                           Xem trước dễ dàng
                        </div>
                     </div>
                  </div>

                  <div class="flex flex-wrap gap-3">
                     <a href="/Create_CV/Create"
                        class="inline-flex items-center gap-2 rounded-2xl bg-white px-6 py-3.5 text-sm font-bold text-emerald-700 shadow-lg transition hover:-translate-y-0.5 hover:bg-emerald-50">
                        <i class="fa-solid fa-plus"></i>
                        Tạo CV mới
                     </a>

                     <a href="/Create_CV/Upload_CV"
                        class="inline-flex items-center gap-2 rounded-2xl border border-white/25 bg-white/10 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/20">
                        <i class="fa-solid fa-upload"></i>
                        Tải CV từ máy tính
                     </a>
                  </div>
               </div>
            </section>

            <!-- LIST HEADER + SEARCH -->
            <section class="rounded-[28px] border border-emerald-50 bg-white p-6 shadow-soft">
               <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                  <div>
                     <h2 class="text-2xl font-black text-slate-800">CV đã tạo trên hệ thống</h2>
                     <p class="mt-1 text-sm text-slate-500">
                        Quản lý, chỉnh sửa, xem trước và sử dụng CV để ứng tuyển nhanh chóng.
                     </p>
                  </div>

                  <div class="flex flex-col gap-3 sm:flex-row">
                     <div class="relative">
                        <i
                        class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        <input id="cvSearch" type="text" placeholder="Tìm theo tên CV..."
                               class="w-full rounded-2xl border border-slate-200 bg-slate-50 py-3 pl-11 pr-4 text-sm outline-none transition focus:border-emerald-400 focus:bg-white sm:w-72" />
                     </div>

                     <a href="/Create_CV/Create"
                        class="inline-flex items-center justify-center gap-2 rounded-2xl bg-emerald-600 px-5 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-emerald-700">
                        <i class="fa-solid fa-plus"></i>
                        Tạo CV mới
                     </a>
                  </div>
               </div>

               <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3">
                  <div class="rounded-2xl bg-emerald-50 p-4">
                     <div class="flex items-center gap-3">
                        <div
                           class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-100 text-emerald-600">
                           <i class="fa-solid fa-file-lines"></i>
                        </div>
                        <div>
                           <p class="text-sm text-slate-500">Tổng số CV</p>
                           <p class="text-xl font-black text-slate-800">@cvCount</p>
                        </div>
                     </div>
                  </div>

                  <div class="rounded-2xl bg-sky-50 p-4">
                     <div class="flex items-center gap-3">
                        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
                           <i class="fa-solid fa-eye"></i>
                        </div>
                        <div>
                           <p class="text-sm text-slate-500">Sẵn sàng xem trước</p>
                           <p class="text-xl font-black text-slate-800">Preview</p>
                        </div>
                     </div>
                  </div>

                  <div class="rounded-2xl bg-amber-50 p-4">
                     <div class="flex items-center gap-3">
                        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-100 text-amber-600">
                           <i class="fa-solid fa-pen-to-square"></i>
                        </div>
                        <div>
                           <p class="text-sm text-slate-500">Trạng thái quản lý</p>
                           <p class="text-xl font-black text-slate-800">Đầy đủ</p>
                        </div>
                     </div>
                  </div>
               </div>
            </section>

            <!-- CV LIST -->
            <section class="rounded-[28px] border border-emerald-50 bg-white p-6 shadow-soft">
               @if (cvs != null && cvs.Count > 0)
               {
                  <div id="cvList" class="grid grid-cols-1 gap-5 md:grid-cols-2">
                     @foreach (var cv in cvs)
                     {
                        <article
                           class="cv-card group rounded-[26px] border border-slate-200 bg-white p-5 transition duration-200 hover:-translate-y-1 hover:border-emerald-300 hover:shadow-softLg">
                           <div class="mb-4 flex items-start justify-between gap-3">
                              <div>
                                 <h3 class="cv-title text-[28px] leading-tight font-black text-slate-800 md:text-[30px]">
                                    @cv.Title
                                 </h3>
                                 <p class="mt-2 text-sm text-slate-500">
                                    <i class="fa-regular fa-clock mr-1"></i>
                                    Cập nhật: @cv.UpdatedAt
                                 </p>
                              </div>

                              <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700">
                                 @cv.Status
                              </span>
                           </div>

                           <div class="mb-5 rounded-2xl bg-slate-50 p-4">
                              <div class="flex items-center gap-3">
                                 <div
                                    class="flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-600">
                                    <i class="fa-solid fa-file-lines text-xl"></i>
                                 </div>
                                 <div>
                                    <p class="font-bold text-slate-700">Mẫu CV chuyên nghiệp</p>
                                    <p class="text-sm text-slate-500">Sẵn sàng để chỉnh sửa và ứng tuyển</p>
                                 </div>
                              </div>
                           </div>

                           <div class="grid grid-cols-2 gap-3">
                              <a href="/Create_CV/Edit/@cv.Id"
                                 class="inline-flex items-center justify-center gap-2 rounded-2xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-emerald-700">
                                 <i class="fa-solid fa-pen"></i>
                                 Chỉnh sửa
                              </a>

                              <a href="/Create_CV/Preview/@cv.Id"
                                 class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                                 <i class="fa-solid fa-eye"></i>
                                 Xem trước
                              </a>

                              <button type="button" onclick="window.print()"
                                      class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                                 <i class="fa-solid fa-download"></i>
                                 Tải xuống
                              </button>

                              <form method="post" action="/Create_CV/Delete/@cv.Id" class="w-full">
                                 @Html.AntiForgeryToken()
                                 <button type="submit" onclick="return confirm('Bạn có chắc muốn xóa CV này không?')"
                                         class="inline-flex w-full items-center justify-center gap-2 rounded-2xl border border-red-200 bg-white px-4 py-3 text-sm font-semibold text-red-600 transition hover:bg-red-50">
                                    <i class="fa-solid fa-trash"></i>
                                    Xóa
                                 </button>
                              </form>
                           </div>
                        </article>
                     }
                  </div>

                  <div id="emptySearch" class="hidden py-16 text-center">
                     <div
                        class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-slate-100 text-slate-400">
                        <i class="fa-solid fa-magnifying-glass text-3xl"></i>
                     </div>
                     <h3 class="mt-5 text-2xl font-black text-slate-800">Không tìm thấy CV phù hợp</h3>
                     <p class="mt-2 text-slate-500">Thử nhập từ khóa khác hoặc tạo một CV mới.</p>
                  </div>
               }
               else
               {
                  <div
                     class="rounded-[28px] border border-dashed border-emerald-200 bg-gradient-to-b from-emerald-50 to-white px-6 py-16 text-center">
                     <div
                        class="mx-auto flex h-28 w-28 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 shadow-inner">
                        <i class="fa-regular fa-file-lines text-5xl"></i>
                     </div>

                     <h3 class="mt-6 text-4xl font-black text-slate-800">Bạn chưa tạo CV nào</h3>
                     <p class="mx-auto mt-3 max-w-xl text-lg leading-8 text-slate-500">
                        Hãy tạo CV đầu tiên để bắt đầu ứng tuyển ngay hôm nay. Một hồ sơ đẹp và rõ ràng sẽ giúp bạn tạo ấn
                        tượng tốt hơn với nhà tuyển dụng.
                     </p>

                     <div class="mt-8 flex flex-wrap justify-center gap-4">
                        <a href="/Create_CV/Create"
                           class="inline-flex items-center gap-2 rounded-2xl bg-emerald-600 px-7 py-3.5 font-bold text-white shadow-md transition hover:bg-emerald-700">
                           <i class="fa-solid fa-plus"></i>
                           Tạo CV mới
                        </a>

                        <a href="/Create_CV/Upload_CV"
                           class="inline-flex items-center gap-2 rounded-2xl border border-emerald-200 bg-white px-7 py-3.5 font-bold text-emerald-700 transition hover:bg-emerald-50">
                           <i class="fa-solid fa-upload"></i>
                           Tải CV lên
                        </a>
                     </div>
                  </div>
               }
            </section>
         </div>

         <!-- RIGHT -->
         <aside class="space-y-6">

            <!-- PROFILE -->
            <section class="overflow-hidden rounded-[28px] border border-emerald-50 bg-white shadow-soft">
               <div class="h-24 bg-gradient-to-r from-emerald-500 via-green-500 to-teal-500"></div>

               <div class="-mt-12 px-6 pb-6">
                  <div class="flex items-end gap-4">
                     <div class="relative">
                        <div
                           class="flex h-24 w-24 items-center justify-center rounded-full border-4 border-white bg-emerald-100 text-emerald-600 shadow-lg">
                           <i class="fa-solid fa-user text-4xl"></i>
                        </div>
                        <span
                        class="absolute bottom-1 right-1 flex h-5 w-5 rounded-full border-2 border-white bg-emerald-500"></span>
                     </div>

                     <div class="pb-2">
                        @if (isVerified)
                        {
                           <span
                              class="inline-block rounded-full bg-amber-100 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-amber-700">
                              Verified
                           </span>
                        }
                        else
                        {
                           <span
                              class="inline-block rounded-full bg-slate-100 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-slate-600">
                              Chưa xác thực
                           </span>
                        }

                        <h3 class="mt-2 text-3xl font-black text-slate-800">@userName</h3>
                        <p class="mt-1 text-sm text-slate-500">
                           @(isVerified ? "Tài khoản đã xác thực" : "Tài khoản chưa xác thực")
                        </p>
                     </div>
                  </div>

                  <div class="mt-6 grid grid-cols-2 gap-3">
                     <div class="rounded-2xl bg-emerald-50 p-5 text-center">
                        <p class="text-3xl font-black text-emerald-700">@cvCount</p>
                        <p class="mt-1 text-sm text-slate-600">CV hiện có</p>
                     </div>
                     <div class="rounded-2xl bg-slate-50 p-5 text-center">
                        <p class="text-3xl font-black text-slate-700">Pro</p>
                        <p class="mt-1 text-sm text-slate-600">Gói tài khoản</p>
                     </div>
                  </div>

                  <button
                     class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-2xl border-2 border-emerald-600 py-3.5 font-bold text-emerald-600 transition hover:bg-emerald-50">
                     <i class="fa-solid fa-crown text-amber-500"></i>
                     Nâng cấp tài khoản
                  </button>
               </div>
            </section>

            <!-- SETTINGS -->
            <section class="rounded-[28px] border border-emerald-50 bg-white p-6 shadow-soft">
               <div class="mb-5">
                  <h3 class="text-2xl font-black text-slate-800">Cài đặt tìm việc</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-500">
                     Quản lý trạng thái hiển thị hồ sơ và khả năng được nhà tuyển dụng tìm thấy.
                  </p>
               </div>

               <div class="space-y-4">
                  <div class="rounded-2xl bg-slate-50 p-4">
                     <div class="flex items-start justify-between gap-4">
                        <div>
                           <p class="font-bold text-slate-800">Trạng thái tìm việc</p>
                           <p class="mt-1 text-sm leading-6 text-slate-500">
                              Bật để nhà tuyển dụng chủ động liên hệ khi hồ sơ phù hợp.
                           </p>
                        </div>

                        <label class="relative inline-flex cursor-pointer items-center">
                           <input id="openToWork" type="checkbox" class="peer sr-only" @(openToWork ? "checked" : "")>
                           <div
                              class="h-7 w-14 rounded-full bg-slate-300 transition peer-checked:bg-emerald-600 after:absolute after:left-1 after:top-1 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-7">
                           </div>
                        </label>
                     </div>
                  </div>

                  <div class="rounded-2xl bg-slate-50 p-4">
                     <div class="flex items-start justify-between gap-4">
                        <div>
                           <p class="font-bold text-slate-800">Cho phép NTD tìm hồ sơ</p>
                           <p class="mt-1 text-sm leading-6 text-slate-500">
                              Hiển thị hồ sơ của bạn trong kết quả tìm kiếm của doanh nghiệp.
                           </p>
                        </div>

                        <label class="relative inline-flex cursor-pointer items-center">
                           <input id="allowSearch" type="checkbox" class="peer sr-only" @(allowSearch ? "checked" : "")>
                           <div
                              class="h-7 w-14 rounded-full bg-slate-300 transition peer-checked:bg-emerald-600 after:absolute after:left-1 after:top-1 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-7">
                           </div>
                        </label>
                     </div>
                  </div>
               </div>

               <div
                  class="mt-5 rounded-2xl border border-emerald-100 bg-emerald-50 p-4 text-sm leading-6 text-emerald-800">
                  <div class="flex items-start gap-2">
                     <i class="fa-solid fa-circle-info mt-1"></i>
                     <p>
                        Hồ sơ đầy đủ và bật trạng thái tìm việc sẽ giúp tăng khả năng được nhà tuyển dụng chú ý.
                     </p>
                  </div>
               </div>
            </section>

            <!-- QUICK ACTION -->
            <section class="rounded-[28px] border border-emerald-50 bg-white p-6 shadow-soft">
               <h3 class="text-2xl font-black text-slate-800">Thao tác nhanh</h3>

               <div class="mt-4 space-y-3">
                  <a href="/Create_CV/Create"
                     class="flex items-center justify-between rounded-2xl border border-slate-200 px-4 py-4 transition hover:border-emerald-300 hover:bg-emerald-50">
                     <span class="flex items-center gap-3 font-semibold text-slate-700">
                        <i class="fa-solid fa-wand-magic-sparkles text-emerald-600"></i>
                        Tạo CV mới
                     </span>
                     <i class="fa-solid fa-chevron-right text-slate-400"></i>
                  </a>

                  <a href="/Create_CV/Upload_CV"
                     class="flex items-center justify-between rounded-2xl border border-slate-200 px-4 py-4 transition hover:border-emerald-300 hover:bg-emerald-50">
                     <span class="flex items-center gap-3 font-semibold text-slate-700">
                        <i class="fa-solid fa-cloud-arrow-up text-emerald-600"></i>
                        Upload CV
                     </span>
                     <i class="fa-solid fa-chevron-right text-slate-400"></i>
                  </a>

                  <a href="/Create_CV/All_CV_Style"
                     class="flex items-center justify-between rounded-2xl border border-slate-200 px-4 py-4 transition hover:border-emerald-300 hover:bg-emerald-50">
                     <span class="flex items-center gap-3 font-semibold text-slate-700">
                        <i class="fa-solid fa-layer-group text-emerald-600"></i>
                        Chọn mẫu CV
                     </span>
                     <i class="fa-solid fa-chevron-right text-slate-400"></i>
                  </a>
               </div>
            </section>
         </aside>
      </div>
   </div>
</main>

<script>
   document.addEventListener('DOMContentLoaded', function () {
      const searchInput = document.getElementById('cvSearch');
      const cards = document.querySelectorAll('.cv-card');
      const emptySearch = document.getElementById('emptySearch');
      const cvList = document.getElementById('cvList');

      if (searchInput && cards.length > 0) {
         searchInput.addEventListener('input', function () {
            const keyword = this.value.toLowerCase().trim();
            let visibleCount = 0;

            cards.forEach(card => {
               const title = card.querySelector('.cv-title')?.innerText.toLowerCase() || '';
               const matched = title.includes(keyword);

               card.style.display = matched ? '' : 'none';
               if (matched) visibleCount++;
            });

            if (emptySearch) {
               emptySearch.classList.toggle('hidden', visibleCount > 0);
            }

            if (cvList) {
               cvList.style.display = visibleCount > 0 ? 'grid' : 'none';
            }
         });
      }

      const openToWork = document.getElementById('openToWork');
      const allowSearch = document.getElementById('allowSearch');

      if (openToWork) {
         openToWork.addEventListener('change', function () {
            console.log('OpenToWork:', this.checked);
         });
      }

      if (allowSearch) {
         allowSearch.addEventListener('change', function () {
            console.log('AllowSearch:', this.checked);
         });
      }
   });
</script>