@* Views/Create_CV/Create/Index.cshtml *@
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CV Builder — SRB Recruitment</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f1f5f9; }

        /* ===== SIDEBAR ===== */
        #sidebar { width: 220px; min-width: 220px; background: #fff; border-right: 1px solid #e5e7eb; height: 100vh; position: sticky; top: 0; overflow-y: auto; }
        .sidebar-item { display: flex; align-items: center; gap: 10px; padding: 10px 16px; font-size: 13px; color: #374151; cursor: pointer; border-radius: 8px; margin: 2px 8px; transition: background .15s; }
        .sidebar-item:hover { background: #f0fdf4; color: #16a34a; }
        .sidebar-item.active { background: #dcfce7; color: #15803d; font-weight: 600; }
        .sidebar-item i { font-size: 18px; }

        /* ===== PANEL ===== */
        #panel { width: 280px; min-width: 280px; background: #fff; border-right: 1px solid #e5e7eb; height: 100vh; position: sticky; top: 0; overflow-y: auto; display: none; }
        #panel.open { display: block; }

        /* ===== CV PREVIEW ===== */
        #cv-wrap { flex: 1; display: flex; justify-content: center; padding: 24px; overflow-y: auto; height: 100vh; }
        #cv-paper { width: 794px; min-height: 1123px; background: #fff; box-shadow: 0 4px 24px rgba(0,0,0,.12); border-radius: 4px; padding: 40px 48px; position: relative; }

        /* ===== CV STYLES ===== */
        .cv-name { font-size: 28px; font-weight: 700; color: #111; }
        .cv-position { font-size: 14px; color: #6b7280; margin-top: 2px; }
        .cv-section-title { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #111; border-bottom: 1.5px solid #111; padding-bottom: 4px; margin: 20px 0 10px; }
        .cv-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px 24px; font-size: 12px; color: #374151; margin-top: 8px; }
        .cv-info-label { color: #9ca3af; font-size: 11px; }
        .cv-entry { margin-bottom: 12px; }
        .cv-entry-header { display: flex; justify-content: space-between; font-size: 13px; font-weight: 600; }
        .cv-entry-sub { font-size: 12px; color: #4b5563; }
        .cv-entry-desc { font-size: 12px; color: #6b7280; margin-top: 2px; line-height: 1.5; }
        .cv-skill-bar { height: 6px; background: #e5e7eb; border-radius: 3px; margin-top: 3px; }
        .cv-skill-fill { height: 100%; background: #16a34a; border-radius: 3px; transition: width .3s; }

        /* ===== EDITABLE ===== */
        [contenteditable] { outline: none; cursor: text; }
        [contenteditable]:hover { background: #f0fdf4; border-radius: 3px; }
        [contenteditable]:focus { background: #dcfce7; border-radius: 3px; outline: 1px dashed #16a34a; }

        /* ===== ENTRY DELETE BTN ===== */
        .entry-wrap { position: relative; }
        .entry-wrap:hover .del-btn { display: flex; }
        .del-btn { display: none; position: absolute; right: -24px; top: 0; width: 20px; height: 20px; background: #fee2e2; border-radius: 4px; align-items: center; justify-content: center; cursor: pointer; font-size: 12px; color: #dc2626; border: none; }

        /* ===== ADD BTN ===== */
        .add-btn { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: #16a34a; background: #f0fdf4; border: 1px dashed #86efac; border-radius: 8px; padding: 6px 14px; cursor: pointer; margin-top: 4px; transition: background .15s; }
        .add-btn:hover { background: #dcfce7; }

        /* ===== PHOTO ===== */
        #cv-photo-wrap { width: 90px; height: 90px; border-radius: 50%; overflow: hidden; border: 2px solid #e5e7eb; cursor: pointer; flex-shrink: 0; background: #f3f4f6; display: flex; align-items: center; justify-content: center; }
        #cv-photo-wrap img { width: 100%; height: 100%; object-fit: cover; }
        #photo-input { display: none; }

        /* ===== TOPBAR ===== */
        #topbar { background: #fff; border-bottom: 1px solid #e5e7eb; padding: 0 20px; height: 52px; display: flex; align-items: center; gap: 12px; position: sticky; top: 0; z-index: 50; }
        .tb-btn { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 500; padding: 7px 14px; border-radius: 8px; cursor: pointer; border: 1px solid #e5e7eb; background: #fff; color: #374151; transition: all .15s; }
        .tb-btn:hover { background: #f9fafb; }
        .tb-btn.green { background: #16a34a; color: #fff; border-color: #16a34a; }
        .tb-btn.green:hover { background: #15803d; }
        .tb-btn.blue { background: #1d4ed8; color: #fff; border-color: #1d4ed8; }
        .tb-btn.blue:hover { background: #1e40af; }
        .tb-btn i { font-size: 16px; }

        /* ===== TOAST ===== */
        #toast { position: fixed; bottom: 24px; right: 24px; background: #1a1a1a; color: #fff; padding: 10px 18px; border-radius: 10px; font-size: 13px; opacity: 0; pointer-events: none; transition: opacity .3s; z-index: 9999; }
        #toast.show { opacity: 1; }

        /* ===== FONT PANEL ===== */
        .font-opt { padding: 8px 12px; border-radius: 8px; border: 1px solid #e5e7eb; cursor: pointer; font-size: 13px; transition: all .15s; }
        .font-opt:hover, .font-opt.active { border-color: #16a34a; background: #f0fdf4; color: #15803d; }

        /* ===== LAYOUT OPTS ===== */
        .layout-opt { border: 2px solid #e5e7eb; border-radius: 10px; padding: 10px; cursor: pointer; transition: all .15s; text-align: center; font-size: 12px; }
        .layout-opt:hover, .layout-opt.active { border-color: #16a34a; background: #f0fdf4; }

        @@media print { #topbar, #sidebar, #panel { display: none !important; } #cv-wrap { padding: 0; height: auto; } #cv-paper { box-shadow: none; } }
    </style>
</head>
<body class="bg-slate-100">

<!-- TOPBAR -->
<div id="topbar">
    <div class="font-bold text-green-700 text-base mr-2">CV Builder</div>
    <span id="cv-title-bar" contenteditable class="text-sm text-gray-400 px-2 py-1 rounded hover:bg-gray-100 focus:bg-gray-100 focus:outline-none min-w-[120px]">CV chưa đặt tên</span>
    <div class="flex-1"></div>
    <div class="text-xs text-yellow-700 bg-yellow-50 border border-yellow-200 rounded-lg px-3 py-1.5 hidden md:block">
        💡 Click vào nội dung CV để chỉnh sửa. Dùng sidebar trái để thêm / tuỳ chỉnh mục.
    </div>
    <div class="flex-1"></div>
    <button class="tb-btn" onclick="doUndo()"><i class='bx bx-undo'></i> Hoàn tác</button>
    <button class="tb-btn" onclick="doPreview()"><i class='bx bx-show'></i> Xem trước</button>
    <button class="tb-btn green" onclick="doSave()"><i class='bx bx-save'></i> Lưu CV</button>
    <button class="tb-btn blue" onclick="doExportPDF()"><i class='bx bxs-file-pdf'></i> Xuất PDF</button>
</div>

<div style="display:flex; height: calc(100vh - 52px);">

    <!-- SIDEBAR -->
    <div id="sidebar">
        <div class="px-4 pt-4 pb-2 text-xs font-bold text-gray-400 uppercase tracking-wider">Chức năng</div>
        <div class="sidebar-item active" onclick="openPanel('them-muc')">
            <i class='bx bx-plus-circle'></i> Thêm mục
        </div>
        <div class="sidebar-item" onclick="openPanel('thiet-ke')">
            <i class='bx bx-palette'></i> Thiết kế & Font
        </div>
        <div class="sidebar-item" onclick="openPanel('bo-cuc')">
            <i class='bx bx-layout'></i> Bố cục
        </div>
        <div class="sidebar-item" onclick="openPanel('goi-y')">
            <i class='bx bx-edit-alt'></i> Gợi ý viết CV
        </div>
        <div class="sidebar-item" onclick="openPanel('thu-vien')">
            <i class='bx bx-collection'></i> Thư viện CV
        </div>
        <div class="px-4 pt-4 pb-2 text-xs font-bold text-gray-400 uppercase tracking-wider">Nhanh</div>
        <div class="sidebar-item" onclick="doSave()"><i class='bx bx-save'></i> Lưu CV</div>
        <div class="sidebar-item" onclick="doExportPDF()"><i class='bx bxs-file-pdf'></i> Xuất PDF</div>
        <div class="sidebar-item" onclick="doClear()"><i class='bx bx-trash'></i> Tạo CV mới</div>
    </div>

    <!-- PANEL -->
    <div id="panel">
        <!-- THÊM MỤC -->
        <div id="p-them-muc" class="p-4">
            <div class="flex items-center justify-between mb-3">
                <div class="font-bold text-gray-800">Thêm mục</div>
                <button onclick="closePanel()" class="text-gray-400 hover:text-gray-700 text-lg leading-none">×</button>
            </div>
            <input type="text" placeholder="Tìm mục..." class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm mb-4 focus:outline-none focus:border-green-400" oninput="filterSections(this.value)">
            <div class="text-xs font-bold text-gray-400 uppercase mb-2">Chưa sử dụng</div>
            <div id="unused-sections" class="space-y-1"></div>
            <div class="text-xs font-bold text-gray-400 uppercase mt-4 mb-2">Đã sử dụng</div>
            <div id="used-sections" class="space-y-1"></div>
        </div>

        <!-- THIẾT KẾ -->
        <div id="p-thiet-ke" class="p-4 hidden">
            <div class="flex items-center justify-between mb-4">
                <div class="font-bold text-gray-800">Thiết kế & Font</div>
                <button onclick="closePanel()" class="text-gray-400 hover:text-gray-700 text-lg">×</button>
            </div>
            <div class="text-xs font-bold text-gray-500 mb-2 uppercase">Màu chủ đạo</div>
            <div class="flex gap-2 mb-5 flex-wrap">
                <div class="w-7 h-7 rounded-full bg-green-600 cursor-pointer ring-2 ring-offset-1 ring-green-600" onclick="setColor('#16a34a')"></div>
                <div class="w-7 h-7 rounded-full bg-blue-600 cursor-pointer" onclick="setColor('#2563eb')"></div>
                <div class="w-7 h-7 rounded-full bg-purple-600 cursor-pointer" onclick="setColor('#7c3aed')"></div>
                <div class="w-7 h-7 rounded-full bg-red-600 cursor-pointer" onclick="setColor('#dc2626')"></div>
                <div class="w-7 h-7 rounded-full bg-orange-500 cursor-pointer" onclick="setColor('#ea580c')"></div>
                <div class="w-7 h-7 rounded-full bg-teal-600 cursor-pointer" onclick="setColor('#0d9488')"></div>
                <div class="w-7 h-7 rounded-full bg-gray-800 cursor-pointer" onclick="setColor('#1f2937')"></div>
            </div>
            <div class="text-xs font-bold text-gray-500 mb-2 uppercase">Font chữ</div>
            <div class="space-y-2">
                <div class="font-opt active" style="font-family:'Segoe UI'" onclick="setFont('Segoe UI')">Segoe UI — Mặc định</div>
                <div class="font-opt" style="font-family:Georgia" onclick="setFont('Georgia')">Georgia — Thanh lịch</div>
                <div class="font-opt" style="font-family:Arial" onclick="setFont('Arial')">Arial — Đơn giản</div>
                <div class="font-opt" style="font-family:'Times New Roman'" onclick="setFont('Times New Roman')">Times New Roman — Cổ điển</div>
            </div>
            <div class="text-xs font-bold text-gray-500 mt-4 mb-2 uppercase">Cỡ chữ CV</div>
            <input type="range" min="11" max="16" value="13" class="w-full" oninput="setCVFontSize(this.value)" />
        </div>

        <!-- BỐ CỤC -->
        <div id="p-bo-cuc" class="p-4 hidden">
            <div class="flex items-center justify-between mb-4">
                <div class="font-bold text-gray-800">Bố cục</div>
                <button onclick="closePanel()" class="text-gray-400 hover:text-gray-700 text-lg">×</button>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div class="layout-opt active" onclick="setLayout('classic')">
                    <div class="text-xl mb-1">☰</div>
                    <div>Cổ điển<br/><span class="text-gray-400">1 cột</span></div>
                </div>
                <div class="layout-opt" onclick="setLayout('sidebar')">
                    <div class="text-xl mb-1">⊟</div>
                    <div>Sidebar<br/><span class="text-gray-400">2 cột</span></div>
                </div>
                <div class="layout-opt" onclick="setLayout('modern')">
                    <div class="text-xl mb-1">▦</div>
                    <div>Hiện đại<br/><span class="text-gray-400">Header màu</span></div>
                </div>
                <div class="layout-opt" onclick="setLayout('minimal')">
                    <div class="text-xl mb-1">─</div>
                    <div>Tối giản<br/><span class="text-gray-400">Minimal</span></div>
                </div>
            </div>
        </div>

        <!-- GỢI Ý -->
        <div id="p-goi-y" class="p-4 hidden">
            <div class="flex items-center justify-between mb-4">
                <div class="font-bold text-gray-800">Gợi ý viết CV</div>
                <button onclick="closePanel()" class="text-gray-400 hover:text-gray-700 text-lg">×</button>
            </div>
            <div class="space-y-3 text-sm text-gray-600">
                <div class="bg-green-50 border border-green-100 rounded-xl p-3">
                    <div class="font-semibold text-green-700 mb-1">🎯 Mục tiêu nghề nghiệp</div>
                    <div class="text-xs leading-relaxed">Viết 2-3 câu ngắn gọn. Nêu rõ vị trí ứng tuyển, thế mạnh của bạn và giá trị bạn mang lại cho công ty.</div>
                </div>
                <div class="bg-blue-50 border border-blue-100 rounded-xl p-3">
                    <div class="font-semibold text-blue-700 mb-1">📊 Kinh nghiệm làm việc</div>
                    <div class="text-xs leading-relaxed">Dùng động từ hành động. Ưu tiên số liệu cụ thể: "Tăng doanh số 30% trong 6 tháng".</div>
                </div>
                <div class="bg-purple-50 border border-purple-100 rounded-xl p-3">
                    <div class="font-semibold text-purple-700 mb-1">🎓 Học vấn</div>
                    <div class="text-xs leading-relaxed">Ghi GPA nếu trên 3.2/4.0. Liệt kê các môn học liên quan đến vị trí ứng tuyển.</div>
                </div>
                <div class="bg-orange-50 border border-orange-100 rounded-xl p-3">
                    <div class="font-semibold text-orange-700 mb-1">⚡ Kỹ năng</div>
                    <div class="text-xs leading-relaxed">Chia kỹ năng cứng và kỹ năng mềm. Chỉ liệt kê kỹ năng thực sự thành thạo.</div>
                </div>
            </div>
        </div>

        <!-- THƯ VIỆN -->
        <div id="p-thu-vien" class="p-4 hidden">
            <div class="flex items-center justify-between mb-4">
                <div class="font-bold text-gray-800">Thư viện CV</div>
                <button onclick="closePanel()" class="text-gray-400 hover:text-gray-700 text-lg">×</button>
            </div>
            <div id="saved-list" class="space-y-2"></div>
            <div id="saved-empty" class="text-center text-gray-400 text-sm py-8">Chưa có CV nào được lưu.<br/>Nhấn "Lưu CV" để lưu.</div>
        </div>
    </div>

    <!-- CV PREVIEW AREA -->
    <div id="cv-wrap">
        <div id="cv-paper">

            <!-- HEADER -->
            <div id="cv-header" style="display:flex; gap:20px; align-items:flex-start;">
                <!-- Photo -->
                <div id="cv-photo-wrap" onclick="document.getElementById('photo-input').click()" title="Click để đổi ảnh">
                    <img id="cv-photo" src="" alt="" style="display:none;" />
                    <span id="photo-placeholder" style="font-size:28px;">👤</span>
                </div>
                <input type="file" id="photo-input" accept="image/*" onchange="handlePhoto(this)" />

                <div style="flex:1">
                    <div class="cv-name" contenteditable id="cv-name-field" data-placeholder="Họ và Tên">Họ và Tên</div>
                    <div class="cv-position" contenteditable id="cv-pos-field" data-placeholder="Vị trí ứng tuyển">Vị trí ứng tuyển</div>

                    <div class="cv-info-grid" style="margin-top:10px;">
                        <div><span class="cv-info-label">Ngày sinh: </span><span contenteditable>12/11/2005</span></div>
                        <div><span class="cv-info-label">Giới tính: </span><span contenteditable>Nam / Nữ</span></div>
                        <div><span class="cv-info-label">SĐT: </span><span contenteditable>0123 456 789</span></div>
                        <div><span class="cv-info-label">Email: </span><span contenteditable>email@example.com</span></div>
                        <div><span class="cv-info-label">Website: </span><span contenteditable>linkedin.com/in/...</span></div>
                        <div><span class="cv-info-label">Địa chỉ: </span><span contenteditable>Quận X, TP.HCM</span></div>
                    </div>
                </div>
            </div>

            <!-- DYNAMIC SECTIONS -->
            <div id="cv-sections"></div>

        </div>
    </div>
</div>

<!-- TOAST -->
<div id="toast"></div>

<script>
// ============================================================
// DATA & STATE
// ============================================================
const SECTIONS = [
    { key: 'objective',  label: 'Mục tiêu nghề nghiệp', icon: 'bx bx-target-lock',   used: true  },
    { key: 'education',  label: 'Học vấn',               icon: 'bx bx-book-open',     used: true  },
    { key: 'experience', label: 'Kinh nghiệm làm việc',  icon: 'bx bx-briefcase',     used: true  },
    { key: 'activity',   label: 'Hoạt động',             icon: 'bx bx-run',           used: true  },
    { key: 'certificate',label: 'Chứng chỉ',             icon: 'bx bx-certification', used: true  },
    { key: 'award',      label: 'Giải thưởng',           icon: 'bx bx-trophy',        used: true  },
    { key: 'skill',      label: 'Kỹ năng',               icon: 'bx bx-brain',         used: true  },
    { key: 'referee',    label: 'Người giới thiệu',      icon: 'bx bx-group',         used: false },
    { key: 'hobby',      label: 'Sở thích',              icon: 'bx bx-heart',         used: false },
    { key: 'language',   label: 'Ngoại ngữ',             icon: 'bx bx-globe',         used: false },
    { key: 'project',    label: 'Dự án',                 icon: 'bx bx-rocket',        used: false },
    { key: 'extra',      label: 'Thông tin thêm',        icon: 'bx bx-info-circle',   used: false },
];

let history = [];
let accentColor = '#16a34a';
let cvFont = 'Segoe UI';

// ============================================================
// INIT
// ============================================================
window.addEventListener('DOMContentLoaded', () => {
    loadFromStorage();
    renderSectionList();
    renderCVSections();
    openPanel('them-muc');
});

// ============================================================
// PANEL
// ============================================================
function openPanel(id) {
    document.getElementById('panel').classList.add('open');
    ['them-muc','thiet-ke','bo-cuc','goi-y','thu-vien'].forEach(k => {
        const el = document.getElementById('p-' + k);
        if (el) el.classList.toggle('hidden', k !== id);
    });
    document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
    const map = { 'them-muc': 0, 'thiet-ke': 1, 'bo-cuc': 2, 'goi-y': 3, 'thu-vien': 4 };
    const items = document.querySelectorAll('.sidebar-item');
    if (map[id] !== undefined) items[map[id]].classList.add('active');
    if (id === 'thu-vien') renderSavedList();
}
function closePanel() {
    document.getElementById('panel').classList.remove('open');
    document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
}

// ============================================================
// SECTION LIST (panel)
// ============================================================
function renderSectionList() {
    const used = document.getElementById('used-sections');
    const unused = document.getElementById('unused-sections');
    used.innerHTML = ''; unused.innerHTML = '';
    SECTIONS.forEach(s => {
        const div = document.createElement('div');
        div.className = 'flex items-center justify-between px-3 py-2 rounded-lg text-sm cursor-pointer hover:bg-gray-50 border border-transparent hover:border-gray-200';
        div.innerHTML = `<span style="display:flex;align-items:center;gap:7px;"><i class="${s.icon}" style="font-size:17px;color:#6b7280;"></i>${s.label}</span>
            <span class="text-xs px-2 py-0.5 rounded-full font-medium ${s.used ? 'bg-green-100 text-green-700 cursor-pointer' : 'bg-gray-100 text-gray-500 cursor-pointer'}"
                onclick="toggleSection('${s.key}')">${s.used ? 'Ẩn' : 'Thêm'}</span>`;
        (s.used ? used : unused).appendChild(div);
    });
}

function toggleSection(key) {
    const s = SECTIONS.find(x => x.key === key);
    if (!s) return;
    s.used = !s.used;
    renderSectionList();
    renderCVSections();
    autoSave();
}

function filterSections(q) {
    q = q.toLowerCase();
    document.querySelectorAll('#used-sections > div, #unused-sections > div').forEach(el => {
        el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}

// ============================================================
// RENDER CV SECTIONS
// ============================================================
function renderCVSections() {
    const container = document.getElementById('cv-sections');
    const usedSections = SECTIONS.filter(s => s.used);
    container.innerHTML = '';
    usedSections.forEach(s => renderSection(s, container));
}

function renderSection(s, container) {
    const wrap = document.createElement('div');
    wrap.id = 'sec-' + s.key;
    wrap.innerHTML = sectionHTML(s);
    container.appendChild(wrap);
}

function sectionHTML(s) {
    switch (s.key) {
        case 'objective': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div contenteditable class="cv-entry-desc" style="font-size:13px;color:#374151;line-height:1.6;" id="obj-text">
                Mô tả mục tiêu nghề nghiệp của bạn, bao gồm mục tiêu ngắn hạn và dài hạn
            </div>`;
        case 'education': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-education"></div>
            <button class="add-btn" onclick="addEntry('education')">+ Thêm học vấn</button>`;
        case 'experience': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-experience"></div>
            <button class="add-btn" onclick="addEntry('experience')">+ Thêm kinh nghiệm</button>`;
        case 'activity': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-activity"></div>
            <button class="add-btn" onclick="addEntry('activity')">+ Thêm hoạt động</button>`;
        case 'certificate': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-certificate"></div>
            <button class="add-btn" onclick="addEntry('certificate')">+ Thêm chứng chỉ</button>`;
        case 'award': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-award"></div>
            <button class="add-btn" onclick="addEntry('award')">+ Thêm giải thưởng</button>`;
        case 'skill': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-skill"></div>
            <button class="add-btn" onclick="addSkill()">+ Thêm kỹ năng</button>`;
        case 'referee': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-referee"></div>
            <button class="add-btn" onclick="addEntry('referee')">+ Thêm người giới thiệu</button>`;
        case 'hobby': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div contenteditable class="cv-entry-desc" style="font-size:13px;color:#374151;" id="hobby-text">
                Đọc sách, du lịch, nhiếp ảnh, thể thao...
            </div>`;
        case 'language': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-language"></div>
            <button class="add-btn" onclick="addLanguage()">+ Thêm ngoại ngữ</button>`;
        case 'project': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div id="list-project"></div>
            <button class="add-btn" onclick="addEntry('project')">+ Thêm dự án</button>`;
        case 'extra': return `
            <div class="cv-section-title">${s.label.toUpperCase()}</div>
            <div contenteditable class="cv-entry-desc" style="font-size:13px;color:#374151;" id="extra-text">
                Thêm thông tin bổ sung khác...
            </div>`;
        default: return '';
    }
}

// ============================================================
// ADD ENTRY (education, experience, activity, ...)
// ============================================================
function addEntry(type) {
    const list = document.getElementById('list-' + type);
    if (!list) return;
    const id = type + '_' + Date.now();
    const div = document.createElement('div');
    div.className = 'entry-wrap cv-entry';
    div.id = id;

    let inner = '';
    if (type === 'education') {
        inner = `
            <div class="cv-entry-header">
                <span contenteditable class="cv-entry-title">Tên trường học</span>
                <span contenteditable class="cv-entry-date" style="color:#6b7280;font-weight:400;font-size:12px;">Bắt đầu – Kết thúc</span>
            </div>
            <div contenteditable class="cv-entry-sub">Ngành học / Môn học</div>
            <div contenteditable class="cv-entry-desc">Mô tả quá trình học tập hoặc thành tích</div>`;
    } else if (type === 'experience') {
        inner = `
            <div class="cv-entry-header">
                <span contenteditable class="cv-entry-title">Tên công ty</span>
                <span contenteditable class="cv-entry-date" style="color:#6b7280;font-weight:400;font-size:12px;">Bắt đầu – Kết thúc</span>
            </div>
            <div contenteditable class="cv-entry-sub">Vị trí công việc</div>
            <div contenteditable class="cv-entry-desc">Mô tả kinh nghiệm làm việc và thành tích đạt được</div>`;
    } else if (type === 'activity') {
        inner = `
            <div class="cv-entry-header">
                <span contenteditable class="cv-entry-title">Tên tổ chức</span>
                <span contenteditable class="cv-entry-date" style="color:#6b7280;font-weight:400;font-size:12px;">Bắt đầu – Kết thúc</span>
            </div>
            <div contenteditable class="cv-entry-sub">Vai trò của bạn</div>
            <div contenteditable class="cv-entry-desc">Mô tả hoạt động</div>`;
    } else if (type === 'certificate') {
        inner = `
            <div class="cv-entry-header">
                <span contenteditable class="cv-entry-title">Tên chứng chỉ</span>
                <span contenteditable class="cv-entry-date" style="color:#6b7280;font-weight:400;font-size:12px;">Năm cấp</span>
            </div>
            <div contenteditable class="cv-entry-sub">Tổ chức cấp chứng chỉ</div>`;
    } else if (type === 'award') {
        inner = `
            <div class="cv-entry-header">
                <span contenteditable class="cv-entry-title">Tên giải thưởng</span>
                <span contenteditable class="cv-entry-date" style="color:#6b7280;font-weight:400;font-size:12px;">Năm</span>
            </div>
            <div contenteditable class="cv-entry-desc">Mô tả giải thưởng</div>`;
    } else if (type === 'referee') {
        inner = `
            <div class="cv-entry-header">
                <span contenteditable class="cv-entry-title">Họ và Tên</span>
            </div>
            <div contenteditable class="cv-entry-sub">Chức danh — Công ty</div>
            <div contenteditable class="cv-entry-desc">📞 SĐT &nbsp;|&nbsp; ✉️ Email</div>`;
    } else if (type === 'project') {
        inner = `
            <div class="cv-entry-header">
                <span contenteditable class="cv-entry-title">Tên dự án</span>
                <span contenteditable class="cv-entry-date" style="color:#6b7280;font-weight:400;font-size:12px;">Thời gian</span>
            </div>
            <div contenteditable class="cv-entry-sub">Vai trò / Công nghệ sử dụng</div>
            <div contenteditable class="cv-entry-desc">Mô tả dự án và kết quả đạt được</div>`;
    }

    div.innerHTML = inner + `<button class="del-btn" onclick="delEntry('${id}')" title="Xóa">✕</button>`;
    list.appendChild(div);
    autoSave();
}

function addSkill() {
    const list = document.getElementById('list-skill');
    if (!list) return;
    const id = 'skill_' + Date.now();
    const div = document.createElement('div');
    div.className = 'entry-wrap';
    div.id = id;
    div.style.cssText = 'margin-bottom:8px;';
    div.innerHTML = `
        <div style="display:flex;align-items:center;gap:8px;">
            <span contenteditable style="font-size:13px;font-weight:500;min-width:120px;">Tên kỹ năng</span>
            <div class="cv-skill-bar" style="flex:1;">
                <div class="cv-skill-fill" style="width:70%;background:${accentColor}"></div>
            </div>
            <input type="range" min="0" max="100" value="70" style="width:70px;"
                oninput="this.previousElementSibling.querySelector('.cv-skill-fill').style.width=this.value+'%'; autoSave();" />
        </div>
        <button class="del-btn" onclick="delEntry('${id}')" title="Xóa">✕</button>`;
    list.appendChild(div);
    autoSave();
}

function addLanguage() {
    const list = document.getElementById('list-language');
    if (!list) return;
    const id = 'lang_' + Date.now();
    const div = document.createElement('div');
    div.className = 'entry-wrap';
    div.id = id;
    div.style.cssText = 'margin-bottom:8px;display:flex;align-items:center;gap:12px;';
    div.innerHTML = `
        <span contenteditable style="font-size:13px;font-weight:500;min-width:100px;">Tiếng Anh</span>
        <select style="font-size:12px;border:1px solid #e5e7eb;border-radius:6px;padding:3px 8px;color:#374151;" onchange="autoSave()">
            <option>Cơ bản</option><option>Trung cấp</option><option selected>Khá</option>
            <option>Giỏi</option><option>Thành thạo</option><option>Bản ngữ</option>
        </select>
        <button class="del-btn" onclick="delEntry('${id}')" title="Xóa">✕</button>`;
    list.appendChild(div);
    autoSave();
}

function delEntry(id) {
    const el = document.getElementById(id);
    if (el) { el.remove(); autoSave(); }
}

// ============================================================
// PHOTO
// ============================================================
function handlePhoto(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
        const img = document.getElementById('cv-photo');
        img.src = e.target.result;
        img.style.display = 'block';
        document.getElementById('photo-placeholder').style.display = 'none';
        autoSave();
    };
    reader.readAsDataURL(file);
}

// ============================================================
// DESIGN
// ============================================================
function setColor(color) {
    accentColor = color;
    document.querySelectorAll('.cv-section-title').forEach(el => el.style.borderBottomColor = color);
    document.querySelectorAll('.cv-skill-fill').forEach(el => el.style.background = color);
    document.querySelectorAll('.add-btn').forEach(el => el.style.color = color);
    autoSave();
}

function setFont(font) {
    cvFont = font;
    document.getElementById('cv-paper').style.fontFamily = font;
    document.querySelectorAll('.font-opt').forEach(el => el.classList.toggle('active', el.textContent.startsWith(font)));
    autoSave();
}

function setCVFontSize(val) {
    document.getElementById('cv-paper').style.fontSize = val + 'px';
    autoSave();
}

function setLayout(type) {
    document.querySelectorAll('.layout-opt').forEach(el => el.classList.remove('active'));
    event.currentTarget.classList.add('active');
    const paper = document.getElementById('cv-paper');
    if (type === 'modern') {
        document.getElementById('cv-header').style.background = accentColor;
        document.getElementById('cv-header').style.color = '#fff';
        document.getElementById('cv-header').style.margin = '-40px -48px 20px';
        document.getElementById('cv-header').style.padding = '30px 48px';
        document.getElementById('cv-name-field').style.color = '#fff';
        document.getElementById('cv-pos-field').style.color = 'rgba(255,255,255,.8)';
    } else {
        document.getElementById('cv-header').style.cssText = 'display:flex;gap:20px;align-items:flex-start;';
        document.getElementById('cv-name-field').style.color = '#111';
        document.getElementById('cv-pos-field').style.color = '#6b7280';
    }
    toast('Đã đổi bố cục: ' + type);
}

// ============================================================
// SAVE / LOAD
// ============================================================
function autoSave() {
    clearTimeout(window._saveTimer);
    window._saveTimer = setTimeout(doSave, 1500);
}

function doSave() {
    const name = document.getElementById('cv-title-bar').textContent.trim() || 'CV chưa đặt tên';
    const data = {
        name,
        html: document.getElementById('cv-paper').innerHTML,
        photo: document.getElementById('cv-photo').src,
        sections: SECTIONS.map(s => ({ key: s.key, used: s.used })),
        color: accentColor,
        font: cvFont,
        savedAt: new Date().toLocaleString('vi-VN')
    };
    let list = JSON.parse(localStorage.getItem('srb_cv_list') || '[]');
    const idx = list.findIndex(x => x.name === name);
    if (idx >= 0) list[idx] = data; else list.unshift(data);
    localStorage.setItem('srb_cv_list', JSON.stringify(list));
    localStorage.setItem('srb_cv_current', JSON.stringify(data));
    toast('✓ Đã lưu CV: ' + name);
}

function loadFromStorage() {
    const raw = localStorage.getItem('srb_cv_current');
    if (!raw) {
        setTimeout(() => {
            addEntry('education');
            addEntry('experience');
            addEntry('experience');
            addEntry('activity');
            addSkill(); addSkill(); addSkill();
        }, 100);
        return;
    }
    try {
        const data = JSON.parse(raw);
        if (data.name) document.getElementById('cv-title-bar').textContent = data.name;
        if (data.color) accentColor = data.color;
        if (data.font) { cvFont = data.font; document.getElementById('cv-paper').style.fontFamily = data.font; }
        if (data.sections) data.sections.forEach(s => { const found = SECTIONS.find(x => x.key === s.key); if (found) found.used = s.used; });
        setTimeout(() => {
            if (data.html) {
                document.getElementById('cv-paper').innerHTML = data.html;
                if (data.photo && data.photo.length > 5) {
                    const img = document.getElementById('cv-photo');
                    if (img) { img.src = data.photo; img.style.display = 'block'; }
                    const ph = document.getElementById('photo-placeholder');
                    if (ph) ph.style.display = 'none';
                }
            }
        }, 50);
    } catch(e) {}
}

function renderSavedList() {
    const container = document.getElementById('saved-list');
    const empty = document.getElementById('saved-empty');
    const list = JSON.parse(localStorage.getItem('srb_cv_list') || '[]');
    container.innerHTML = '';
    if (list.length === 0) { empty.style.display = 'block'; return; }
    empty.style.display = 'none';
    list.forEach((cv, i) => {
        const div = document.createElement('div');
        div.className = 'border border-gray-200 rounded-xl p-3 hover:border-green-300 transition-colors cursor-pointer';
        div.innerHTML = `
            <div class="font-semibold text-sm text-gray-800">${cv.name}</div>
            <div class="text-xs text-gray-400 mt-0.5">${cv.savedAt}</div>
            <div class="flex gap-2 mt-2">
                <button onclick="loadCV(${i})" class="text-xs bg-green-50 text-green-700 border border-green-200 rounded-lg px-3 py-1 hover:bg-green-100">Mở</button>
                <button onclick="deleteCV(${i})" class="text-xs bg-red-50 text-red-600 border border-red-100 rounded-lg px-3 py-1 hover:bg-red-100">Xóa</button>
            </div>`;
        container.appendChild(div);
    });
}

function loadCV(idx) {
    const list = JSON.parse(localStorage.getItem('srb_cv_list') || '[]');
    const data = list[idx];
    if (!data) return;
    if (data.color) accentColor = data.color;
    if (data.font) { cvFont = data.font; document.getElementById('cv-paper').style.fontFamily = data.font; }
    if (data.sections) data.sections.forEach(s => { const found = SECTIONS.find(x => x.key === s.key); if (found) found.used = s.used; });
    if (data.name) document.getElementById('cv-title-bar').textContent = data.name;
    if (data.html) document.getElementById('cv-paper').innerHTML = data.html;
    renderSectionList();
    toast('Đã mở CV: ' + data.name);
}

function deleteCV(idx) {
    let list = JSON.parse(localStorage.getItem('srb_cv_list') || '[]');
    list.splice(idx, 1);
    localStorage.setItem('srb_cv_list', JSON.stringify(list));
    renderSavedList();
    toast('Đã xóa CV');
}

// ============================================================
// EXPORT PDF
// ============================================================
function doExportPDF() {
    const el = document.getElementById('cv-paper');
    document.querySelectorAll('.add-btn, .del-btn, input[type=range], input[type=file], #photo-input').forEach(e => e.style.display = 'none');
    const opt = {
        margin: 0,
        filename: (document.getElementById('cv-title-bar').textContent.trim() || 'CV') + '.pdf',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
    };
    html2pdf().set(opt).from(el).save().then(() => {
        document.querySelectorAll('.add-btn').forEach(e => e.style.display = 'inline-flex');
        toast('✓ Xuất PDF thành công!');
    });
}

// ============================================================
// UTILS
// ============================================================
function doUndo() {
    if (history.length === 0) { toast('Không có gì để hoàn tác'); return; }
    document.getElementById('cv-paper').innerHTML = history.pop();
    toast('Đã hoàn tác');
}

function doPreview() {
    const w = window.open('', '_blank', 'width=900,height=1100');
    w.document.write('<html><body style="margin:0;background:#f3f4f6;display:flex;justify-content:center;padding:24px;">' + document.getElementById('cv-paper').outerHTML + '</body></html>');
    w.document.close();
}

function doClear() {
    if (!confirm('Tạo CV mới sẽ xóa nội dung hiện tại. Bạn có chắc không?')) return;
    localStorage.removeItem('srb_cv_current');
    location.reload();
}

function toast(msg) {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2500);
}

// Auto-save on any edit
document.addEventListener('input', () => {
    history.push(document.getElementById('cv-paper').innerHTML);
    if (history.length > 30) history.shift();
    autoSave();
});
</script>
