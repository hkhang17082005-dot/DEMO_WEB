@{
    ViewData["Title"] = "Mẫu CV Đơn Giản";
}

<script src="https://cdn.tailwindcss.com"></script>
<!-- Background Effects -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-emerald-400 opacity-20 rounded-full blur-3xl -z-10"></div>
    <div class="absolute bottom-20 right-10 w-72 h-72 bg-purple-500 opacity-20 rounded-full blur-3xl -z-10"></div>
<div class="max-w-7xl mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-4">
        <span class="text-green-600 font-medium">Trang chủ</span>
        >
        <span>Mẫu CV theo style</span>
        >
        <span class="text-gray-700 font-semibold">
            Mẫu CV xin việc tiếng Việt Đơn giản chuẩn 2026
        </span>
    </div>

    <!-- TITLE -->
    <div class="flex justify-between items-center mb-6">

        <div>

            <h1 class="text-3xl font-bold text-gray-800">
                Mẫu CV xin việc tiếng Việt
                <span class="text-green-600">
                    Đơn giản
                </span>
                chuẩn 2026
            </h1>

            <p class="text-gray-500 mt-2 max-w-2xl">
                Tuyển chọn 21 mẫu CV tiếng Việt có thiết kế đơn giản, dễ đọc và dễ sử dụng.
                Phù hợp với ứng viên muốn tập trung vào nội dung hơn là trang trí.
            </p>

        </div>

        <!-- Robot -->
        <img src="https://cdn-icons-png.flaticon.com/512/4712/4712109.png"
             class="w-24">
    </div>

    <!-- FILTER -->
    <div class="flex flex-wrap gap-3 mb-8">

        <a href="/Create_CV/All_CV_Style" class="px-4 py-2 bg-gray-200 rounded-full 
        hover:bg-emerald-500 hover:text-white hover:-translate-y-1 transition duration-300">
            Tất cả
        </a>

        <a href="/Create_CV/Simple_CV" class="px-4 py-2 bg-emerald-500 rounded-full
        hover:bg-emerald-500 hover:text-white hover:-translate-y-1 transition duration-300">
            Đơn giản
        </a>

        <a href="/Create_CV/CVChuyenNghiep" class="px-4 py-2 bg-gray-200 rounded-full
        hover:bg-emerald-500 hover:text-white hover:-translate-y-1 transition duration-300">
            Chuyên nghiệp
        </a>

        <a href="/Create_CV/Modern_CV" class="px-4 py-2 bg-gray-200 rounded-full
        hover:bg-emerald-500 hover:text-white hover:-translate-y-1 transition duration-300">
            Hiện đại
        </a>

    </div>


    <!-- TEMPLATE GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

<!-- CARD 1 -->
<div class="bg-white shadow rounded-xl hover:shadow-2xl hover:-translate-y-2 transition p-4">

    <div class="relative group rounded-lg overflow-hidden">

        <img src="/images/cv1.jpg"
             class="w-full h-[450px] object-cover rounded-lg">

        <!-- Hover -->
        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">

            <a href="/CV/Builder"
               class="bg-gradient-to-r from-emerald-500 to-purple-500 text-white px-6 py-3 rounded-lg font-semibold hover:scale-105 transition">
               Dùng mẫu
            </a>

        </div>

    </div>

    <!-- TAG -->
    <div class="flex gap-2 mt-3">

        <span class="bg-emerald-100 text-emerald-700 px-2 py-1 text-xs rounded-full">
            Đơn giản
        </span>

        <span class="bg-purple-100 text-purple-700 px-2 py-1 text-xs rounded-full">
            Chuyên nghiệp
        </span>

    </div>

</div>
        <!-- CARD 2 -->
        <div class="bg-white shadow rounded-xl hover:shadow-2xl hover:-translate-y-2 transition p-4">

            <div class="relative group rounded-lg overflow-hidden">

                <img src="/images/cv2.jpg"
                     class="w-full h-[450px] object-cover">

                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">

                    <a href="/CV/Builder"
                       class="bg-gradient-to-r from-emerald-500 to-purple-500 text-white px-6 py-3 rounded-lg font-semibold hover:scale-105 transition">
                        Dùng mẫu
                    </a>

                </div>

            </div>

            <div class="flex gap-2 p-3">

                <span class="bg-emerald-100 text-emerald-700 px-2 py-1 text-xs rounded-full">
                    Đơn giản
                </span>

                <span class="bg-purple-100 text-purple-700 px-2 py-1 text-xs rounded-full">
                    Chuyên nghiệp
                </span>

            </div>

        </div>


        <!-- CARD 3 -->
        <div class="bg-white shadow rounded-xl hover:shadow-2xl hover:-translate-y-2 transition p-4">

            <div class="relative group rounded-lg overflow-hidden">

                <img src="/images/cv3.jpg"
                     class="w-full h-[450px] object-cover">

                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">

                    <a href="/CV/Builder"
                       class="bg-gradient-to-r from-emerald-500 to-purple-500 text-white px-6 py-3 rounded-lg font-semibold hover:scale-105 transition">
                        Dùng mẫu
                    </a>

                </div>

            </div>

            <div class="flex gap-2 p-3">

                <span class="bg-emerald-100 text-emerald-700 px-2 py-1 text-xs rounded-full">
                    Đơn giản
                </span>

                <span class="bg-purple-100 text-purple-700 px-2 py-1 text-xs rounded-full">
                    Chuyên nghiệp
                </span>

            </div>

        </div>

                <!-- CARD 4 -->
        <div class="bg-white shadow rounded-xl hover:shadow-2xl hover:-translate-y-2 transition p-4">

            <div class="relative group rounded-lg overflow-hidden">

                <img src="/images/cv6.jpg"
                     class="w-full h-[450px] object-cover">

                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">

                    <a href="/CV/Builder"
                       class="bg-gradient-to-r from-emerald-500 to-purple-500 text-white px-6 py-3 rounded-lg font-semibold hover:scale-105 transition">
                        Dùng mẫu
                    </a>

                </div>

            </div>

            <div class="flex gap-2 p-3">

                <span class="bg-emerald-100 text-emerald-700 px-2 py-1 text-xs rounded-full">
                    Đơn giản
                </span>

                <span class="bg-cyan-500 text-white px-2 py-1 text-xs rounded-full">
                    Hiện đại
                </span>

            </div>

        </div>

    </div>

</div>