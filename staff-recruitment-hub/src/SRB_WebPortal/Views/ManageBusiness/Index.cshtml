                  <option>51 – 200 nhân viên</option>
                  <option selected>201 – 1000 nhân viên</option>
                  <option>1000+ nhân viên</option>
                </select>
              </div>
              <div class="mb-form-group">
                <label class="mb-form-label">Lĩnh vực</label>
