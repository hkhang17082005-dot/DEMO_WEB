@{
    ViewData["Title"] = "Quản lý Doanh nghiệp";
    Layout = "_Layout"; // Giữ layout gốc của bạn, hoặc đổi thành null nếu muốn full-page
}

<!-- ════════════════════════════════════════════════
     GOOGLE FONTS (bỏ nếu _Layout đã có)
════════════════════════════════════════════════ -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

<!-- ════════════════════════════════════════════════
     SCOPED STYLES — prefix .mb- tránh xung đột
════════════════════════════════════════════════ -->
<style>
/* ── RESET SCOPED ── */
.mb-page *, .mb-page *::before, .mb-page *::after {
  box-sizing: border-box; margin: 0; padding: 0;
}
.mb-page { font-family: 'Be Vietnam Pro', sans-serif; background: #f0faf4; color: #1e293b; position: fixed; inset: 0; overflow: hidden; z-index: 9999; }

/* ── LAYOUT ── */
.mb-wrap    { display: flex; height: 100vh; width: 100vw; overflow: hidden; }
.mb-sidebar { width: 240px; background: #e8f7ef; border-right: 1.5px solid #c3e9d5; display: flex; flex-direction: column; flex-shrink: 0; height: 100vh; overflow-y: auto; }
.mb-main    { flex: 1; overflow-y: auto; overflow-x: hidden; display: flex; flex-direction: column; }

/* ── SIDEBAR ── */
.mb-sidebar-logo {
  padding: 24px 20px 18px;
  border-bottom: 1px solid #c3e9d5;
  display: flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.mb-sidebar-logo-icon {
  width: 36px; height: 36px;
  background: linear-gradient(135deg,#a855f7,#ec4899);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 800; color: #fff;
  flex-shrink: 0;
}
.mb-sidebar-logo-name { font-size: 15px; font-weight: 700; line-height: 1; }
.mb-sidebar-logo-name .ln-z { background: linear-gradient(90deg,#a855f7,#ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.mb-sidebar-logo-name .ln-d { color: #0ea5e9; }

.mb-sidebar-section { padding: 16px 16px 5px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #6b9e82; }

.mb-nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 16px; margin: 2px 8px;
  border-radius: 8px;
  font-size: 13.5px; font-weight: 500; color: #2d6a4f;
  text-decoration: none; cursor: pointer;
  transition: background .15s, color .15s;
  border: none; background: none; width: calc(100% - 16px); text-align: left;
}
.mb-nav-item svg { width: 17px; height: 17px; flex-shrink: 0; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
.mb-nav-item:hover { background: #d1f0e0; color: #00b14f; }
.mb-nav-item.active { color: #fff; background: linear-gradient(135deg, #a855f7, #ec4899); box-shadow: 0 3px 10px rgba(168,85,247,.3); }
.mb-nav-badge { margin-left: auto; background: #ef4444; color: #fff; font-size: 10px; font-weight: 700; padding: 1px 7px; border-radius: 99px; }

.mb-sidebar-footer { margin-top: auto; padding: 16px 12px; border-top: 1px solid #c3e9d5; }

/* ── TOPBAR ── */
.mb-topbar {
  background: #fff;
  border-bottom: 1px solid #e2e8f0;
  padding: 0 24px;
  height: 56px;
  display: flex; align-items: center; gap: 16px;
  position: sticky; top: 0; z-index: 100;
  flex-shrink: 0;
}
/* Search */
.mb-topbar-search {
  flex: 1; max-width: 360px;
  display: flex; align-items: center; gap: 8px;
  background: #f1f5f9; border: 1.5px solid #e2e8f0; border-radius: 9px;
  padding: 8px 14px; transition: border-color .15s;
}
.mb-topbar-search:focus-within { border-color: #00b14f; background: #fff; }
.mb-topbar-search svg { width: 15px; height: 15px; stroke: #94a3b8; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
.mb-topbar-search input { border: none; background: none; font-size: 13px; color: #374151; width: 100%; outline: none; font-family: inherit; }
/* Right group */
.mb-topbar-actions { display: flex; align-items: center; gap: 10px; margin-left: auto; }
/* User chip */
.mb-user-chip {
  display: flex; align-items: center; gap: 8px;
  padding: 5px 12px 5px 5px;
  border: 1.5px solid #e2e8f0; border-radius: 99px;
  cursor: pointer; transition: border-color .15s;
  background: #fff;
}
.mb-user-chip:hover { border-color: #00b14f; }
.mb-user-chip-name { font-size: 13px; font-weight: 600; color: #374151; }
.mb-user-chip svg { width: 14px; height: 14px; stroke: #94a3b8; fill: none; stroke-width: 2; }
.mb-avatar {
  width: 30px; height: 30px; border-radius: 50%;
  background: linear-gradient(135deg,#a855f7,#ec4899);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 12px; font-weight: 700;
  flex-shrink: 0;
}
/* Icon buttons */
.mb-icon-btn {
  position: relative; background: none; border: 1.5px solid #e2e8f0; border-radius: 9px;
  cursor: pointer; color: #64748b; padding: 7px; display: flex; align-items: center; justify-content: center;
  transition: border-color .15s, color .15s;
}
.mb-icon-btn:hover { border-color: #00b14f; color: #00b14f; }
.mb-icon-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
.mb-bell-dot { position: absolute; top: 4px; right: 4px; width: 7px; height: 7px; background: #ef4444; border-radius: 50%; border: 2px solid #fff; }

/* ── CONTENT ── */
.mb-content { padding: 28px 32px; }

/* ── SECTION HEADER ── */
.mb-section-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 18px;
}
.mb-section-head h2 { font-size: 16px; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px; }
.mb-section-head h2 svg { width: 18px; height: 18px; stroke: #00b14f; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
.mb-section-head h2::before { content: ''; display: block; width: 4px; height: 18px; background: #00b14f; border-radius: 2px; }

/* ── STAT CARDS ── */
.mb-stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-bottom: 28px; }

.mb-stat-card {
  background: #fff; border-radius: 14px; padding: 22px 24px;
  border: 1px solid #e2e8f0;
  display: flex; align-items: flex-start; gap: 16px;
  position: relative; overflow: hidden;
  animation: mb-fadeup .4s ease both;
}
.mb-stat-card:nth-child(2) { animation-delay: .08s; }
.mb-stat-card:nth-child(3) { animation-delay: .16s; }

@@keyframes mb-fadeup { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }

.mb-stat-card::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 14px 14px 0 0; }
.mb-stat-card.green::after { background: linear-gradient(90deg, #00b14f, #34d399); }
.mb-stat-card.blue::after  { background: linear-gradient(90deg, #0ea5e9, #38bdf8); }
.mb-stat-card.purple::after{ background: linear-gradient(90deg, #a855f7, #ec4899); }

.mb-stat-icon {
  width: 48px; height: 48px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.mb-stat-icon svg { width: 22px; height: 22px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
.mb-stat-card.green .mb-stat-icon { background: #e6f9ef; color: #00b14f; }
.mb-stat-card.blue  .mb-stat-icon { background: #e0f2fe; color: #0ea5e9; }
.mb-stat-card.purple .mb-stat-icon { background: #f5f3ff; color: #a855f7; }

.mb-stat-body {}
.mb-stat-label { font-size: 12.5px; color: #64748b; font-weight: 500; margin-bottom: 4px; }
.mb-stat-value { font-size: 30px; font-weight: 800; color: #0f172a; line-height: 1; }
.mb-stat-sub   { font-size: 12px; color: #94a3b8; margin-top: 4px; }
.mb-stat-sub b { color: #00b14f; }

/* ── JOB MANAGEMENT ── */
.mb-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; margin-bottom: 28px; overflow: hidden; animation: mb-fadeup .5s ease both; animation-delay: .2s; }
.mb-card-head {
  padding: 16px 24px;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid #f1f5f9;
}
.mb-card-head-title { font-size: 15px; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px; }
.mb-card-head-title svg { width: 17px; height: 17px; stroke: #00b14f; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

/* Buttons */
.mb-btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
  cursor: pointer; border: none; font-family: inherit; transition: all .15s;
  text-decoration: none;
}
.mb-btn svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; }
.mb-btn-primary { background: #00b14f; color: #fff; }
.mb-btn-primary:hover { background: #009a44; }
.mb-btn-outline { background: #fff; color: #374151; border: 1.5px solid #d1d5db; }
.mb-btn-outline:hover { border-color: #00b14f; color: #00b14f; }
.mb-btn-sm { padding: 5px 11px; font-size: 12px; }
.mb-btn-danger { background: #fee2e2; color: #dc2626; }
.mb-btn-danger:hover { background: #fecaca; }
.mb-btn-warning { background: #fef3c7; color: #d97706; }
.mb-btn-warning:hover { background: #fde68a; }
.mb-btn-info { background: #e0f2fe; color: #0284c7; }
.mb-btn-info:hover { background: #bae6fd; }

/* Search bar */
.mb-toolbar { padding: 14px 24px; display: flex; gap: 10px; align-items: center; border-bottom: 1px solid #f1f5f9; flex-wrap: wrap; }
.mb-search { display: flex; align-items: center; gap: 8px; background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 8px; padding: 8px 14px; flex: 1; min-width: 180px; }
.mb-search svg { width: 15px; height: 15px; stroke: #94a3b8; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
.mb-search input { border: none; background: none; font-size: 13px; color: #374151; width: 100%; outline: none; font-family: inherit; }
.mb-select { padding: 9px 12px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 13px; color: #374151; background: #f8fafc; font-family: inherit; cursor: pointer; outline: none; }
.mb-select:focus { border-color: #00b14f; }

/* Table */
.mb-table-wrap { overflow-x: auto; }
.mb-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
.mb-table thead th { background: #f8fafc; font-weight: 600; color: #64748b; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; padding: 12px 20px; text-align: left; border-bottom: 1px solid #e2e8f0; white-space: nowrap; }
.mb-table tbody tr { border-bottom: 1px solid #f1f5f9; transition: background .12s; }
.mb-table tbody tr:hover { background: #fafcff; }
.mb-table tbody td { padding: 14px 20px; vertical-align: middle; }

/* Status badges */
.mb-badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 99px; font-size: 12px; font-weight: 600; white-space: nowrap; }
.mb-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.mb-badge-active   { background: #e6f9ef; color: #00b14f; }
.mb-badge-closed   { background: #f1f5f9; color: #94a3b8; }
.mb-badge-expired  { background: #fee2e2; color: #dc2626; }
.mb-badge-pending  { background: #fef3c7; color: #d97706; }
.mb-badge-new      { background: #e0f2fe; color: #0284c7; }
.mb-badge-review   { background: #f5f3ff; color: #7c3aed; }
.mb-badge-invited  { background: #e6f9ef; color: #00b14f; }
.mb-badge-rejected { background: #fee2e2; color: #dc2626; }
.mb-badge-hired    { background: #0f172a; color: #f0fdf4; }

.mb-job-title { font-weight: 600; color: #0f172a; margin-bottom: 3px; }
.mb-job-meta  { font-size: 12px; color: #94a3b8; }

.mb-action-row { display: flex; gap: 6px; flex-wrap: wrap; }

/* Pagination */
.mb-pagination { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px; border-top: 1px solid #f1f5f9; }
.mb-page-info { font-size: 12.5px; color: #94a3b8; }
.mb-page-btns { display: flex; gap: 4px; }
.mb-page-btn  { width: 32px; height: 32px; border-radius: 7px; border: 1.5px solid #e2e8f0; background: #fff; font-size: 13px; font-weight: 600; color: #374151; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .15s; }
.mb-page-btn:hover, .mb-page-btn.active { background: #00b14f; border-color: #00b14f; color: #fff; }

/* ── CANDIDATE TABLE ── */
.mb-cv-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg,#a855f7,#ec4899); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; font-weight: 700; flex-shrink: 0; }
.mb-cv-info   { display: flex; align-items: center; gap: 10px; }
.mb-cv-name   { font-weight: 600; color: #0f172a; font-size: 13.5px; }
.mb-cv-role   { font-size: 12px; color: #94a3b8; }

/* ── PROFILE FORM ── */
.mb-profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; padding: 24px; }
.mb-profile-full  { grid-column: 1 / -1; }
.mb-form-group {}
.mb-form-label { font-size: 12.5px; font-weight: 700; color: #374151; text-transform: uppercase; letter-spacing: .4px; margin-bottom: 7px; display: block; }
.mb-form-input, .mb-form-textarea, .mb-form-select {
  width: 100%; padding: 10px 14px;
  border: 1.5px solid #e2e8f0; border-radius: 9px;
  font-size: 13.5px; color: #0f172a; font-family: inherit;
  background: #f8fafc; outline: none;
  transition: border-color .15s, box-shadow .15s;
}
.mb-form-input:focus, .mb-form-textarea:focus, .mb-form-select:focus {
  border-color: #00b14f; background: #fff;
  box-shadow: 0 0 0 3px rgba(0,177,79,.12);
}
.mb-form-textarea { resize: vertical; min-height: 100px; }

.mb-logo-upload {
  display: flex; align-items: center; gap: 16px; margin-bottom: 18px; padding: 20px 24px;
  border-bottom: 1px solid #f1f5f9;
}
.mb-logo-preview {
  width: 72px; height: 72px; border-radius: 14px; border: 2px dashed #d1d5db;
  background: #f8fafc;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  overflow: hidden;
}
.mb-logo-preview svg { width: 28px; height: 28px; stroke: #cbd5e1; fill: none; stroke-width: 1.5; }
.mb-logo-upload-info h4 { font-size: 14px; font-weight: 600; color: #0f172a; margin-bottom: 4px; }
.mb-logo-upload-info p  { font-size: 12px; color: #94a3b8; margin-bottom: 10px; }

/* ── BENEFIT TAGS ── */
.mb-benefit-wrap { display: flex; flex-wrap: wrap; gap: 8px; padding: 12px 14px; border: 1.5px solid #e2e8f0; border-radius: 9px; background: #f8fafc; }
.mb-benefit-tag { display: flex; align-items: center; gap: 6px; padding: 5px 12px; background: #e6f9ef; color: #00b14f; border-radius: 99px; font-size: 12px; font-weight: 600; }
.mb-benefit-tag button { background: none; border: none; cursor: pointer; color: #00b14f; font-size: 14px; line-height: 1; padding: 0; }
.mb-benefit-add { display: flex; align-items: center; gap: 6px; padding: 5px 12px; border: 1.5px dashed #d1d5db; border-radius: 99px; font-size: 12px; font-weight: 600; color: #94a3b8; cursor: pointer; background: none; font-family: inherit; }
.mb-benefit-add:hover { border-color: #00b14f; color: #00b14f; }

/* ── PROFILE SAVE ROW ── */
.mb-profile-actions { padding: 16px 24px; background: #f8fafc; border-top: 1px solid #e2e8f0; display: flex; justify-content: flex-end; gap: 10px; }

/* ── TAB NAV ── */
.mb-tabs { display: flex; gap: 2px; padding: 0 24px; background: #fff; border-bottom: 1px solid #e2e8f0; }
.mb-tab { padding: 13px 18px; font-size: 13.5px; font-weight: 600; color: #64748b; border: none; background: none; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; display: flex; align-items: center; gap: 7px; font-family: inherit; transition: color .15s; }
.mb-tab svg { width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
.mb-tab:hover { color: #00b14f; }
.mb-tab.active { color: #00b14f; border-bottom-color: #00b14f; }
.mb-tab-count { background: #e6f9ef; color: #00b14f; font-size: 10px; padding: 1px 6px; border-radius: 99px; }

/* ── RESPONSIVE ── */
@@media (max-width: 900px) {
  .mb-sidebar { display: none; }
  .mb-stat-grid { grid-template-columns: 1fr 1fr; }
  .mb-profile-grid { grid-template-columns: 1fr; }
}
@@media (max-width: 600px) {
  .mb-content { padding: 18px 16px; }
  .mb-topbar { padding: 12px 16px; }
  .mb-stat-grid { grid-template-columns: 1fr; }
}
</style>

<!-- ════════════════════════════════════════════════
     MARKUP
════════════════════════════════════════════════ -->
<div class="mb-page">
  <div class="mb-wrap">

    <!-- ──────────────────
         SIDEBAR
    ────────────────── -->
    <aside class="mb-sidebar">
      <a href="/" class="mb-sidebar-logo">
        <div class="mb-sidebar-logo-icon">Z</div>
        <span class="mb-sidebar-logo-name"><span class="ln-z">Zeion</span> <span class="ln-d">Dev</span></span>
      </a>

      <span class="mb-sidebar-section">Tổng quan</span>
      <button class="mb-nav-item active" onclick="showTab('dashboard')">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </button>

      <span class="mb-sidebar-section">Quản lý</span>
      <button class="mb-nav-item" onclick="showTab('jobs')">
