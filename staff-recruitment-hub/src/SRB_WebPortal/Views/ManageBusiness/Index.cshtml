                </div>
              </div>
              <div class="mb-form-group">
                <label class="mb-form-label">Email liên hệ tuyển dụng</label>
                <input class="mb-form-input" type="email" value="hr@fptsoftware.com" />
              </div>
              <div class="mb-form-group">
                <label class="mb-form-label">Điện thoại</label>
                <input class="mb-form-input" type="tel" value="024 7300 1234" />
