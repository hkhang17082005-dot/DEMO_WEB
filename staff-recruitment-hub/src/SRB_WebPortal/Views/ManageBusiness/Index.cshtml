                    <th>Trạng thái</th>
                    <th>Hành động</th>
                  </tr>
                </thead>
                <tbody>
                  @{
                    var candidates = new[] {
                      new { Init="VA", Name="Nguyễn Văn A", Skill="5 năm React / Vue",    Role="Senior Frontend Developer",  Date="21/07/2025", Status="Chưa đọc",     Badge="new"      },
                      new { Init="TB", Name="Trần Thị B",   Skill="3 năm .NET Core",       Role="Backend Engineer (.NET)",    Date="21/07/2025", Status="Chưa đọc",     Badge="new"      },
                      new { Init="MC", Name="Lê Minh C",    Skill="AWS / GCP / Docker",     Role="DevOps / Cloud Engineer",   Date="20/07/2025", Status="Đang xem xét", Badge="review"   },
                      new { Init="QD", Name="Phạm Quang D", Skill="React Native 4 năm",    Role="React Native Developer",    Date="19/07/2025", Status="Mời PV",        Badge="invited"  },
                      new { Init="TH", Name="Hoàng Thu E",  Skill="Node.js / PostgreSQL",  Role="Backend Engineer (.NET)",   Date="18/07/2025", Status="Trúng tuyển",  Badge="hired"    },
                      new { Init="VF", Name="Vũ Trọng F",   Skill="Spark / Kafka / Python", Role="Data Engineer",            Date="15/07/2025", Status="Từ chối",      Badge="rejected" },
