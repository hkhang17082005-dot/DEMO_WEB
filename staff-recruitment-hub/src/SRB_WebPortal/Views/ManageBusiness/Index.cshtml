                <button class="mb-page-btn active">1</button>
                <button class="mb-page-btn">2</button>
                <button class="mb-page-btn">3</button>
                <button class="mb-page-btn">4</button>
                <button class="mb-page-btn">›</button>
              </div>
            </div>
          </div>
        </div>
        <!-- /tab-candidates -->

        <!-- ══════════════ PROFILE TAB ══════════════ -->
        <div id="tab-profile" style="display:none;">
          <div class="mb-card">
