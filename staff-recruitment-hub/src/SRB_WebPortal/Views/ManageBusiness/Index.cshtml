<!-- ════════════════════════════════════════════════
     SCRIPTS (vanilla JS, không cần jQuery)
════════════════════════════════════════════════ -->
<script>
// ── Tab navigation ──
function showTab(name) {
  ['dashboard','jobs','candidates','profile'].forEach(t => {
    document.getElementById('tab-' + t).style.display = (t === name) ? '' : 'none';
  });
  document.querySelectorAll('.mb-nav-item').forEach(el => el.classList.remove('active'));
  const map = { dashboard: 0, jobs: 1, candidates: 2, profile: 3 };
  document.querySelectorAll('.mb-nav-item')[map[name]]?.classList.add('active');
}

// ── Sub-tabs (candidate status filter) ──
document.querySelectorAll('.mb-tab').forEach(btn => {
  btn.addEventListener('click', function () {
    document.querySelectorAll('.mb-tab').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
  });
});

// ── Benefit tags ──
function removeBenefit(btn) { btn.closest('.mb-benefit-tag').remove(); }

function addBenefit() {
  const val = prompt('Nhập phúc lợi mới:');
  if (!val) return;
  const wrap = document.getElementById('benefitWrap');
  const addBtn = wrap.querySelector('.mb-benefit-add');
  const tag = document.createElement('span');
  tag.className = 'mb-benefit-tag';
  tag.innerHTML = val + ' <button onclick="removeBenefit(this)" type="button">×</button>';
  wrap.insertBefore(tag, addBtn);
}

// ── Confirm dialogs ──
function confirmClose(id) {
  if (confirm('Bạn có chắc muốn đóng tin #' + id + ' không? Ứng viên sẽ không thấy tin này nữa.')) {
    alert('Đã đóng tin #' + id + ' — tích hợp API tại đây!');
  }
}
function confirmHide(id) {
  if (confirm('Ẩn tin hết hạn #' + id + ' khỏi trang chủ?')) {
    alert('Đã ẩn tin #' + id + ' — tích hợp API tại đây!');
  }
}
</script>
