        Hồ sơ ứng viên
        <span class="mb-nav-badge">7</span>
      </button>
      <button class="mb-nav-item" onclick="showTab('profile')">
        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Hồ sơ Công ty
      </button>

      <span class="mb-sidebar-section">Khác</span>
      <a href="#" class="mb-nav-item">
        <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Hỗ trợ
      </a>
      <a href="#" class="mb-nav-item">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 1 0 4.93 19.07M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0"/></svg>
        Cài đặt
      </a>

      <div class="mb-sidebar-footer">
        <div class="mb-nav-item" style="color:#ef4444;cursor:pointer;">
          <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
          Đăng xuất
        </div>
      </div>
    </aside>

    <!-- ──────────────────
         MAIN
    ────────────────── -->
    <div class="mb-main">

      <!-- TOPBAR -->
      <div class="mb-topbar">
        <!-- Search -->
        <div class="mb-topbar-search">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" placeholder="Tìm kiếm ứng viên, tin đăng..." />
        </div>

        <!-- Action buttons + user -->
        <div class="mb-topbar-actions">
          <a href="/Create/Index" class="mb-btn mb-btn-primary mb-btn-sm">
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Tạo tin đăng
          </a>
          <a href="/Create_CV/Index" class="mb-btn mb-btn-outline mb-btn-sm">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
