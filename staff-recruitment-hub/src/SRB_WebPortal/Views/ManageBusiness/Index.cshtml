              <table class="mb-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Vị trí & thông tin</th>
                    <th>Trạng thái</th>
                    <th>Hạn nộp</th>
                    <th>Lượt xem</th>
                    <th>CV nộp</th>
                    <th>Hành động</th>
                  </tr>
                </thead>
                <tbody>
                  @{
                    var jobs = new[] {
                      new { Id=1, Title="Senior Frontend Developer",  Level="Senior",   Status="Đang chạy", Badge="active",  Deadline="31/07/2025", Views=1420, CVs=18 },
                      new { Id=2, Title="Backend Engineer (.NET Core)",Level="Mid",      Status="Đang chạy", Badge="active",  Deadline="25/07/2025", Views=980,  CVs=11 },
                      new { Id=3, Title="DevOps / Cloud Engineer",    Level="Senior",   Status="Chờ duyệt", Badge="pending", Deadline="20/08/2025", Views=0,    CVs=0  },
                      new { Id=4, Title="React Native Developer",     Level="Mid",      Status="Hết hạn",   Badge="expired", Deadline="10/07/2025", Views=760,  CVs=9  },
                      new { Id=5, Title="Data Engineer (Spark)",      Level="Junior",   Status="Đã đóng",   Badge="closed",  Deadline="01/07/2025", Views=530,  CVs=6  },
                    };
                  }
                  @foreach (var j in jobs)
                  {
                  <tr>
                    <td style="color:#94a3b8;font-size:13px;">@j.Id</td>
                    <td>
                      <div class="mb-job-title">@j.Title</div>
                      <div class="mb-job-meta">@j.Level · FPT Software</div>
                    </td>
                    <td><span class="mb-badge mb-badge-@j.Badge">@j.Status</span></td>
                    <td style="font-size:13px;color:#374151;">@j.Deadline</td>
                    <td style="font-size:13px;color:#374151;">@j.Views.ToString("N0")</td>
                    <td style="font-size:13px;color:#374151;font-weight:600;">@j.CVs</td>
                    <td>
                      <div class="mb-action-row">
                        <a href="/FindJobByID/Index?id=@j.Id" class="mb-btn mb-btn-sm mb-btn-info">Xem</a>
                        <a href="/Create/Edit?id=@j.Id" class="mb-btn mb-btn-sm mb-btn-warning">Sửa</a>
                        @if (j.Badge == "active") {
                          <button class="mb-btn mb-btn-sm mb-btn-danger" onclick="confirmClose(@j.Id)">Đóng</button>
                        } else if (j.Badge == "expired") {
                          <button class="mb-btn mb-btn-sm mb-btn-outline" onclick="confirmHide(@j.Id)">Ẩn</button>
                        }
                      </div>
                    </td>
                  </tr>
                  }
                </tbody>
              </table>
            </div>
            <div class="mb-pagination">
              <span class="mb-page-info">Hiển thị 1–5 trong tổng số 12 tin</span>
              <div class="mb-page-btns">
                <button class="mb-page-btn">‹</button>
                <button class="mb-page-btn active">1</button>
                <button class="mb-page-btn">2</button>
                <button class="mb-page-btn">3</button>
                <button class="mb-page-btn">›</button>
              </div>
            </div>
          </div>
        </div>
        <!-- /tab-jobs -->

        <!-- ══════════════ CANDIDATE TAB ══════════════ -->
        <div id="tab-candidates" style="display:none;">
