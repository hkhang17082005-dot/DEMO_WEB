                <div class="mb-stat-value">12</div>
                <div class="mb-stat-sub"><b>+2</b> so với tuần trước</div>
              </div>
            </div>
            <div class="mb-stat-card blue">
              <div class="mb-stat-icon">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div class="mb-stat-body">
                <div class="mb-stat-label">CV chưa đọc</div>
                <div class="mb-stat-value">7</div>
                <div class="mb-stat-sub"><b>+7</b> trong hôm nay</div>
              </div>
            </div>
            <div class="mb-stat-card purple">
