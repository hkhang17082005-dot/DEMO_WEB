                <div class="mb-stat-label">Tổng lượt xem tin</div>
                <div class="mb-stat-value">4,821</div>
                <div class="mb-stat-sub"><b>+312</b> trong 7 ngày qua</div>
              </div>
            </div>
          </div>

          <!-- Quick info cards -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:28px;">
            <!-- Lịch phỏng vấn -->
            <div class="mb-card" style="margin-bottom:0;">
              <div class="mb-card-head">
                <span class="mb-card-head-title">
                  <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  Lịch phỏng vấn sắp tới
                </span>
                <a href="#" class="mb-btn mb-btn-outline mb-btn-sm">Xem tất cả</a>
              </div>
              <div style="padding:0 8px;">
                @foreach (var item in new[] {
                  new { Name="Nguyễn Văn A", Role="Frontend Developer", Time="Hôm nay, 14:00", Color="#e6f9ef", Tc="#00b14f", Init="VA" },
                  new { Name="Trần Thị B",   Role="Backend .NET",       Time="Ngày mai, 09:30", Color="#e0f2fe", Tc="#0284c7", Init="TB" },
                  new { Name="Lê Minh C",    Role="DevOps Engineer",    Time="28/07 – 10:00",  Color="#f5f3ff", Tc="#7c3aed", Init="MC" },
                })
                {
                <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;border-bottom:1px solid #f1f5f9;">
                  <div style="width:38px;height:38px;border-radius:50%;background:@item.Color;color:@item.Tc;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;">@item.Init</div>
                  <div style="flex:1;">
                    <div style="font-weight:600;font-size:13.5px;color:#0f172a;">@item.Name</div>
                    <div style="font-size:12px;color:#94a3b8;">@item.Role</div>
                  </div>
                  <div style="text-align:right;">
                    <div style="font-size:12px;font-weight:600;color:#374151;">@item.Time</div>
                    <span class="mb-badge mb-badge-invited" style="margin-top:3px;">Phỏng vấn</span>
                  </div>
                </div>
                }
              </div>
            </div>

            <!-- CV mới nhất -->
            <div class="mb-card" style="margin-bottom:0;">
              <div class="mb-card-head">
                <span class="mb-card-head-title">
                  <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  CV mới nộp hôm nay
                </span>
                <button class="mb-btn mb-btn-outline mb-btn-sm" onclick="showTab('candidates')">Quản lý</button>
              </div>
              <div style="padding:0 8px;">
                @foreach (var cv in new[] {
                  new { Name="Phạm Quang D", Role="React Developer", Applied="Senior Frontend", Time="09:14", IsNew=true  },
                  new { Name="Hoàng Thu E",  Role="Node.js Dev",     Applied="Backend Lead",   Time="10:32", IsNew=true  },
                  new { Name="Vũ Trọng F",   Role="Data Engineer",   Applied="Senior Backend", Time="11:55", IsNew=false },
                  new { Name="Đỗ Lan G",     Role="UX/UI Designer",  Applied="Product Design", Time="13:20", IsNew=false },
                })
                {
                <div style="display:flex;align-items:center;gap:12px;padding:13px 16px;border-bottom:1px solid #f1f5f9;">
                  <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#a855f7,#ec4899);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;">@cv.Name.Substring(0,1)@cv.Name.Split(' ').Last().Substring(0,1)</div>
                  <div style="flex:1;">
                    <div style="font-weight:600;font-size:13px;color:#0f172a;">@cv.Name</div>
                    <div style="font-size:12px;color:#94a3b8;">Ứng tuyển: @cv.Applied</div>
                  </div>
                  <div style="text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:3px;">
                    <span style="font-size:11.5px;color:#94a3b8;">@cv.Time</span>
                    @if (cv.IsNew) { <span class="mb-badge mb-badge-new">Mới</span> } else { <span class="mb-badge mb-badge-review">Đang xem</span> }
                  </div>
                </div>
                }
              </div>
            </div>
          </div>
        </div>
        <!-- /tab-dashboard -->

        <!-- ══════════════ JOB TAB ══════════════ -->
        <div id="tab-jobs" style="display:none;">
