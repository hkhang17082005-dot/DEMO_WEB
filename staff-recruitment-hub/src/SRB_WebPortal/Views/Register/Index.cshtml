@{
   ViewData["Title"] = "Register";
}

<div class="flex items-center justify-center min-h-screen p-4">
   <div class="w-full max-w-md p-8 space-y-8 bg-white border border-gray-100 shadow-xl rounded-2xl">
      <!-- Header -->
      <div class="text-center">
         <h2 class="text-3xl font-bold text-gray-800">Tạo tài khoản mới</h2>
         <p class="mt-2 text-sm text-gray-500">Đăng ký để bắt đầu hành trình của bạn</p>
      </div>

      <!-- Social Register Buttons -->
      <div class="space-y-3">
         <button
            class="flex items-center justify-center w-full gap-3 px-4 py-3 text-gray-700 transition-all duration-200 bg-white border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 group">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
               <path fill="#4285F4"
                     d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
               <path fill="#34A853"
                     d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
               <path fill="#FBBC05"
                     d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
               <path fill="#EA4335"
                     d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
            </svg>
            <span class="text-sm font-medium">Đăng ký với Google</span>
         </button>

         <button
            class="flex items-center justify-center w-full gap-3 px-4 py-3 text-white transition-all duration-200 bg-gray-900 rounded-lg cursor-pointer hover:bg-gray-800 group ">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
               <path fill-rule="evenodd"
                     d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                     clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium">Đăng ký với GitHub</span>
         </button>
      </div>

      <!-- Divider -->
      <div class="relative">
         <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200"></div>
         </div>
         <div class="relative flex justify-center text-sm">
            <span class="px-4 text-gray-400 bg-white">Hoặc đăng ký với email</span>
         </div>
      </div>

      <!-- Register Form -->
      <form class="space-y-6" method="POST" id="registerForm">
         <div class="space-y-4">
            <!-- Username Field -->
            <div>
               <label for="username" class="block mb-1 text-sm font-medium text-gray-700">
                  Tên đăng nhập
               </label>
               <input type="text" id="username" name="username" required
                      class="w-full px-4 py-3 transition-all duration-200 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-200 focus:border-green-400 placeholder:text-sm "
                      placeholder="Tên đăng nhập">
            </div>

            <!-- Password Field -->
            <div>
               <label for="password" class="block mb-1 text-sm font-medium text-gray-700">
                  Mật khẩu
               </label>
               <input type="password" id="password" name="password" required
                      class="w-full px-4 py-3 transition-all duration-200 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-200 focus:border-green-400 placeholder:text-sm"
                      placeholder="Tối thiểu 8 ký tự">
            </div>

            <!-- Confirm Password Field -->
            <div>
               <label for="confirmPassword" class="block mb-1 text-sm font-medium text-gray-700">
                  Xác nhận mật khẩu
               </label>
               <input type="password" id="confirmPassword" name="confirmPassword" required
                      class="w-full px-4 py-3 transition-all duration-200 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-200 focus:border-green-400 placeholder:text-sm"
                      placeholder="Nhập lại mật khẩu">
            </div>
         </div>

         <!-- Password Strength Indicator -->
         <div class="space-y-2">
            <div class="flex h-1 gap-1">
               <div class="flex-1 bg-gray-200 rounded-l-full"></div>
               <div class="flex-1 bg-gray-200"></div>
               <div class="flex-1 bg-gray-200"></div>
               <div class="flex-1 bg-gray-200 rounded-r-full"></div>
            </div>
            <p class="text-xs text-gray-400">Mật khẩu mạnh bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt</p>
         </div>

         <!-- Terms and Conditions -->
         <div class="space-y-3">
            <div class="flex items-start">
               <input type="checkbox" id="terms" name="terms" required
                      class="w-4 h-4 mt-1 text-green-500 transition-all duration-200 border-gray-300 rounded focus:ring-green-200">
               <label for="terms" class="block ml-2 text-sm text-gray-600">
                  Tôi xác nhận đã đọc và đồng ý với
                  <a href="#" class="text-green-600 transition-all duration-200 hover:text-green-500">Điều khoản dịch
                     vụ
                  </a>
                  <span class="mx-1">và</span>
                  <a href="#" class="text-green-600 transition-all duration-200 hover:text-green-500">Chính sách bảo
                     mật
                  </a>
               </label>
            </div>
         </div>

         <!-- Register Button -->
         <button type="submit" class="w-full bg-gray-800 text-white rounded-lg
            px-4 py-3 font-medium hover:bg-gray-700 focus:outline-none
            focus:ring-2 focus:ring-gray-300 transform transition-all
            duration-200 hover:scale-[1.02] cursor-pointer">
            Đăng ký tài khoản
         </button>
      </form>

      <!-- Login Link -->
      <div class="pt-4 text-center border-t border-gray-100">
         <p class="text-sm text-gray-500">
            Đã có tài khoản?
            <a href="/login" class="font-medium text-green-600 transition-all duration-200 hover:text-green-500">
               Đăng nhập ngay
            </a>
         </p>
      </div>
   </div>
</div>

<script>
   document.querySelectorAll('input[type="text"], input[type="email"], input[type="password"]').forEach(input => {
      input.addEventListener('focus', function () {
         this.parentElement.classList.add('focused');
      });
      input.addEventListener('blur', function () {
         if (!this.value) {
            this.parentElement.classList.remove('focused');
         }
      });
   });

   // Optional: Simple password match validation UI
   const password = document.getElementById('password');
   const confirmPassword = document.getElementById('confirm_password');

   if (confirmPassword) {
      confirmPassword.addEventListener('input', function () {
         if (password.value !== this.value) {
            this.classList.add('border-red-300', 'focus:border-red-400', 'focus:ring-red-200');
            this.classList.remove('focus:border-green-400', 'focus:ring-green-200');
         } else {
            this.classList.remove('border-red-300', 'focus:border-red-400', 'focus:ring-red-200');
            this.classList.add('focus:border-green-400', 'focus:ring-green-200');
         }
      });
   }
</script>

<script type="module">
   import authService from '/js/services/authService.js';

   const registerForm = document.getElementById('registerForm');
   const submitBtn = registerForm.querySelector('button[type="submit"]');
   const originalBtnText = "Đăng ký tài khoản";

   registerForm.addEventListener('submit', async (e) => {
   e.preventDefault();

   const formData = new FormData(registerForm);
   const data = Object.fromEntries(formData.entries());

   if (data.password !== data.confirmPassword) {
   alert("Mật khẩu xác nhận không khớp!");
   return;
   }

   submitBtn.disabled = true;
   submitBtn.innerHTML = `
   <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline-block" xmlns="http://www.w3.org" fill="none" viewBox="0 0 24 24">
   <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
   <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
   </svg>
   Đang tạo tài khoản...
   `;
   submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

   try {
   const result = await authService.register(data);

   window.location.href = "/register/CreateProfile";
   } catch (err) {
   console.error("Lỗi:", err.message);
   alert("Đăng ký thất bại: " + err.message);

   submitBtn.disabled = false;
   submitBtn.innerHTML = originalBtnText;
   submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
   }
   });
</script>
