@using SRB_ViewModel.Data
<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
   <div class="max-w-4xl mx-auto bg-white shadow-md rounded-lg overflow-hidden">

      <!-- Header -->
      <div class="bg-indigo-600 px-6 py-4">
         <h2 class="text-2xl font-bold text-white">Tạo Hồ Sơ</h2>
         <p class="text-indigo-100 text-sm">Hoàn thiện thông tin để kết nối với nhà tuyển dụng</p>
      </div>

      <form class="p-8 space-y-6" method="POST" id="createProfileForm">

         <!-- Thông tin cơ bản -->
         <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Avatar Upload -->
            <div class="col-span-1 md:col-span-2 flex items-center space-x-6 mb-4">
               <div class="shrink-0">
                  <img class="h-24 w-24 object-cover rounded-full ring-2 ring-indigo-500"
                       src="https://via.placeholder.com" alt="Avatar preview">
               </div>
               <label class="block">
                  <span class="sr-only">Chọn ảnh đại diện</span>
                  <input type="file" name="AvatarFile" class="block w-full text-sm text-slate-500
                  file:mr-4 file:py-2 file:px-4
                  file:rounded-full file:border-0
                  file:text-sm file:font-semibold
                  file:bg-indigo-50 file:text-indigo-700
                  hover:file:bg-indigo-100" />
               </label>
            </div>

            <!-- Full Name -->
            <div>
               <label class="block text-sm font-medium text-gray-700">Họ và tên *</label>
               <input type="text" name="FullName" required
                      class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"
                      placeholder="VD: Nguyễn Văn A">
            </div>

            <!-- Email -->
            <div>
               <label class="block text-sm font-medium text-gray-700">Email liên hệ *</label>
               <input type="email" name="Email" required
                      class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"
                      placeholder="VD: nguyenvana@gmail.com">
            </div>

            <!-- Phone -->
            <div>
               <label class="block text-sm font-medium text-gray-700">Số điện thoại</label>
               <input type="tel" name="PhoneNumber"
                      class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"
                      placeholder="VD: 0966312345">
            </div>

            <!-- Gender -->
            <div>
               <label class="block text-sm font-medium text-gray-700">Giới tính</label>
               <select name="Gender"
                       class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500">
                  <option value=@GenderTypes.Male selected>Nam</option>
                  <option value=@GenderTypes.Female>Nữ</option>
                  <option value=@GenderTypes.Other>Khác</option>
               </select>
            </div>

            <!-- Birthday -->
            <div>
               <label class="block text-sm font-medium text-gray-700">Ngày sinh</label>
               <input type="date" name="Birthday"
                      class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500">
            </div>

            <!-- Address -->
            <div>
               <label class="block text-sm font-medium text-gray-700">Địa chỉ</label>
               <input type="text" name="Address" placeholder="Quận/Huyện, Tỉnh/Thành phố"
                      class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500">
            </div>
         </div>

         <!-- CV & Giới thiệu -->
         <div class="border-t border-gray-200 pt-6">
            <div>
               <label class="block text-sm font-medium text-gray-700">Giới thiệu bản thân</label>
               <textarea name="Summary" rows="4"
                         placeholder="Tóm tắt ngắn gọn kinh nghiệm và mục tiêu nghề nghiệp của bạn..."
                         class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"></textarea>
            </div>

            <div class="mt-6">
               <label class="block text-sm font-medium text-gray-700 mb-2">Tải lên CV (PDF)</label>
               <div
                  class="flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md hover:border-indigo-400 transition-colors">
                  <div class="space-y-1 text-center">
                     <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                        <path
                        d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                     </svg>
                     <div class="flex text-sm text-gray-600">
                        <label
                           class="relative cursor-pointer bg-white rounded-md font-medium text-indigo-600 hover:text-indigo-500 focus-within:outline-none">
                           <span>Tải file lên</span>
                           <input name="CVFile" type="file" class="sr-only">
                        </label>
                        <p class="pl-1">hoặc kéo thả vào đây</p>
                     </div>
                     <p class="text-xs text-gray-500">PDF lên đến 5MB</p>
                  </div>
               </div>
            </div>
         </div>

         <!-- Nút Action -->
         <div class="flex justify-end space-x-3 pt-4">
            <button type="button"
                    class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">Hủy</button>
            <button type="submit"
                    class="px-6 py-2 bg-indigo-600 border border-transparent rounded-md text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 shadow-lg transition-all">
               Lưu Hồ Sơ
            </button>
         </div>
      </form>
   </div>
</div>

<script type="module">
   import authService from '/js/services/authService.js';

   const createProfileForm = document.getElementById('createProfileForm');

   createProfileForm.addEventListener('submit', async (e) => {
   e.preventDefault();

   const formData = new FormData(createProfileForm);

   try {
   const result = await authService.createProfile(formData);

   window.location.href = "/";
   } catch (err) {
   console.error("Lỗi:", err.message);

   alert("Đăng ký thất bại: " + err.message);
   }
   });
</script>
