@using CloudinaryDotNet.Actions
@{
    ViewData["Title"] = "Việc làm đã ứng tuyển";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="bg-[#f8fafc] min-h-screen py-8 px-4 font-sans antialiased">
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8">
        
        <div class="flex-1 bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100 flex flex-col min-h-[600px] overflow-hidden">
            
            <div class="p-6 border-b border-gray-50 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative z-30">
                <div>
                    <h2 class="text-2xl font-extrabold text-gray-800 tracking-tight">Việc làm đã ứng tuyển</h2>
                    <p class="text-sm text-gray-400 mt-1 font-medium">Theo dõi trạng thái hồ sơ của bạn</p>
                </div>
                
                <div class="relative w-full sm:w-auto" x-data="{ open: false, selected: 'Tất cả trạng thái' }">
                    <button x-on:click="open = !open" 
                            :class="open ? 'border-emerald-500 ring-4 ring-emerald-50' : 'border-gray-200 hover:border-emerald-300'"
                            class="flex items-center justify-between w-full sm:w-60 bg-white border rounded-xl px-5 py-2.5 text-sm font-bold text-gray-600 transition-all focus:outline-none shadow-sm">
                        <span x-text="selected" class="truncate"></span>
                        <i class="fa-solid fa-chevron-down text-[10px] text-gray-400 transition-transform duration-300"
                           :class="open ? 'rotate-180 text-emerald-500' : ''"></i>
                    </button>

                    <div x-show="open" 
                         x-on:click.away="open = false"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 scale-95"
                         x-transition:enter-end="opacity-100 scale-100"
                         class="absolute right-0 mt-2 w-full bg-white border border-gray-100 shadow-2xl rounded-xl overflow-hidden z-50 p-1.5"
                         style="display: none;">
                        
                        <div class="space-y-1">
                            <template x-for="item in ['Tất cả trạng thái', 'Đã ứng tuyển', 'NTD đã xem hồ sơ']">
                                <div x-on:click="selected = item; open = false"
                                     class="flex items-center justify-between px-4 py-3 text-sm rounded-lg cursor-pointer transition-colors"
                                     :class="selected === item ? 'bg-emerald-50 text-emerald-700 font-bold' : 'text-gray-600 hover:bg-gray-50'">
                                    <span x-text="item"></span>
                                    <i x-show="selected === item" class="fa-solid fa-check text-xs"></i>
                                </div>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex-1 flex flex-col items-center justify-center py-20 px-10 text-center">
                <div class="relative mb-10 group">
                    <div class="absolute inset-0 bg-emerald-100 rounded-full blur-3xl opacity-30 group-hover:opacity-50 transition-opacity"></div>
                    
                    <div class="relative w-48 h-48 bg-white rounded-3xl shadow-2xl flex items-center justify-center transform group-hover:rotate-3 transition-transform duration-500 border border-gray-50">
                        <div class="flex flex-col items-center">
                            <div class="w-16 h-2 bg-emerald-500 rounded-full mb-3 opacity-20"></div>
                            <div class="w-24 h-2 bg-emerald-500 rounded-full mb-8 opacity-10"></div>
                            <i class="fa-solid fa-paper-plane text-6xl text-emerald-500 animate-bounce"></i>
                        </div>
                        
                        <div class="absolute -top-4 -right-4 w-12 h-12 bg-orange-100 rounded-2xl flex items-center justify-center text-orange-500 shadow-lg">
                            <i class="fa-solid fa-bolt"></i>
                        </div>
                        <div class="absolute -bottom-2 -left-6 w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center text-blue-500 shadow-lg border-4 border-white">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </div>
                    </div>
                </div>

                <h3 class="text-2xl font-extrabold text-gray-800 mb-3 tracking-tight">Hành trình mới đang chờ bạn</h3>
                <p class="text-gray-400 text-base mb-10 max-w-sm leading-relaxed font-medium">
                    Bạn chưa có hồ sơ ứng tuyển nào. Hãy để những cơ hội hấp dẫn nhất tìm đến bạn ngay hôm nay!
                </p>
                <a href="/" class="group bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-4 px-14 rounded-2xl transition-all shadow-[0_10px_20px_rgba(16,185,129,0.2)] hover:shadow-emerald-200 active:scale-95 flex items-center gap-3">
                    <i class="fa-solid fa-briefcase group-hover:animate-pulse"></i>
                    Tìm việc ngay
                </a>
            </div>
        </div>

        <div class="w-full lg:w-[380px] space-y-6">
            
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-xl font-extrabold text-gray-800 mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-user-gear text-emerald-600"></i>
                    Quản lý hồ sơ
                </h2>
                
                <div class="mb-6 p-4 rounded-2xl bg-slate-50 border border-slate-100 group transition-all" x-data="{ on: true }">
                    <div class="flex items-center justify-between mb-3">
                        <span class="font-bold text-sm text-gray-700" :class="on ? 'text-emerald-700' : ''">Trạng thái tìm việc</span>
                        <div x-on:click="on = !on" 
                             class="w-12 h-6 rounded-full relative cursor-pointer transition-colors duration-300 shadow-inner" 
                             :class="on ? 'bg-emerald-500' : 'bg-gray-300'">
                            <div class="absolute top-1 w-4 h-4 bg-white rounded-full transition-all duration-300 shadow-md" 
                                 :class="on ? 'left-7' : 'left-1'"></div>
                        </div>
                    </div>
                    <p class="text-xs text-gray-500 leading-relaxed font-medium">
                         <span x-text="on ? 'Hồ sơ của bạn đang hiển thị ưu tiên với các Nhà tuyển dụng.' : 'Bật tìm việc để NTD chủ động liên hệ với bạn.'"></span>
                    </p>
                </div>

                <div class="p-4 rounded-2xl hover:bg-emerald-50 transition-all border border-transparent hover:border-emerald-100" x-data="{ on: false }">
                    <div class="flex items-center justify-between mb-2">
                        <span class="font-bold text-sm text-gray-700">Cho phép NTD tìm kiếm</span>
                        <div x-on:click="on = !on" 
                             class="w-12 h-6 rounded-full relative cursor-pointer transition-colors duration-300" 
                             :class="on ? 'bg-emerald-500' : 'bg-gray-300'">
                            <div class="absolute top-1 w-4 h-4 bg-white rounded-full transition-all duration-300 shadow-sm" 
                                 :class="on ? 'left-7' : 'left-1'"></div>
                        </div>
                    </div>
                    <p class="text-[11px] text-gray-400 font-medium">Khi bật, CV của bạn sẽ nằm trong kho dữ liệu tìm kiếm của NTD.</p>
                </div>
            </div>

            <div class="bg-gradient-to-br from-[#1e293b] to-[#0f172a] rounded-3xl p-6 text-white relative overflow-hidden shadow-2xl group">
                <div class="absolute -top-10 -right-10 w-32 h-32 bg-emerald-500 rounded-full blur-[80px] opacity-20 group-hover:opacity-40 transition-opacity"></div>
                
                <div class="relative z-10">
                    <div class="flex gap-4 items-center mb-6">
                        <div class="bg-gradient-to-tr from-orange-400 to-red-500 p-3 rounded-2xl shadow-lg shadow-orange-500/20">
                            <i class="fa-solid fa-crown text-xl"></i>
                        </div>
                        <h3 class="font-bold text-lg leading-tight">Bạn muốn CV được ưu tiên xem trước?</h3>
                    </div>
                    
                    <button class="w-full bg-emerald-500 hover:bg-emerald-400 text-white font-extrabold py-4 rounded-2xl uppercase text-xs tracking-widest shadow-lg shadow-emerald-500/30 transition-all active:scale-95 mb-6">
                        Nâng cấp ngay
                    </button>
                    
                    <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-4 flex items-center gap-4">
                         <div class="w-12 h-12 bg-gradient-to-br from-gray-700 to-gray-800 rounded-full border-2 border-emerald-500/50 flex items-center justify-center shrink-0">
                             <i class="fa-solid fa-user text-gray-500"></i>
                         </div>
                         <div class="flex-1 space-y-2">
                             <div class="h-2 w-2/3 bg-white/20 rounded-full"></div>
                             <div class="h-1.5 w-full bg-white/10 rounded-full"></div>
                         </div>
                         <div class="text-orange-400 animate-pulse">
                             <i class="fa-solid fa-certificate text-xl"></i>
                         </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    /* Custom Scrollbar */
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }

    /* Fix Layout isolate for Safari */
    .isolate { isolation: isolate; }
</style>