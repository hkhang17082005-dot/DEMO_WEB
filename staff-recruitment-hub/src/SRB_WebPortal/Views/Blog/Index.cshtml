@{
    ViewData["Title"] = "Blog";
}

<div class="min-h-screen bg-gray-50">

    <!-- Hero -->
    <section class="bg-gradient-to-br from-green-600 to-emerald-700 py-16">
        <div class="max-w-6xl mx-auto px-6 text-center">
            <span class="inline-block bg-white/20 text-white text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-4">
                📝 Blog & Tin tức
            </span>
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4">Kiến thức nghề nghiệp</h1>
            <p class="text-green-100 text-lg max-w-xl mx-auto">
                Chia sẻ kinh nghiệm, mẹo tìm việc và xu hướng thị trường lao động mới nhất.
            </p>
        </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 py-14">

        <!-- Search & Filter -->
        <div class="flex flex-wrap gap-3 mb-10 items-center justify-between">
            <div class="flex gap-2 flex-wrap">
                <button class="bg-green-600 text-white px-4 py-2 rounded-xl text-sm font-bold">Tất cả</button>
                <button class="bg-white text-gray-600 hover:bg-green-50 px-4 py-2 rounded-xl text-sm font-semibold border border-gray-200 transition">Tìm việc</button>
                <button class="bg-white text-gray-600 hover:bg-green-50 px-4 py-2 rounded-xl text-sm font-semibold border border-gray-200 transition">Viết CV</button>
                <button class="bg-white text-gray-600 hover:bg-green-50 px-4 py-2 rounded-xl text-sm font-semibold border border-gray-200 transition">Phỏng vấn</button>
                <button class="bg-white text-gray-600 hover:bg-green-50 px-4 py-2 rounded-xl text-sm font-semibold border border-gray-200 transition">Thị trường</button>
            </div>
            <div class="relative">
                <input type="text" placeholder="Tìm bài viết..." class="border border-gray-200 rounded-xl px-4 py-2 text-sm w-60 focus:outline-none focus:border-green-400" />
                <span class="absolute right-3 top-2.5 text-gray-400">🔍</span>
            </div>
        </div>

        <!-- Featured Post -->
        <div class="bg-gradient-to-r from-green-600 to-emerald-500 rounded-3xl p-8 mb-10 text-white relative overflow-hidden">
            <div class="absolute right-0 top-0 bottom-0 w-1/3 opacity-10 text-[200px] flex items-center justify-center">📰</div>
            <div class="relative max-w-2xl">
                <span class="bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full mb-4 inline-block">⭐ Nổi bật</span>
                <h2 class="text-2xl md:text-3xl font-black mb-3">10 kỹ năng được nhà tuyển dụng tìm kiếm nhiều nhất năm 2026</h2>
                <p class="text-green-100 text-sm leading-relaxed mb-5">Thị trường lao động đang thay đổi nhanh chóng. Khám phá những kỹ năng hot nhất giúp bạn nổi bật và được tuyển dụng ngay.</p>
                <div class="flex items-center gap-4 text-sm text-green-100">
                    <span>👤 Admin</span>
                    <span>📅 22/03/2026</span>
                    <span>⏱ 5 phút đọc</span>
                </div>
            </div>
        </div>

        <!-- Blog Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <!-- Post 1 -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
                <div class="h-44 bg-gradient-to-br from-blue-400 to-cyan-300 flex items-center justify-center text-5xl">📄</div>
                <div class="p-5">
                    <span class="text-xs font-bold text-green-600 uppercase tracking-wider">Viết CV</span>
                    <h3 class="font-bold text-gray-900 text-base mt-1 mb-2 group-hover:text-green-600 transition-colors">Cách viết CV xin việc chuẩn 2026 gây ấn tượng với nhà tuyển dụng</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">Bí quyết tạo CV chuyên nghiệp, thu hút và vượt qua vòng lọc hồ sơ tự động của doanh nghiệp.</p>
                    <div class="flex items-center justify-between text-xs text-gray-400">
                        <span>📅 20/03/2026</span>
                        <span>⏱ 4 phút đọc</span>
                    </div>
                </div>
            </div>

            <!-- Post 2 -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
                <div class="h-44 bg-gradient-to-br from-purple-400 to-pink-300 flex items-center justify-center text-5xl">🎯</div>
                <div class="p-5">
                    <span class="text-xs font-bold text-green-600 uppercase tracking-wider">Phỏng vấn</span>
                    <h3 class="font-bold text-gray-900 text-base mt-1 mb-2 group-hover:text-green-600 transition-colors">Top 20 câu hỏi phỏng vấn thường gặp và cách trả lời hay nhất</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">Chuẩn bị kỹ lưỡng với những câu hỏi phỏng vấn phổ biến nhất và bí quyết trả lời ấn tượng.</p>
                    <div class="flex items-center justify-between text-xs text-gray-400">
                        <span>📅 18/03/2026</span>
                        <span>⏱ 6 phút đọc</span>
                    </div>
                </div>
            </div>

            <!-- Post 3 -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
                <div class="h-44 bg-gradient-to-br from-orange-400 to-yellow-300 flex items-center justify-center text-5xl">💰</div>
                <div class="p-5">
                    <span class="text-xs font-bold text-green-600 uppercase tracking-wider">Thị trường</span>
                    <h3 class="font-bold text-gray-900 text-base mt-1 mb-2 group-hover:text-green-600 transition-colors">Mức lương ngành IT năm 2026: Những con số bạn cần biết</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">Khảo sát mức lương thực tế của các vị trí IT phổ biến nhất tại Việt Nam năm 2026.</p>
                    <div class="flex items-center justify-between text-xs text-gray-400">
                        <span>📅 15/03/2026</span>
                        <span>⏱ 7 phút đọc</span>
                    </div>
                </div>
            </div>

            <!-- Post 4 -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
                <div class="h-44 bg-gradient-to-br from-green-400 to-teal-300 flex items-center justify-center text-5xl">🔍</div>
                <div class="p-5">
                    <span class="text-xs font-bold text-green-600 uppercase tracking-wider">Tìm việc</span>
                    <h3 class="font-bold text-gray-900 text-base mt-1 mb-2 group-hover:text-green-600 transition-colors">5 bí quyết tìm việc nhanh chóng trong thời đại 4.0</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">Tận dụng công nghệ và mạng lưới quan hệ để tìm được công việc mơ ước nhanh hơn bao giờ hết.</p>
                    <div class="flex items-center justify-between text-xs text-gray-400">
                        <span>📅 12/03/2026</span>
                        <span>⏱ 5 phút đọc</span>
                    </div>
                </div>
            </div>

            <!-- Post 5 -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
                <div class="h-44 bg-gradient-to-br from-red-400 to-pink-300 flex items-center justify-center text-5xl">🤝</div>
                <div class="p-5">
                    <span class="text-xs font-bold text-green-600 uppercase tracking-wider">Kỹ năng</span>
                    <h3 class="font-bold text-gray-900 text-base mt-1 mb-2 group-hover:text-green-600 transition-colors">Kỹ năng mềm quan trọng nhất mà mọi nhà tuyển dụng đều muốn</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">Ngoài kiến thức chuyên môn, đây là những kỹ năng mềm giúp bạn thăng tiến nhanh hơn.</p>
                    <div class="flex items-center justify-between text-xs text-gray-400">
                        <span>📅 10/03/2026</span>
                        <span>⏱ 4 phút đọc</span>
                    </div>
                </div>
            </div>

            <!-- Post 6 -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
                <div class="h-44 bg-gradient-to-br from-indigo-400 to-purple-300 flex items-center justify-center text-5xl">🚀</div>
                <div class="p-5">
                    <span class="text-xs font-bold text-green-600 uppercase tracking-wider">Thị trường</span>
                    <h3 class="font-bold text-gray-900 text-base mt-1 mb-2 group-hover:text-green-600 transition-colors">Xu hướng tuyển dụng 2026: Những ngành nghề hot nhất hiện nay</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">AI, Data Science, Cybersecurity đang là những ngành có nhu cầu tuyển dụng cao nhất năm 2026.</p>
                    <div class="flex items-center justify-between text-xs text-gray-400">
                        <span>📅 08/03/2026</span>
                        <span>⏱ 6 phút đọc</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-center gap-2 mt-12">
            <button class="w-10 h-10 rounded-xl border border-gray-200 text-gray-500 hover:bg-green-50 hover:border-green-300 transition text-sm font-semibold">←</button>
            <button class="w-10 h-10 rounded-xl bg-green-600 text-white text-sm font-bold">1</button>
            <button class="w-10 h-10 rounded-xl border border-gray-200 text-gray-500 hover:bg-green-50 hover:border-green-300 transition text-sm font-semibold">2</button>
            <button class="w-10 h-10 rounded-xl border border-gray-200 text-gray-500 hover:bg-green-50 hover:border-green-300 transition text-sm font-semibold">3</button>
            <button class="w-10 h-10 rounded-xl border border-gray-200 text-gray-500 hover:bg-green-50 hover:border-green-300 transition text-sm font-semibold">→</button>
        </div>

    </div>
</div>
