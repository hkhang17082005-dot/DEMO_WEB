@{
   ViewData["Title"] = "Đăng tin tuyển dụng";
}

<div class="container max-w-4xl p-6 mx-auto">
   <div class="flex items-center justify-between mb-6">
      <h2 class="text-3xl font-bold text-gray-800">Đăng tin tuyển dụng mới</h2>
      <a href="/Business/MyJobs" class="flex items-center text-blue-600 transition duration-200 hover:text-blue-800">
         <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18">
            </path>
         </svg>
         Quay lại danh sách
      </a>
   </div>

   <div class="p-8 bg-white border border-gray-100 shadow-lg rounded-xl">
      <form id="postJobForm" class="space-y-6">
         <div>
            <label class="block mb-2 text-sm font-semibold text-gray-700">
               Tiêu đề công việc
               <span class="text-red-500">*</span>
            </label>
            <input type="text" id="Title" name="Title" required
                   class="w-full px-4 py-3 transition border border-gray-300 rounded-lg shadow-sm outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                   placeholder="VD: Lập trình viên .NET Core / Chuyên viên Marketing">
         </div>

         <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div>
               <label class="block mb-2 text-sm font-semibold text-gray-700">Số lượng cần tuyển</label>
               <input type="number" id="Quantity" name="Quantity" min="1"
                      class="w-full px-4 py-3 transition border border-gray-300 rounded-lg shadow-sm outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      placeholder="VD: 5">
            </div>
            <div>
               <label class="block mb-2 text-sm font-semibold text-gray-700">Mức lương</label>
               <input type="text" id="SalaryRange" name="SalaryRange"
                      class="w-full px-4 py-3 transition border border-gray-300 rounded-lg shadow-sm outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      placeholder="VD: 15 - 20 Triệu / Thỏa thuận">
            </div>
         </div>

         <div>
            <label class="block mb-2 text-sm font-semibold text-gray-700">
               Địa điểm làm việc
               <span class="text-red-500">*</span>
            </label>
            <input type="text" id="Location" name="Location" required
                   class="w-full px-4 py-3 transition border border-gray-300 rounded-lg shadow-sm outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                   placeholder="VD: Tòa nhà ABC, Quận 1, TP.HCM">
         </div>

         <div>
            <label class="block mb-2 text-sm font-semibold text-gray-700">
               Mô tả công việc
               <span class="text-red-500">*</span>
            </label>
            <textarea id="Description" name="Description" required rows="5"
                   class="w-full px-4 py-3 transition border border-gray-300 rounded-lg shadow-sm outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      placeholder="- Phát triển tính năng mới...&#10;- Bảo trì hệ thống cũ...">
            </textarea>
         </div>

         <div>
            <label class="block mb-2 text-sm font-semibold text-gray-700">Yêu cầu ứng viên</label>
            <textarea id="Requirements" name="Requirements" rows="4"
                   class="w-full px-4 py-3 transition border border-gray-300 rounded-lg shadow-sm outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      placeholder="- Có ít nhất 1 năm kinh nghiệm...&#10;- Tinh thần trách nhiệm cao...">
            </textarea>
         </div>

         <div id="errorMessage"
              class="items-center hidden p-4 mt-4 text-sm text-red-600 border border-red-200 rounded-lg bg-red-50">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                     d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span id="errorText"></span>
         </div>

         <div class="flex justify-end pt-6 mt-6 border-t border-gray-100">
            <button type="button" onclick="window.location.href='/Business/MyJobs'"
                    class="px-6 py-3 mr-4 font-semibold text-gray-700 transition duration-200 bg-gray-100 rounded-lg hover:bg-gray-200">
               Hủy bỏ
            </button>
            <button type="submit" id="submitBtn"
                    class="flex items-center justify-center px-8 py-3 font-semibold text-white transition duration-200 bg-blue-600 rounded-lg shadow-md hover:bg-blue-700 min-w-40">
               <span id="btnText">Đăng Tin Ngay</span>
               <div id="btnSpinner" class="hidden w-5 h-5 ml-2 border-b-2 border-white rounded-full animate-spin"></div>
            </button>
         </div>
      </form>
   </div>
</div>

@section Scripts {
   <script>
      document.getElementById('postJobForm').addEventListener('submit', async function (e) {
         e.preventDefault(); // Ngăn trình duyệt tự reload trang

         // Trỏ các phần tử DOM
         const btn = document.getElementById('submitBtn');
         const btnText = document.getElementById('btnText');
         const btnSpinner = document.getElementById('btnSpinner');
         const errorMessage = document.getElementById('errorMessage');
         const errorText = document.getElementById('errorText');

         // Gom dữ liệu từ Form
         const formData = {
            title: document.getElementById('Title').value.trim(),
            quantity: document.getElementById('Quantity').value ? parseInt(document.getElementById('Quantity').value) : null,
            salaryRange: document.getElementById('SalaryRange').value.trim(),
            location: document.getElementById('Location').value.trim(),
            description: document.getElementById('Description').value.trim(),
            requirements: document.getElementById('Requirements').value.trim()
         };

         // Kích hoạt trạng thái "Đang xử lý"
         btn.disabled = true;
         btn.classList.add('opacity-75', 'cursor-not-allowed');
         btnText.textContent = 'Đang xử lý...';
         btnSpinner.classList.remove('hidden');
         errorMessage.classList.add('hidden');

         try {
            // LƯU Ý: Chỉnh sửa lại URL này cho đúng với API Post của bạn (ví dụ: '/api/post' hoặc '/api/business/post-job')
            // Đổi từ fetch('/api/post', ...) thành fetch('/api/post/create', ...)
            const response = await fetch('/api/post/create', {
               method: 'POST',
               headers: {
                  'Content-Type': 'application/json'
               },
               body: JSON.stringify(formData)
            });

            // Nếu phiên đăng nhập bị lỗi hoặc hết hạn
            if (response.status === 401) {
               window.location.href = '/Login';
               return;
            }

            const result = await response.json();

            // Xử lý kết quả trả về
            if (response.ok && result.isSuccess !== false) {
               // Nếu dùng thư viện SweetAlert2 thì thay alert bằng Swal.fire sẽ đẹp hơn nhiều
               alert('Đăng tin tuyển dụng thành công!');

               // Chuyển hướng "mượt mà" về trang danh sách việc làm
               window.location.href = '/Business/MyJobs';
            } else {
               // Báo lỗi từ server
               errorText.textContent = result.message || 'Có lỗi xảy ra khi lưu dữ liệu. Vui lòng kiểm tra lại.';
               errorMessage.classList.remove('hidden');
            }
         } catch (error) {
            console.error('Lỗi Call API:', error);
            errorText.textContent = 'Lỗi kết nối máy chủ. Vui lòng kiểm tra mạng và thử lại.';
            errorMessage.classList.remove('hidden');
         } finally {
            // 4. Tắt trạng thái Loading dù thành công hay thất bại
            btn.disabled = false;
            btn.classList.remove('opacity-75', 'cursor-not-allowed');
            btnText.textContent = 'Đăng Tin Ngay';
            btnSpinner.classList.add('hidden');
         }
      });
   </script>
}
