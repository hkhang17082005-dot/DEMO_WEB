@using SRB_ViewModel.Entities
@{
   ViewData["Title"] = "Tạo Chiến Dịch Tuyển Dụng Mới";

   Layout = "~/Views/Shared/_BusinessLayout.cshtml";
}

<a href="/Business/MyJobPost"
   class="text-gray-500 hover:text-green-600 transition flex items-center gap-2 text-sm font-medium mb-6">
   <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
</a>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-4xl mx-auto">
   <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b border-gray-100 pb-4">Thông tin chiến dịch</h2>

   <form id="createPostForm" class="space-y-6">
      <div>
         <label class="block text-sm font-bold text-gray-700 mb-2">Tiêu đề bài đăng tuyển dụng
            <span class="text-red-500">*</span>
         </label>
         <input type="text" name="title" required placeholder="VD: Lập trình viên Backend .NET"
                class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition">
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
         <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Ngành nghề</label>
            <select class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500">
               <option>IT - Phần mềm</option>
               <option>Marketing / Truyền thông</option>
               <option>Kinh doanh / Bán hàng</option>
            </select>
         </div>

         <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Khu vực làm việc</label>
            <select name="LocationID" required
                    class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500">
               <option value="">-- Chọn khu vực --</option>

               @if (ViewBag.Locations != null)
               {
                  foreach (var loc in (IEnumerable<Location>)ViewBag.Locations)
                  {
                     <option value="@loc.LocationID">@loc.LocationName</option>
                  }
               }
            </select>
         </div>

         <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Mức lương (VND)</label>
            <div class="flex items-center gap-2">
               <input type="text" name="SalaryRange" required placeholder="Thỏa thuận"
                      class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500">
            </div>
         </div>

         <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Hạn nhận hồ sơ
               <span class="text-red-500">*</span>
            </label>
            <input type="date" name="expiryDate" required
                   class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500 text-gray-600">
         </div>
      </div>

      <div>
         <label class="block text-sm font-bold text-gray-700 mb-2">Email nhận hồ sơ
            <span class="text-red-500">*</span>
         </label>
         <input type="email" name="contactEmail" required placeholder="hr@company.com"
                class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500">
      </div>

      <div>
         <label class="block text-sm font-bold text-gray-700 mb-2">Địa chỉ làm việc
            <span class="text-red-500">*</span>
         </label>
         <input type="text" name="address" required placeholder="Thủ Đức, TP Hồ Chí Minh"
                class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500">
      </div>

      <div class="pt-4">
         <label class="block text-sm font-bold text-gray-700 mb-2">Mô tả công việc
            <span class="text-red-500">*</span>
         </label>
         <div class="bg-gray-50 border border-gray-200 rounded-t-lg p-2 flex gap-2">
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-bold text-gray-600"></i>
            </button>
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-italic text-gray-600"></i>
            </button>
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-list-ul text-gray-600"></i>
            </button>
         </div>
         <textarea rows="6" name="description" placeholder="- Viết các mô tả công việc tại đây..."
                   class="w-full border-x border-b border-gray-300 rounded-b-lg p-4 outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"></textarea>
      </div>

      <div>
         <label class="block text-sm font-bold text-gray-700 mb-2">Mô tả yêu cầu
            <span class="text-red-500">*</span>
         </label>
         <div class="bg-gray-50 border border-gray-200 rounded-t-lg p-2 flex gap-2">
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-bold text-gray-600"></i>
            </button>
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-italic text-gray-600"></i>
            </button>
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-list-ul text-gray-600"></i>
            </button>
         </div>
         <textarea rows="6" name="requirements" placeholder="- Viết các yêu cầu công việc tại đây..."
                   class="w-full border-x border-b border-gray-300 rounded-b-lg p-4 outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"></textarea>
      </div>

      <div>
         <label class="block text-sm font-bold text-gray-700 mb-2">Mô tả đãi ngộ
            <span class="text-red-500">*</span>
         </label>
         <div class="bg-gray-50 border border-gray-200 rounded-t-lg p-2 flex gap-2">
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-bold text-gray-600"></i>
            </button>
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-italic text-gray-600"></i>
            </button>
            <button type="button" class="p-2 hover:bg-gray-200 rounded">
               <i class="fa-solid fa-list-ul text-gray-600"></i>
            </button>
         </div>
         <textarea rows="6" name="benefits" placeholder="- Viết các đãi ngộ công việc tại đây..."
                   class="w-full border-x border-b border-gray-300 rounded-b-lg p-4 outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"></textarea>
      </div>

      <p class="text-xs text-gray-500 mt-2">
         Gợi ý: Trình bày rõ ràng thành các gạch đầu dòng sẽ thu hút ứng viên hơn
      </p>

      <div class="flex justify-end gap-4 pt-6 border-t border-gray-100">
         <button type="button"
                 class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg font-bold hover:bg-gray-50 transition">
            Lưu Nháp
         </button>
         <button type="submit" id="btnPublish"
                 class="px-8 py-3 bg-green-600 text-white rounded-lg font-bold shadow-md shadow-green-200 hover:bg-green-700 transition">
            <i class="fa-solid fa-paper-plane mr-2"></i> Đăng Chiến Dịch
         </button>
      </div>
   </form>
</div>

@section Scripts {
   <script type="module">
      import postService from '/js/services/postService.js';

      document.getElementById('createPostForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btnPublish');
      const formData = new FormData(e.target);
      const submitData = Object.fromEntries(formData.entries());

      try {
      btn.disabled = true;
      const originalContent = btn.innerHTML;
      btn.innerHTML = '<i class="fa-solid fa-circle-notch animate-spin mr-2"></i> Đang đăng...';

      const res = await postService.savePost(submitData);

      if (res.isSuccess) {
      alert("Đăng tin tuyển dụng thành công!");
      window.location.href = "/Business/MyJobPost";
      } else {
      alert("Lỗi: " + res.message);
      // Trả lại trạng thái nút nếu server trả lỗi
      btn.disabled = false;
      btn.innerHTML = originalContent;
      }
      } catch (err) {
      console.error("Lỗi hệ thống:", err);
      alert("Có lỗi xảy ra, vui lòng thử lại sau.");
      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-paper-plane mr-2"></i> Đăng Chiến Dịch';
      }
      });
   </script>
}
