@{
    ViewData["Title"] = "Đăng tin tuyển dụng";
}

<div class="bg-white border-b shadow-sm mb-6">
    <div class="container mx-auto px-4 flex gap-8">
        <a href="/Business/Index" class="py-4 font-semibold text-gray-500 hover:text-blue-600 transition">Tổng quan</a>
        <a href="/Business/MyJobs" class="py-4 font-bold border-b-2 border-blue-600 text-blue-600">Quản lý tin tuyển
            dụng</a>
            <a href="/Business/Profile" class="py-4 font-semibold text-gray-500 hover:text-blue-600 transition">Hồ sơ công
                ty</a>
            </div>
        </div>

        <main class="container mx-auto px-4 pb-12">
            <a href="/Business/MyJobs"
                   class="inline-flex items-center text-gray-500 hover:text-blue-600 font-medium mb-6 transition">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18">
                    </path>
                </svg>
                Quay lại danh sách tin
            </a>

            <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-200 max-w-4xl mx-auto">
                <h2 class="text-2xl font-bold text-gray-800 border-b pb-4 mb-6">Tạo tin tuyển dụng mới</h2>

                <form id="postJobForm" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Chức danh / Vị trí cần tuyển <span
                                class="text-red-500">*</span></label>
                                <input type="text" id="jobTitle"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                       placeholder="VD: Lập trình viên ASP.NET, Chuyên viên Marketing..." required>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Mức lương dự kiến</label>
                                <input type="text" id="jobSalary"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                       placeholder="VD: 15 - 20 Triệu, Thỏa thuận...">
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Hình thức làm việc</label>
                                <select id="jobType"
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none bg-white">
                                    <option value="Toàn thời gian">Toàn thời gian (Full-time)</option>
                                    <option value="Bán thời gian">Bán thời gian (Part-time)</option>
                                    <option value="Thực tập">Thực tập sinh (Intern)</option>
                                    <option value="Làm từ xa">Làm từ xa (Remote)</option>
                                </select>
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Địa điểm làm việc</label>
                                <input type="text" id="jobLocation"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                       placeholder="Nơi ứng viên sẽ làm việc...">
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Mô tả công việc chi tiết <span
                                    class="text-red-500">*</span></label>
                                    <textarea id="jobDescription" rows="6"
                                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                              placeholder="- Mô tả các công việc ứng viên cần làm&#10;- Yêu cầu kinh nghiệm&#10;- Quyền lợi được hưởng..."
                                              required></textarea>
                                </div>
                            </div>

                            <div class="flex justify-end pt-6 border-t border-gray-100 mt-8">
                                <button type="button" class="px-6 py-3 text-gray-500 hover:text-gray-700 font-medium mr-4">Hủy
                                    bỏ</button>
                                    <button type="submit" id="publishJobBtn"
                                            class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg shadow-md transition">
                                        Đăng Tin Tuyển Dụng
                                    </button>
                                </div>
                            </form>
                        </div>
                    </main>

                    @section Scripts {
                        <script src="~/js/business.js"></script>
                    }