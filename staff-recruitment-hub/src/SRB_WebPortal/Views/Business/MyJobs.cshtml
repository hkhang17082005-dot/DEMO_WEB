@{
   ViewData["Title"] = "Quản lý tin tuyển dụng";
}

<main class="container mx-auto px-4 pb-12">
   <div class="flex justify-between items-center mb-6">
      <div>
         <h2 class="text-2xl font-bold text-gray-800">Tin tuyển dụng của bạn</h2>
         <p class="text-gray-500 text-sm mt-1">Quản lý, chỉnh sửa hoặc xóa các tin tuyển dụng đang hiển thị.</p>
      </div>
      <a href="/Business/PostJob"
         class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg shadow font-medium transition flex items-center gap-2">
         <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
         </svg>
         Đăng tin mới
      </a>
   </div>

   <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
         <table class="w-full text-left text-sm text-gray-600">
            <thead class="bg-gray-50 text-gray-700 font-semibold border-b">
               <tr>
                  <th scope="col" class="px-6 py-4">Chức danh / Vị trí</th>
                  <th scope="col" class="px-6 py-4">Hình thức</th>
                  <th scope="col" class="px-6 py-4">Mức lương</th>
                  <th scope="col" class="px-6 py-4 text-center">Trạng thái</th>
                  <th scope="col" class="px-6 py-4 text-right">Thao tác</th>
               </tr>
            </thead>
            <tbody id="jobsTableBody" class="divide-y divide-gray-100">
               <tr>
                  <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                     <div class="flex justify-center items-center gap-2">
                        <div class="w-5 h-5 border-2 border-blue-600 border-t-transparent rounded-full animate-spin">
                        </div>
                        Đang tải dữ liệu...
                     </div>
                  </td>
               </tr>
            </tbody>
         </table>
      </div>
   </div>
</main>

@section Scripts {
   <script src="~/js/business.js"></script>
}
