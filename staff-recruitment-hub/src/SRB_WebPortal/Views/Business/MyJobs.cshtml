@model List<SRB_ViewModel.Entities.JobPost>

@{
   ViewData["Title"] = "Quản lý chiến dịch tuyển dụng";
   Layout = "~/Views/Shared/_BusinessLayout.cshtml";
}

<div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 mb-6 flex items-center justify-between gap-4">
   <div class="flex-1 relative">
      <i class="fa-solid fa-magnifying-glass absolute left-4 top-3 text-gray-400"></i>
      <input type="text" placeholder="Tìm kiếm theo tiêu đề chiến dịch..."
             class="w-full pl-11 pr-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-green-500 focus:bg-white outline-none transition text-sm">
   </div>
   <div class="flex gap-3">
      <select
         class="border border-gray-200 bg-gray-50 text-gray-700 py-2.5 px-4 rounded-lg outline-none text-sm focus:ring-2 focus:ring-green-500">
         <option>Trạng thái: Tất cả</option>
         <option>Đang hiển thị</option>
         <option>Đã đóng</option>
      </select>
      <a href="/Business/PostJob"
         class="bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-lg font-medium shadow-sm transition">
         Tạo chiến dịch mới
      </a>
   </div>
</div>

<div class="space-y-4">
   @if (Model != null && Model.Any())
   {
      foreach (var job in Model)
      {
         <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:border-green-400 transition overflow-hidden">
            <div class="p-5 flex justify-between items-start gap-6">
                    
               <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                     @if (job.IsActive)
                     {
                        <span
                           class="px-2.5 py-1 bg-green-100 text-green-700 text-[11px] font-bold rounded-full uppercase tracking-wide">Đang
                           hiển thị</span>
                        }
                            else
                        {
                           <span
                              class="px-2.5 py-1 bg-gray-100 text-gray-600 text-[11px] font-bold rounded-full uppercase tracking-wide">Đã
                              đóng</span>
                           }
                            
                           <span class="text-xs text-gray-400">
                              <i class="fa-regular fa-clock mr-1"></i> Ngày đăng: @job.CreatedAt.ToString("dd/MM/yyyy")
                           </span>
                        </div>
                        <h3 class="text-lg font-bold text-gray-800 hover:text-green-600 transition cursor-pointer mb-2">
                           @job.Title
                        </h3>
                        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600">
                           <span><i class="fa-solid fa-location-dot mr-1 text-gray-400"></i> @job.Location</span>
                           <span><i class="fa-solid fa-sack-dollar mr-1 text-gray-400"></i> @job.SalaryRange</span>
                        </div>
                     </div>

                     <div class="flex gap-4">
                        <div class="bg-gray-50 border border-gray-100 rounded-lg p-3 text-center min-w-[90px]">
                           <p class="text-2xl font-bold text-gray-700">0</p>
                           <p class="text-[11px] text-gray-500 font-medium mt-1">LƯỢT XEM</p>
                        </div>
                        
                        <a href="/Business/CVList?jobId=@job.JobPostID"
                           class="bg-green-50 border border-green-100 rounded-lg p-3 text-center min-w-[90px] cursor-pointer hover:bg-green-100 transition group">
                           <p class="text-2xl font-bold text-green-600 group-hover:scale-110 transition">0</p>
                           <p class="text-[11px] text-green-700 font-bold mt-1 uppercase">CV Ứng tuyển</p>
                        </a>
                     </div>
                  </div>
               </div>
            }
         }
    else
         {
            <div class="text-center py-10 bg-white rounded-xl border border-dashed border-gray-300">
               <p class="text-gray-500">Chưa có chiến dịch tuyển dụng nào.</p>
            </div>
         }
      </div>