@{
   ViewData["Title"] = "Cập nhật Hồ sơ Doanh nghiệp";
   Layout = "~/Views/Shared/_BusinessLayout.cshtml";
}

<div class="flex flex-col md:flex-row gap-8 max-w-6xl mx-auto">
    
   @* <div class="w-full md:w-64 shrink-0">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
         <div class="p-4 border-b border-gray-100 bg-gray-50">
            <p class="font-bold text-gray-800">Cài đặt chung</p>
         </div>
         <nav class="flex flex-col p-2">
            <a href="#" class="px-4 py-2.5 bg-green-50 text-green-700 font-medium rounded-lg transition">
               Thông tin công ty
            </a>
            <a href="#"
               class="px-4 py-2.5 text-gray-600 hover:bg-gray-50 hover:text-green-600 font-medium rounded-lg transition">
               Giấy phép kinh doanh
            </a>
            <a href="#"
               class="px-4 py-2.5 text-gray-600 hover:bg-gray-50 hover:text-green-600 font-medium rounded-lg transition">
               Bảo mật tài khoản
            </a>
         </nav>
      </div>
   </div> *@

   <div class="flex-1">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
         <h2 class="text-xl font-bold text-gray-800 mb-6 pb-4 border-b border-gray-100">Thông tin cơ bản</h2>
            
         <form class="space-y-6">
            <div class="flex items-center gap-8 mb-8">
               <div class="relative group cursor-pointer">
                  <div
                     class="w-24 h-24 rounded-full border-2 border-dashed border-gray-300 flex items-center justify-center bg-gray-50 group-hover:bg-green-50 group-hover:border-green-400 transition overflow-hidden">
                     <i class="fa-solid fa-camera text-gray-400 text-2xl group-hover:text-green-500 transition"></i>
                  </div>
                  <div
                     class="absolute -bottom-2 right-0 bg-white border border-gray-200 p-1.5 rounded-full shadow-sm text-gray-500 hover:text-green-600">
                     <i class="fa-solid fa-pen text-xs"></i>
                  </div>
               </div>
               <div>
                  <h3 class="font-bold text-gray-800 text-lg">Logo Công Ty</h3>
                  <p class="text-sm text-gray-500 mt-1">Định dạng .JPG, .PNG. Kích thước tối ưu 400x400px.</p>
                  <button type="button" class="mt-3 text-sm font-medium text-green-600 hover:underline">Tải ảnh
                     lên</button>
                  </div>
               </div>

               <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div class="md:col-span-2">
                     <label class="block text-sm font-bold text-gray-700 mb-2">Tên công ty (Đầy đủ) <span
                        class="text-red-500">*</span></label>
                        <input type="text" placeholder="VD: Công ty Cổ phần Công nghệ ABC"
                               class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500 transition">
                     </div>

                     <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Mã số thuế <span
                           class="text-red-500">*</span></label>
                           <input type="text" placeholder="Nhập MST..."
                                  class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500 transition">
                        </div>

                        <div>
                           <label class="block text-sm font-bold text-gray-700 mb-2">Quy mô nhân sự</label>
                           <select
                              class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500">
                              <option>Dưới 50 người</option>
                              <option>50 - 150 người</option>
                              <option>150 - 500 người</option>
                              <option>Trên 500 người</option>
                           </select>
                        </div>

                        <div>
                           <label class="block text-sm font-bold text-gray-700 mb-2">Website</label>
                           <input type="text" placeholder="https://..."
                                  class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500 transition">
                        </div>

                        <div>
                           <label class="block text-sm font-bold text-gray-700 mb-2">Năm thành lập</label>
                           <input type="number" placeholder="VD: 2015"
                                  class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-green-500 transition">
                        </div>
                     </div>

                     <div class="pt-4">
                        <label class="block text-sm font-bold text-gray-700 mb-2">Giới thiệu về công ty</label>
                        <textarea rows="5" placeholder="Mô tả môi trường làm việc, văn hóa, chế độ đãi ngộ..."
                                  class="w-full border border-gray-300 rounded-lg p-4 outline-none focus:ring-2 focus:ring-green-500 transition"></textarea>
                     </div>

                     <div class="flex justify-end pt-6 border-t border-gray-100">
                        <button type="button"
                                class="px-8 py-3 bg-green-600 text-white rounded-lg font-bold shadow-md shadow-green-200 hover:bg-green-700 transition">
                           Lưu Thay Đổi
                        </button>
                     </div>
                  </form>
               </div>
            </div>
         </div>