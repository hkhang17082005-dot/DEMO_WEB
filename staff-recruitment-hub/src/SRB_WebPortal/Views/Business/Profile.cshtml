@{
   ViewData["Title"] = "Hồ sơ công ty";
}

<main class="container mx-auto px-4 pb-12">
   <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <div class="lg:col-span-1">
         <h2 class="text-2xl font-bold text-gray-800">Thông tin chung</h2>
         <p class="text-gray-500 mt-2 text-sm leading-relaxed">Cập nhật thông tin chi tiết về doanh nghiệp của bạn.
            Những thông tin này sẽ hiển thị trực tiếp với các ứng viên trên trang chủ.</p>
         </div>

         <div class="lg:col-span-2 bg-white p-8 rounded-xl shadow-sm border border-gray-200">
            <form id="businessProfileForm" class="space-y-6">
               <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-2">Tên doanh nghiệp hiển thị <span
                     class="text-red-500">*</span></label>
                     <input type="text" id="companyNameInput"
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none transition-shadow"
                            placeholder="VD: Công ty TNHH Phần mềm ABC" required>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                     <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Mã số thuế</label>
                        <input type="text" id="taxCodeInput"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none transition-shadow"
                               placeholder="Nhập mã số thuế">
                     </div>
                     <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Số điện thoại liên hệ <span
                           class="text-red-500">*</span></label>
                           <input type="tel" id="phoneInput"
                                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none transition-shadow"
                                  placeholder="Nhập số điện thoại" required>
                        </div>
                     </div>

                     <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Địa chỉ trụ sở chính</label>
                        <input type="text" id="addressInput"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none transition-shadow"
                               placeholder="Số nhà, đường, quận/huyện...">
                     </div>

                     <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Giới thiệu về công ty</label>
                        <textarea id="descriptionInput" rows="5"
                                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none transition-shadow"
                                  placeholder="Mô tả môi trường làm việc, văn hóa, phúc lợi..."></textarea>
                     </div>

                     <div class="flex justify-end pt-6 border-t border-gray-100">
                        <button type="submit" id="saveProfileBtn"
                                class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg shadow-md transition">
                           Lưu Thông Tin
                        </button>
                     </div>
                  </form>
               </div>

            </div>
         </main>

         @section Scripts {
            <script src="~/js/business.js"></script>
         }
