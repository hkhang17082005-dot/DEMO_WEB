@using SRB_WebPortal.Controllers.apis.business
@model List<JobPostApprovalDTO>
@{
   ViewData["Title"] = "Hồ sơ ứng viên: " + ViewBag.JobTitle;

   Layout = "~/Views/Shared/_BusinessLayout.cshtml";
}

<div class="mb-6 flex items-center justify-between">
   <a href="/Business/MyJobPost"
      class="text-gray-500 hover:text-green-600 transition flex items-center gap-2 text-sm font-medium">
      <i class="fa-solid fa-arrow-left"></i> Quay lại chiến dịch
   </a>
   <div class="text-sm text-gray-500">
      Tổng số: <span class="font-bold text-gray-800">@Model.Count CV</span>
   </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
   <table class="w-full text-left border-collapse">
      <thead class="bg-gray-50 text-gray-600 text-[13px] uppercase tracking-wider border-b border-gray-200">
         <tr>
            <th class="py-4 px-6 font-semibold w-1/3">Ứng viên</th>
            <th class="py-4 px-6 font-semibold">Thời gian nộp</th>
            <th class="py-4 px-6 font-semibold">Trạng thái</th>
            <th class="py-4 px-6 font-semibold text-right">Thao tác</th>
         </tr>
      </thead>
      <tbody class="text-sm">
         @if (Model != null && Model.Any())
         {
            foreach (var item in Model)
            {
               <tr class="border-b border-gray-100 hover:bg-green-50/50 transition group">
                  <td class="py-4 px-6">
                     <div class="flex items-center gap-3">
                        <div
                           class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold">
                           @item.CandidateName.Substring(0, 1)
                        </div>
                        <div>
                           <p class="font-bold text-gray-800 text-base group-hover:text-green-600 transition">
                              @item.CandidateName
                           </p>
                           <p class="text-gray-500 text-xs mt-0.5"><i class="fa-solid fa-envelope mr-1"></i>
                              @item.CandidateEmail
                           </p>
                        </div>
                     </div>
                  </td>
                  <td class="py-4 px-6 text-gray-600">
                     @item.AppliedAt.ToString("dd/MM/yyyy - HH:mm")
                  </td>
                  <td class="py-4 px-6">
                     <span class="border px-3 py-1 rounded-full text-xs font-bold shadow-sm">
                        @item.Status
                     </span>
                  </td>
                  <td class="py-4 px-6 text-right">
                     <a href="/Business/ReviewCV?applicationID=@item.ApplicationID" target="_blank"
                        class="inline-block bg-white border border-gray-300 text-gray-700 hover:border-green-500 hover:text-green-600 px-4 py-2 rounded-lg font-medium transition shadow-sm">
                        Xem & Duyệt
                     </a>
                  </td>
               </tr>
            }
         }
         else
         {
            <tr>
               <td colspan="4" class="py-10 text-center text-gray-500">
                  Chưa có ứng viên nào nộp hồ sơ cho chiến dịch này!
               </td>
            </tr>
         }
      </tbody>
   </table>
</div>
