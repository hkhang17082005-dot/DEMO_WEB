@model List<SRB_WebPortal.Data.JobMock.MockApplication>
@{
    // Giữ nguyên Title và Layout của bạn
    ViewData["Title"] = "Hồ sơ ứng viên: " + ViewBag.JobTitle;
    Layout = "~/Views/Shared/_BusinessLayout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>

<div class="mb-6 flex items-center justify-between">
    <a href="/Business/MyJobs" class="text-gray-500 hover:text-green-600 transition flex items-center gap-2 text-sm font-medium">
        <i class="fa-solid fa-arrow-left"></i> Quay lại chiến dịch
    </a>
    <div class="text-sm text-gray-500">
        Tổng số: <span class="font-bold text-gray-800">@Model.Count CV</span>
    </div>
</div>

<div class="flex overflow-x-auto space-x-4 pb-8 items-start min-h-[600px]">

    <div class="flex-shrink-0 w-80 bg-gray-50 border border-gray-200 rounded-xl shadow-sm flex flex-col">
        <div class="p-4 border-b border-gray-200 bg-white rounded-t-xl flex justify-between items-center">
            <h3 class="font-semibold text-gray-700 uppercase text-sm">Mới ứng tuyển</h3>
            <span class="bg-blue-100 text-blue-800 text-xs px-2.5 py-1 rounded-full font-bold shadow-sm">@Model.Count</span>
        </div>
        
        <div id="status-new" class="kanban-col flex-1 min-h-[400px] p-3 space-y-3" data-status="New">
            
            @if (Model != null && Model.Any())
            {
                foreach (var cv in Model)
                {
                    <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 cursor-grab hover:shadow-md hover:border-green-400 transition group" data-id="@cv.ApplicationId">
                        
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-lg flex-shrink-0">
                                @cv.CandidateName.Substring(0, 1)
                            </div>
                            
                            <div class="overflow-hidden">
                                <h4 class="font-bold text-gray-800 text-base group-hover:text-green-600 transition truncate">@cv.CandidateName</h4>
                                <p class="text-xs text-gray-500 truncate mt-0.5"><i class="fa-solid fa-envelope mr-1"></i>@cv.Email</p>
                            </div>
                        </div>

                        <div class="flex justify-between items-center mb-3 text-xs">
                            <span class="@cv.StatusColor border px-2 py-0.5 rounded-full font-medium">@cv.Status</span>
                            <span class="text-gray-500"><i class="fa-regular fa-clock mr-1"></i>@cv.AppliedDate.ToString("dd/MM/yyyy")</span>
                        </div>

                        <div class="flex justify-end border-t border-gray-100 pt-3">
                            <a href="/Business/ReviewCV?id=@cv.ApplicationId" target="_blank" class="text-xs bg-gray-50 border border-gray-200 text-gray-700 hover:bg-green-500 hover:text-white hover:border-green-500 px-3 py-1.5 rounded-md font-medium transition">
                                Xem & Duyệt
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-10 text-gray-400 text-sm">
                    Chưa có ứng viên.
                </div>
            }

        </div>
    </div>

    <div class="flex-shrink-0 w-80 bg-gray-50 border border-gray-200 rounded-xl shadow-sm flex flex-col opacity-90">
        <div class="p-4 border-b border-gray-200 bg-yellow-50 rounded-t-xl flex justify-between items-center">
            <h3 class="font-semibold text-yellow-700 uppercase text-sm">Đang xem xét</h3>
            <span class="bg-yellow-200 text-yellow-800 text-xs px-2.5 py-1 rounded-full font-bold shadow-sm">0</span>
        </div>
        <div id="status-reviewing" class="kanban-col flex-1 min-h-[400px] p-3 space-y-3" data-status="Reviewing">
            </div>
    </div>

    <div class="flex-shrink-0 w-80 bg-gray-50 border border-gray-200 rounded-xl shadow-sm flex flex-col opacity-90">
        <div class="p-4 border-b border-gray-200 bg-purple-50 rounded-t-xl flex justify-between items-center">
            <h3 class="font-semibold text-purple-700 uppercase text-sm">Phỏng vấn</h3>
            <span class="bg-purple-200 text-purple-800 text-xs px-2.5 py-1 rounded-full font-bold shadow-sm">0</span>
        </div>
        <div id="status-interview" class="kanban-col flex-1 min-h-[400px] p-3 space-y-3" data-status="Interview">
            </div>
    </div>

    <div class="flex-shrink-0 w-80 bg-gray-50 border border-gray-200 rounded-xl shadow-sm flex flex-col opacity-90">
        <div class="p-4 border-b border-gray-200 bg-red-50 rounded-t-xl flex justify-between items-center">
            <h3 class="font-semibold text-red-700 uppercase text-sm">Từ chối</h3>
            <span class="bg-red-200 text-red-800 text-xs px-2.5 py-1 rounded-full font-bold shadow-sm">0</span>
        </div>
        <div id="status-rejected" class="kanban-col flex-1 min-h-[400px] p-3 space-y-3" data-status="Rejected">
            </div>
    </div>

</div>

<style>
    .overflow-x-auto::-webkit-scrollbar { height: 8px; }
    .overflow-x-auto::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
    .overflow-x-auto::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    .overflow-x-auto::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    .kanban-col { outline: none !important; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const columns = document.querySelectorAll('.kanban-col');
        
        columns.forEach(col => {
            new Sortable(col, {
                group: 'shared', // Cho phép kéo qua lại giữa các cột
                animation: 150,
                ghostClass: 'opacity-50',
                dragClass: 'shadow-2xl',
                
                onEnd: function (evt) {
                    const itemEl = evt.item;
                    const toColumn = evt.to;
                    const fromColumn = evt.from;
                    
                    if (toColumn === fromColumn) return;

                    const applicationId = itemEl.getAttribute('data-id');
                    const newStatus = toColumn.getAttribute('data-status');

                    // Ở Phase tiếp theo, chúng ta sẽ dùng Ajax (fetch API) để gửi applicationId và newStatus này xuống Controller C#
                    console.log(`Đã kéo Application ID: ${applicationId} sang cột: ${newStatus}`);
                    
                    // Code tự động cập nhật số lượng trên tiêu đề cột (UI)
                    updateColumnCount(fromColumn);
                    updateColumnCount(toColumn);
                },
            });
        });

        function updateColumnCount(colElement) {
            const count = colElement.children.length;
            // Tìm thẻ span chứa số lượng nằm trong header ngay trên cột đó
            const headerSpan = colElement.parentElement.querySelector('.p-4 span');
            if (headerSpan) {
                headerSpan.textContent = count;
            }
        }
    });
</script>