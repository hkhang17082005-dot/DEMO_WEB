@{
    ViewData["Title"] = "Tổng quan Doanh nghiệp";
}

<div class="bg-white border-b shadow-sm mb-6">
    <div class="container mx-auto px-4 flex gap-8">
        <a href="/Business/Index" class="py-4 font-bold border-b-2 border-blue-600 text-blue-600">Tổng quan</a>
        <a href="/Business/MyJobs" class="py-4 font-semibold text-gray-500 hover:text-blue-600 transition">Quản lý tin tuyển dụng</a>
        <a href="/Business/Profile" class="py-4 font-semibold text-gray-500 hover:text-blue-600 transition">Hồ sơ công ty</a>
    </div>
</div>

<main class="container mx-auto px-4 pb-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-800">
                Xin chào, <span id="companyName" class="text-blue-600 animate-pulse">Đang tải...</span> 👋
            </h1>
            <p class="text-gray-500 mt-2">Theo dõi và quản lý hiệu quả tuyển dụng của bạn tại đây.</p>
        </div>
        <a href="/Business/PostJob" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg shadow font-semibold transition flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Đăng tin mới ngay
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="p-6 bg-white shadow-sm hover:shadow-md transition rounded-xl border border-gray-100 flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-500 font-medium uppercase tracking-wide">Tin đang tuyển</p>
                <h2 class="text-3xl font-bold text-gray-800 mt-2" id="totalJobsCount">0</h2>
            </div>
            <div class="p-4 bg-blue-50 text-blue-600 rounded-full">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
        </div>
        
        <div class="p-6 bg-white shadow-sm hover:shadow-md transition rounded-xl border border-gray-100 flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-500 font-medium uppercase tracking-wide">Hồ sơ ứng viên mới</p>
                <h2 class="text-3xl font-bold text-gray-800 mt-2" id="totalApplicationsCount">0</h2>
            </div>
            <div class="p-4 bg-emerald-50 text-emerald-600 rounded-full">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script src="~/js/business.js"></script>
}