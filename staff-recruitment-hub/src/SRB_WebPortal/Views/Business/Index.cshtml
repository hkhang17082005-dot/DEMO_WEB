@{
   ViewData["Title"] = "Bảng tin tổng quan";
   Layout = "~/Views/Shared/_BusinessLayout.cshtml";
}

<div class="flex justify-between items-center mb-8">
   <div>
      <h1 class="text-2xl font-bold text-gray-800">Chào buổi sáng, HR!</h1>
      <p class="text-gray-500 mt-1">Dưới đây là hiệu quả tuyển dụng của bạn trong 30 ngày qua.</p>
   </div>
   <a href="/Business/PostJob"
      class="bg-green-600 hover:bg-green-700 text-white px-6 py-2.5 rounded-lg font-semibold shadow-md shadow-green-200 transition flex items-center gap-2">
      <i class="fa-solid fa-pen-to-square"></i> Đăng tin mới
   </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
   <div
      class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative overflow-hidden group hover:shadow-md transition">
      <div
         class="absolute -right-4 -top-4 w-20 h-20 bg-blue-50 rounded-full opacity-50 group-hover:scale-110 transition duration-300">
      </div>
      <p class="text-sm font-semibold text-gray-500 mb-1">Tin đang hiển thị</p>
      <h3 class="text-3xl font-bold text-gray-800">@ViewBag.ActivePosts</h3>
      <div class="mt-4 text-sm text-blue-600 font-medium flex items-center gap-1">
         <span>Chi tiết</span> <i class="fa-solid fa-arrow-right text-xs"></i>
      </div>
   </div>

   <div
      class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative overflow-hidden group hover:shadow-md transition">
      <div
         class="absolute -right-4 -top-4 w-20 h-20 bg-green-50 rounded-full opacity-50 group-hover:scale-110 transition duration-300">
      </div>
      <p class="text-sm font-semibold text-gray-500 mb-1">CV tiếp nhận mới</p>
      <h3 class="text-3xl font-bold text-gray-800">@ViewBag.NewCVs</h3>
   </div>

   <div
      class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative overflow-hidden group hover:shadow-md transition">
      <div
         class="absolute -right-4 -top-4 w-20 h-20 bg-orange-50 rounded-full opacity-50 group-hover:scale-110 transition duration-300">
      </div>
      <p class="text-sm font-semibold text-gray-500 mb-1">Sắp lịch phỏng vấn</p>
      <h3 class="text-3xl font-bold text-gray-800">@ViewBag.Interviews</h3>
   </div>

   <div
      class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative overflow-hidden group hover:shadow-md transition">
      <div
         class="absolute -right-4 -top-4 w-20 h-20 bg-red-50 rounded-full opacity-50 group-hover:scale-110 transition duration-300">
      </div>
      <p class="text-sm font-semibold text-gray-500 mb-1">Dịch vụ đang dùng</p>
      <h3 class="text-xl font-bold text-gray-800 mt-2">Gói Cơ Bản</h3>
      <a href="#" class="mt-4 inline-block text-sm text-red-600 font-medium hover:underline">Nâng cấp ngay</a>
   </div>
</div>
