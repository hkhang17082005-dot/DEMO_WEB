@{
    // Không dùng Layout chung để có không gian full-màn hình
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title>Duyệt CV: Nguyễn Văn A</title>
    <link rel="stylesheet" href="~/css/output.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>

<body class="bg-gray-800 h-screen overflow-hidden flex font-sans">

    <div class="w-8/12 h-full relative flex flex-col">
        <div class="h-14 bg-gray-900 text-white flex items-center justify-between px-6 border-b border-gray-700 z-10">
            <div class="flex items-center gap-4">
                <button onclick="window.close()" class="text-gray-400 hover:text-white" title="Đóng tab"><i
                    class="fa-solid fa-xmark text-xl"></i></button>
                    <span class="font-medium">CV_NguyenVanA_Backend.pdf</span>
                </div>
                <div class="flex gap-4 text-gray-400">
                    <button class="hover:text-white"><i class="fa-solid fa-download"></i></button>
                    <button class="hover:text-white"><i class="fa-solid fa-print"></i></button>
                </div>
            </div>
        
            <div class="flex-1 overflow-y-auto p-8 flex justify-center custom-scrollbar">
                <img src="~/images/cv1.jpg" alt="CV Document"
                     class="max-w-3xl w-full h-auto shadow-2xl rounded-sm object-contain" />
            </div>
        </div>

        <div class="w-4/12 h-full bg-white flex flex-col shadow-[-10px_0_15px_rgba(0,0,0,0.1)] z-20">
        
            <div class="flex border-b border-gray-200">
                <button
                    class="flex-1 py-4 text-center border-b-2 border-green-600 text-green-600 font-bold bg-green-50/30">Đánh
                    giá CV</button>
                    <button class="flex-1 py-4 text-center text-gray-500 font-medium hover:bg-gray-50">Lịch sử</button>
                </div>

                <div class="flex-1 overflow-y-auto p-6">
                    <div class="text-center mb-6">
                        <div
                            class="w-20 h-20 mx-auto rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-3xl mb-3 shadow-inner">
                            NV</div>
                            <h2 class="text-2xl font-bold text-gray-800">Nguyễn Văn A</h2>
                            <p class="text-gray-500 font-medium mt-1">C#.NET Backend Developer</p>
                        </div>

                        <div class="bg-gray-50 rounded-lg p-4 mb-6 text-sm text-gray-700 space-y-3 border border-gray-100">
                            <p class="flex items-center gap-3"><i class="fa-solid fa-envelope text-gray-400 w-4"></i> nva@gmail.com
                            </p>
                            <p class="flex items-center gap-3"><i class="fa-solid fa-phone text-gray-400 w-4"></i> 0987.654.321</p>
                            <p class="flex items-center gap-3"><i class="fa-solid fa-sack-dollar text-gray-400 w-4"></i> Mức lương:
                                Lên đến 25tr</p>
                            </div>

                            <div class="mb-6 flex justify-between items-center">
                                <span class="text-sm font-semibold text-gray-600">Trạng thái hiện tại:</span>
                                <span id="cv-status"
                                      class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded text-xs font-bold uppercase tracking-wider">Mới
                                    tiếp nhận</span>
                                </div>

                                <div class="space-y-3 border-t border-gray-100 pt-6">
                                    <button onclick="changeStatus('Đang phỏng vấn', 'bg-blue-100 text-blue-800')"
                                            class="w-full bg-green-600 hover:bg-green-700 text-white py-3 rounded-lg font-bold shadow-md shadow-green-200 transition">
                                        <i class="fa-solid fa-check mr-2"></i> Phù hợp - Hẹn phỏng vấn
                                    </button>
                
                                    <button onclick="changeStatus('Đưa vào KIV', 'bg-gray-200 text-gray-800')"
                                            class="w-full bg-white border-2 border-gray-200 text-gray-700 hover:bg-gray-50 py-3 rounded-lg font-bold transition">
                                        <i class="fa-regular fa-folder-open mr-2"></i> Lưu vào danh sách chờ (KIV)
                                    </button>

                                    <button onclick="openRejectModal()"
                                            class="w-full bg-white border-2 border-red-100 text-red-500 hover:bg-red-50 hover:border-red-500 py-3 rounded-lg font-bold transition mt-6">
                                        <i class="fa-solid fa-ban mr-2"></i> Từ chối hồ sơ
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div id="rejectModal"
                             class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center z-50">
                            <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden transform scale-100">
                                <div class="bg-red-50 px-6 py-4 border-b border-red-100 flex justify-between items-center">
                                    <h3 class="font-bold text-lg text-red-600">Từ chối ứng viên này?</h3>
                                    <button onclick="closeRejectModal()" class="text-gray-400 hover:text-gray-800"><i
                                        class="fa-solid fa-xmark text-lg"></i></button>
                                    </div>
                                    <div class="p-6">
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Lý do từ chối (Ghi chú nội bộ cho
                                            HR)</label>
                                            <textarea id="txtRejectReason" rows="3"
                                                      class="w-full border border-gray-300 rounded-lg p-3 text-sm focus:ring-2 focus:ring-red-500 outline-none"
                                                      placeholder="VD: Chưa đủ năm kinh nghiệm..."></textarea>
                
                                            <label class="flex items-center gap-2 mt-4 cursor-pointer">
                                                <input type="checkbox" checked
                                                       class="rounded text-red-600 focus:ring-red-500 w-4 h-4 border-gray-300">
                                                <span class="text-sm text-gray-600">Gửi Thư cảm ơn (Email từ chối) tự động</span>
                                            </label>
                                        </div>
                                        <div class="bg-gray-50 px-6 py-4 flex justify-end gap-3 border-t border-gray-100">
                                            <button onclick="closeRejectModal()"
                                                    class="px-5 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50">Hủy</button>
                                            <button onclick="confirmReject()"
                                                    class="px-5 py-2 bg-red-600 text-white rounded-lg font-bold hover:bg-red-700 shadow-md">Xác nhận Từ
                                                chối</button>
                                            </div>
                                        </div>
                                    </div>

                                    <script src="~/lib/jquery/dist/jquery.min.js"></script>
                                    <script>
                                            function changeStatus(text, classes) {
                                                $('#cv-status').removeClass().addClass(`px-3 py-1 rounded text-xs font-bold uppercase tracking-wider ${classes}`).text(text);
                                            }
                                            function openRejectModal() { $('#rejectModal').removeClass('hidden'); $('#txtRejectReason').val(''); }
                                            function closeRejectModal() { $('#rejectModal').addClass('hidden'); }
                                            function confirmReject() {
                                                if (!$('#txtRejectReason').val().trim()) { alert('Vui lòng nhập lý do!'); return; }
                                                closeRejectModal();
                                                changeStatus('Đã từ chối', 'bg-red-100 text-red-800');
                                            }
                                    </script>
                                </body>

                            </html>