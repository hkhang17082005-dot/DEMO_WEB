@model SRB_WebPortal.Data.JobMock.MockApplication
@{
    ViewData["Title"] = "Duyệt hồ sơ: " + Model.CandidateName;
    Layout = "~/Views/Shared/_BusinessLayout.cshtml";
}

<div class="h-screen flex flex-col bg-gray-50">
    <div class="bg-white border-b border-gray-200 p-4 flex items-center justify-between shadow-sm">
        <div class="flex items-center gap-4">
            <a href="javascript:history.back()"
                   class="text-gray-500 hover:text-green-600 p-2 rounded-full hover:bg-gray-100 transition">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <h2 class="text-xl font-bold text-gray-800">Hồ sơ: @Model.CandidateName</h2>
        </div>
        <div class="flex gap-2">
            <span class="@Model.StatusColor border px-3 py-1 rounded-full text-xs font-bold">
                @Model.Status
            </span>
        </div>
    </div>

    <div class="flex flex-1 overflow-hidden">
        
        <div class="w-1/2 h-full overflow-y-auto p-6">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
                <div class="flex items-center gap-6 mb-8 pb-8 border-b border-gray-100">
                    <div
                        class="w-20 h-20 rounded-2xl bg-green-600 text-white flex items-center justify-center font-bold text-4xl shadow-lg">
                        @Model.CandidateName.Substring(0, 1)
                    </div>
                    <div>
                        <h3 class="text-3xl font-black text-gray-900">@Model.CandidateName</h3>
                        <p class="text-gray-500 font-medium">@Model.Email</p>
                    </div>
                </div>

                <div class="space-y-6">
                    <h4 class="font-bold text-gray-800 uppercase text-sm tracking-wider">Thông tin tóm tắt</h4>
                    <div class="grid grid-cols-2 gap-6">
                        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
                            <p class="text-xs text-gray-400 uppercase font-bold">Ngày ứng tuyển</p>
                            <p class="font-semibold text-gray-700 mt-1">@Model.AppliedDate.ToString("dd/MM/yyyy HH:mm")
                            </p>
                        </div>
                        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
                            <p class="text-xs text-gray-400 uppercase font-bold">Mã ứng viên</p>
                            <p class="font-semibold text-gray-700 mt-1">#@Model.ApplicationId</p>
                        </div>
                    </div>

                    <div class="pt-4">
                        <h4 class="font-bold text-gray-800 mb-3">Kỹ năng chuyên môn</h4>
                        <div class="flex flex-wrap gap-2">
                            <span
                                class="px-3 py-1 bg-blue-50 text-blue-600 rounded-md text-sm font-medium border border-blue-100">ASP.NET
                                Core</span>
                                <span
                                    class="px-3 py-1 bg-blue-50 text-blue-600 rounded-md text-sm font-medium border border-blue-100">C#
                                    Entity Framework</span>
                                    <span
                                        class="px-3 py-1 bg-blue-50 text-blue-600 rounded-md text-sm font-medium border border-blue-100">Tailwind
                                        CSS</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="w-1/2 h-full bg-white border-l border-gray-200 overflow-y-auto p-8">
                        <div class="max-w-md mx-auto space-y-10">
                
                            <section>
                                <h4 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                                    <i class="fa-solid fa-star text-yellow-500"></i> Đánh giá năng lực
                                </h4>
                                <div class="flex gap-2 text-3xl text-gray-200">
                                    <i class="fa-solid fa-star cursor-pointer hover:text-yellow-400 transition"></i>
                                    <i class="fa-solid fa-star cursor-pointer hover:text-yellow-400 transition"></i>
                                    <i class="fa-solid fa-star cursor-pointer hover:text-yellow-400 transition"></i>
                                    <i class="fa-solid fa-star cursor-pointer text-gray-200"></i>
                                    <i class="fa-solid fa-star cursor-pointer text-gray-200"></i>
                                </div>
                            </section>

                            <section>
                                <h4 class="text-lg font-bold text-gray-800 mb-4">Ghi chú nội bộ</h4>
                                <textarea
                                class="w-full h-40 p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-green-500 outline-none transition"
                                placeholder="Nhận xét ưu/nhược điểm của ứng viên..."></textarea>
                            </section>

                            <section>
                                <h4 class="text-lg font-bold text-gray-800 mb-4">Quyết định</h4>
                                <div class="grid grid-cols-1 gap-3">
                                    <button
                                        class="w-full py-3 bg-purple-600 text-white rounded-xl font-bold hover:bg-purple-700 transition">Hẹn
                                        phỏng vấn</button>
                                        <div class="grid grid-cols-2 gap-3">
                                            <button
                                                class="py-3 border border-red-200 text-red-600 rounded-xl font-bold hover:bg-red-50 transition">Từ
                                                chối</button>
                                                <button
                                                    class="py-3 bg-green-600 text-white rounded-xl font-bold hover:bg-green-700 transition">Gửi
                                                    Offer</button>
                                                </div>
                                            </div>
                                        </section>

                                    </div>
                                </div>
                            </div>
                        </div>