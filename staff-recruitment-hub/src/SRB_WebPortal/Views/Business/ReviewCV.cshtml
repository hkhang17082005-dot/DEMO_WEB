@using SRB_WebPortal.Controllers.apis.business
@model CVReviewDetailDTO
@{
   Layout = "~/Views/Shared/_LayoutCVReview.cshtml";

   ViewData["Title"] = $"Duyệt CV - {Model.FullName}";
}

@await Html.PartialAsync("~/Views/Business/Components/ReviewCV/_PdfViewer.cshtml", Model)

<div class="w-1/5 h-full bg-white flex flex-col shadow-2xl z-20">
   <div class="flex border-b border-gray-200">
      <button id="tab-review" class="tab-btn flex-1 py-5 border-b-2 border-green-500 text-green-600">
         Đánh giá CV
      </button>
      <button id="tab-history" class="tab-btn flex-1 py-5 text-gray-500">
         Lịch sử
      </button>
   </div>

   <div id="review-content">
      @await Html.PartialAsync("~/Views/Business/Components/ReviewCV/_CandidateInfo.cshtml", Model)
      @await Html.PartialAsync("~/Views/Business/Components/ReviewCV/_ActionButtons.cshtml", Model)
   </div>

   <div id="history-content" class="hidden">
      @await Html.PartialAsync("~/Views/Business/Components/ReviewCV/_HistoryTab.cshtml", Model)
   </div>
</div>

@await Html.PartialAsync("~/Views/Business/Components/ReviewCV/_KIVModal.cshtml")
@await Html.PartialAsync("~/Views/Business/Components/ReviewCV/_RejectModal.cshtml")

@section Scripts {
   <script src="~/Views/Business/Components/ReviewCV/cv-review.js"></script>
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
   const applicationId = '@Model.ApplicationID';
   const userId = '@Model.UserID';

   // Tab switching
   $('#tab-review').click(function () {
   $('#tab-review').addClass('border-green-500 text-green-600 bg-green-50/30')
   .removeClass('border-transparent text-gray-500 bg-transparent');
   $('#tab-history').removeClass('border-green-500 text-green-600 bg-green-50/30')
   .addClass('border-transparent text-gray-500 bg-transparent');
   $('#review-content').removeClass('hidden');
   $('#history-content').addClass('hidden');
   });

   $('#tab-history').click(function () {
   $('#tab-history').addClass('border-green-500 text-green-600 bg-green-50/30')
   .removeClass('border-transparent text-gray-500 bg-transparent');
   $('#tab-review').removeClass('border-green-500 text-green-600 bg-green-50/30')
   .addClass('border-transparent text-gray-500 bg-transparent');
   $('#history-content').removeClass('hidden');
   $('#review-content').addClass('hidden');
   loadHistory();
   });

   if (result.isConfirmed) {
   showLoading();

   try {
   const response = await $.ajax({
   url: `/api/JobApplications/${applicationId}/status`,
   type: 'PUT',
   contentType: 'application/json',
   data: JSON.stringify({
   status: statusCode,
   notes: ''
   })
   });

   if (response.success) {
   updateStatusUI(statusText, colorClass);
   await Swal.fire('Thành công!', `Đã chuyển trạng thái thành "${statusText}"`, 'success');
   addToHistory(statusText);
   } else {
   throw new Error(response.message || 'Có lỗi xảy ra');
   }
   } catch (error) {
   Swal.fire('Lỗi!', error.message || 'Không thể cập nhật trạng thái', 'error');
   }

   hideLoading();
   }
   }

   // KIV functions
   function openKIVModal() {
   $('#kivModal').removeClass('hidden');
   $('#txtKIVReason').val('');
   }

   function closeKIVModal() {
   $('#kivModal').addClass('hidden');
   }

   async function confirmKIV() {
   const reason = $('#txtKIVReason').val().trim();

   const result = await Swal.fire({
   title: 'Xác nhận?',
   text: 'Bạn có chắc chắn muốn lưu hồ sơ này vào danh sách chờ?',
   icon: 'question',
   showCancelButton: true,
   confirmButtonColor: '#f59e0b',
   cancelButtonColor: '#6b7280',
   confirmButtonText: 'Đồng ý',
   cancelButtonText: 'Hủy'
   });

   if (result.isConfirmed) {
   showLoading();

   try {
   const response = await $.ajax({
   url: `/api/JobApplications/${applicationId}/status`,
   type: 'PUT',
   contentType: 'application/json',
   data: JSON.stringify({
   status: 'KIV',
   notes: reason
   })
   });

   if (response.success) {
   updateStatusUI('Đưa vào KIV', 'bg-yellow-400');
   closeKIVModal();
   await Swal.fire('Thành công!', 'Đã lưu vào danh sách chờ', 'success');
   addToHistory('Đưa vào KIV', reason);
   } else {
   throw new Error(response.message || 'Có lỗi xảy ra');
   }
   } catch (error) {
   Swal.fire('Lỗi!', error.message || 'Không thể cập nhật trạng thái', 'error');
   }

   hideLoading();
   }
   }

   // Reject functions
   function openRejectModal() {
   $('#rejectModal').removeClass('hidden');
   $('#txtRejectReason').val('');
   }

   function closeRejectModal() {
   $('#rejectModal').addClass('hidden');
   }

   async function confirmReject() {
   const reason = $('#txtRejectReason').val().trim();
   const sendEmail = $('#sendEmailReject').is(':checked');

   if (!reason) {
   Swal.fire('Lỗi!', 'Vui lòng nhập lý do từ chối', 'error');
   return;
   }

   const result = await Swal.fire({
   title: 'Xác nhận từ chối?',
   text: 'Bạn có chắc chắn muốn từ chối hồ sơ này?',
   icon: 'warning',
   showCancelButton: true,
   confirmButtonColor: '#ef4444',
   cancelButtonColor: '#6b7280',
   confirmButtonText: 'Đồng ý',
   cancelButtonText: 'Hủy'
   });

   if (result.isConfirmed) {
   showLoading();

   try {
   const response = await $.ajax({
   url: `/api/JobApplications/${applicationId}/reject`,
   type: 'POST',
   contentType: 'application/json',
   data: JSON.stringify({
   reason: reason,
   sendEmail: sendEmail
   })
   });

   if (response.success) {
   updateStatusUI('Đã từ chối', 'bg-red-500');
   closeRejectModal();
   await Swal.fire('Thành công!', 'Đã từ chối hồ sơ', 'success');
   addToHistory('Đã từ chối', reason);
   } else {
   throw new Error(response.message || 'Có lỗi xảy ra');
   }
   } catch (error) {
   Swal.fire('Lỗi!', error.message || 'Không thể từ chối hồ sơ', 'error');
   }

   hideLoading();
   }
   }

   // Helper functions
   function updateStatusUI(statusText, colorClass) {
   const statusSpan = $('#cv-status');
   statusSpan.removeClass().addClass(`status-badge px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider ${colorClass}`);
   statusSpan.text(statusText);
   }

   function showLoading() {
   Swal.fire({
   title: 'Đang xử lý...',
   allowOutsideClick: false,
   didOpen: () => {
   Swal.showLoading();
   }
   });
   }

   function hideLoading() {
   Swal.close();
   }

   async function loadHistory() {
   try {
   const response = await $.ajax({
   url: `/api/JobApplications/${applicationId}/history`,
   type: 'GET'
   });

   if (response.success && response.data) {
   let html = '';
   response.data.forEach(item => {
   html += `
   <div class="flex items-start gap-3">
   <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center flex-shrink-0">
   <i class="fa-regular fa-history text-purple-600"></i>
   </div>
   <div class="flex-1">
   <p class="font-medium text-gray-800">${item.status}</p>
   <p class="text-sm text-gray-500">${item.notes || 'Không có ghi chú'}</p>
   <p class="text-xs text-gray-400 mt-1">${new Date(item.createdAt).toLocaleString('vi-VN')}</p>
   </div>
   </div>
   `;
   });
   $('#history-timeline').html(html);
   }
   } catch (error) {
   console.error('Error loading history:', error);
   }
   }

   function addToHistory(status, notes = '') {
   const html = `
   <div class="flex items-start gap-3">
   <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center flex-shrink-0">
   <i class="fa-regular fa-history text-purple-600"></i>
   </div>
   <div class="flex-1">
   <p class="font-medium text-gray-800">${status}</p>
   <p class="text-sm text-gray-500">${notes || 'Không có ghi chú'}</p>
   <p class="text-xs text-gray-400 mt-1">${new Date().toLocaleString('vi-VN')}</p>
   </div>
   </div>
   `;
   $('#history-timeline').prepend(html);
   }

   function shareCV() {
   const url = window.location.href;
   navigator.clipboard.writeText(url).then(() => {
   Swal.fire('Thành công!', 'Đã sao chép link chia sẻ', 'success');
   });
   }

   // Close modals when clicking outside
   $(window).click(function (e) {
   if ($(e.target).is('#kivModal')) {
   closeKIVModal();
   }
   if ($(e.target).is('#rejectModal')) {
   closeRejectModal();
   }
   });
</script>

</html>

@functions {
   public string GetStatusText(string status)
   {
      return status switch
      {
         "Pending" => "Chờ xét duyệt",
         "Interviewing" => "Đang phỏng vấn",
         "KIV" => "Trong danh sách chờ",
         "Rejected" => "Đã từ chối",
         "Hired" => "Đã nhận việc",
         _ => "Không xác định"
      };
   }
}
