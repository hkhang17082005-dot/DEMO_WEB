@using SRB_ViewModel.Entities
@using SRB_WebPortal.Controllers.apis.business
@model CVReviewDetailDTO

<div class="space-y-4 px-4">
   <button onclick="changeStatus(@((int)ApplicationStatus.Interviewing))"
           class="group w-full bg-emerald-500 hover:bg-emerald-600 text-white py-4 rounded-2xl font-bold shadow-lg shadow-emerald-100 transition-all duration-300 flex items-center justify-center gap-3 active:scale-[0.98]">
      <div class="bg-white/20 p-1.5 rounded-lg group-hover:scale-110 transition-transform flex items-center justify-center">
         <i class="fa-solid fa-calendar-check text-lg text-white"></i>
      </div>
      <span class="tracking-wide">Phù hợp - Hẹn phỏng vấn</span>
   </button>

   <button onclick="changeStatus(@((int)ApplicationStatus.UnderReview))"
           class="group w-full bg-white border-2 border-amber-200 text-amber-700 hover:bg-amber-50 hover:border-amber-400 py-4 rounded-2xl font-semibold transition-all duration-300 flex items-center justify-center gap-3 shadow-sm hover:shadow-md active:scale-[0.98]">
      <i class="fa-solid fa-clock-rotate-left text-lg text-amber-500 group-hover:rotate-[-30deg] transition-transform"></i>
      <span>Lưu vào danh sách chờ</span>
   </button>

   <button onclick="changeStatus(@((int)ApplicationStatus.Rejected))"
           class="group w-full bg-slate-50 border border-transparent text-slate-500 hover:bg-red-50 hover:text-red-600 hover:border-red-200 py-4 rounded-2xl font-medium transition-all duration-300 flex items-center justify-center gap-3 active:scale-[0.98]">
      <i class="fa-regular fa-circle-xmark text-lg"></i>
      <span>Từ chối hồ sơ</span>
   </button>
</div>

<style>
   .group:hover .fa-circle-xmark {
      animation: shake 0.5s ease-in-out infinite;
   }

   @@keyframes shake {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(-10deg); }
      75% { transform: rotate(10deg); }
   }
</style>

<script type="module">
   import businessService from '/js/services/businessService.js';

   window.changeStatus = async function(statusValue) {
      const formData = {
         applicationID: "@Model.ApplicationID",
         status: statusValue
      };

      try {
         const response = await businessService.updateStatusApplyJob(formData);

         if (response.isSuccess) {
            alert("Cập nhật trạng thái thành công!");
         } else {
            alert("Cập nhật trạng thái thất bại!");
         }
         location.reload();
      } catch (error) {
         console.error("Lỗi khi cập nhật trạng thái:", error);
         alert("Có lỗi xảy ra, vui lòng thử lại.");
      }
   }
</script>
