@using SRB_WebPortal.Controllers.apis.business
@model CVReviewDetailDTO

<div class="text-center mb-6">
   <div class="relative inline-block">
      <div
         class="w-24 h-24 mx-auto rounded-full bg-linear-to-br from-green-400 to-emerald-500 text-white flex items-center justify-center font-bold text-3xl mb-3 shadow-lg">
         @(Model.FullName?.Split(' ').LastOrDefault()?.FirstOrDefault().ToString().ToUpper() ?? "CV")
      </div>
   </div>
   <h2 class="text-2xl font-bold text-gray-800 mt-2">@Model.FullName</h2>
   <p class="text-gray-500 font-medium mt-1">@Model.JobTitle</p>
   <div class="flex items-center justify-center gap-2 mt-2">
      <span class="text-xs text-gray-400">
         <i class="fa-regular fa-calendar-alt mr-1"></i>
         Ứng tuyển: @Model.AppliedAt.ToString("dd/MM/yyyy")
      </span>
   </div>
</div>

<div class="bg-linear-to-r from-gray-50 to-gray-100 rounded-xl p-5 mb-6 border border-gray-200">
   <h3 class="text-sm font-semibold text-gray-600 mb-3 uppercase tracking-wide">
      <i class="fa-regular fa-address-card mr-2 text-green-600"></i> Thông tin liên hệ
   </h3>
   <div class="space-y-3 text-sm">
      <div class="flex items-center gap-3">
         <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center shadow-sm">
            <i class="fa-regular fa-envelope text-gray-500"></i>
         </div>
         <div>
            <p class="text-xs text-gray-400">Email</p>
            <p class="text-gray-700 font-medium">@Model.Email</p>
         </div>
      </div>
      <div class="flex items-center gap-3">
         <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center shadow-sm">
            <i class="fa-solid fa-mobile-screen-button"></i>
         </div>
         <div>
            <p class="text-xs text-gray-400">Số điện thoại</p>
            <p class="text-gray-700 font-medium">@Model.Phone</p>
         </div>
      </div>
   </div>
</div>

<div class="mb-6 flex justify-between items-center p-4 bg-gray-50 rounded-xl">
   <span class="text-sm font-semibold text-gray-600">Trạng thái hiện tại:</span>
   <span id="cv-status" class="status-badge px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider">
      @Model.StatusName
   </span>
</div>
