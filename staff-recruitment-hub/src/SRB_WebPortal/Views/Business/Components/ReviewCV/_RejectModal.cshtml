<div id="rejectModal" class="fixed inset-0 bg-gray-900/50 modal-overlay flex items-center justify-center z-50 hidden">
   <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden modal-content">
      <div class="bg-linear-to-r from-red-500 to-pink-500 px-6 py-4 flex justify-between items-center">
         <h3 class="font-bold text-lg text-white">
            <i class="fa-regular fa-times-circle mr-2"></i> Từ chối hồ sơ
         </h3>
         <button onclick="closeRejectModal()" class="text-white/80 hover:text-white">
            <i class="fa-solid fa-xmark text-2xl"></i>
         </button>
      </div>
      <div class="p-6">
         <label class="block text-sm font-medium text-gray-700 mb-2">Lý do từ chối</label>
         <textarea id="txtRejectReason" rows="3"
                   class="w-full border border-gray-300 rounded-xl p-3 text-sm focus:ring-2 focus:ring-red-400 focus:border-transparent outline-none transition"
                   placeholder="VD: Chưa đủ kinh nghiệm yêu cầu..."></textarea>

         <label class="flex items-center gap-3 mt-4 cursor-pointer p-3 bg-gray-50 rounded-xl">
            <input type="checkbox" id="sendEmailReject" checked class="rounded text-red-500 focus:ring-red-400 w-4 h-4">
            <span class="text-sm text-gray-700">
               <i class="fa-regular fa-envelope mr-1"></i> Gửi email thông báo từ chối
            </span>
         </label>
      </div>
      <div class="bg-gray-50 px-6 py-4 flex justify-end gap-3">
         <button onclick="closeRejectModal()"
                 class="px-5 py-2 bg-white border border-gray-300 rounded-xl text-gray-700 font-medium hover:bg-gray-50 transition">
            Hủy
         </button>
         <button onclick="confirmReject()"
                 class="px-5 py-2 bg-linear-to-r from-red-500 to-pink-500 text-white rounded-xl font-semibold hover:shadow-lg transition">
            Xác nhận từ chối
         </button>
      </div>
   </div>
</div>
