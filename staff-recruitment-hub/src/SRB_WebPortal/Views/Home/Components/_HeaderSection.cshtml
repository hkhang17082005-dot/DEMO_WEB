<div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
   <div>
      <div
         class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-100 text-green-700 text-xs font-bold uppercase tracking-wider mb-3">
         <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
         </span>
         Hot Opportunities
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">
         Việc làm <span class="text-transparent bg-clip-text bg-linear-to-r from-green-600 to-emerald-500">tốt
         nhất</span>
      </h2>
      <p class="mt-2 text-gray-500 text-sm md:text-base">Khám phá những cơ hội nghề nghiệp hàng đầu dành cho bạn.</p>
   </div>

   <div class="flex items-center gap-4 bg-white p-2 rounded-2xl shadow-sm border border-gray-100">
      <span class="pl-3 text-sm font-semibold text-gray-400 flex items-center gap-2">
         <i class="fa-solid fa-filter text-xs"></i> Lọc theo:
      </span>
      <div class="relative flex items-center bg-gray-100 rounded-xl px-3 hover:bg-gray-200 transition-all group">
         <i id="filterIcon" class="fa-solid fa-location-dot mr-2 text-green-600 text-sm"></i>

         <select id="filterType" onchange="handleFilterChange(this)"
                 class="appearance-none bg-transparent border-none pl-2 pr-8 py-2.5 text-sm font-bold text-gray-700 focus:ring-0 outline-none cursor-pointer w-full">
            <option value="location">Địa điểm</option>
            <option value="salary">Mức lương</option>
            <option value="category">Ngành nghề</option>
         </select>

         <i
         class="fa-solid fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-[10px] text-gray-400 pointer-events-none group-hover:text-gray-600"></i>
      </div>
   </div>
</div>

<script>
   function handleFilterChange(selectElement) {
      const iconElement = document.getElementById('filterIcon');
      const value = selectElement.value;

      // Thay đổi class icon tương ứng với giá trị
      switch (value) {
         case 'location':
            iconElement.className = 'fa-solid fa-location-dot mr-2 text-green-600 text-sm';
            break;
         case 'salary':
            iconElement.className = 'fa-solid fa-circle-dollar-to-slot mr-2 text-amber-500 text-sm';
            break;
         case 'category':
            iconElement.className = 'fa-solid fa-briefcase mr-2 text-blue-500 text-sm';
            break;
         default:
            iconElement.className = 'fa-solid fa-filter mr-2 text-gray-500 text-sm';
      }

      // Gọi hàm cập nhật tags cũ của bạn
      if (typeof updateFilterTags === "function") {
         updateFilterTags();
      }
   }
</script>
