@model List<SRB_ViewModel.Entities.Job>
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- ================= HERO ================= -->
<section
    class="bg-gradient-to-br from-emerald-800 via-emerald-600 to-emerald-400 py-20 text-white text-center rounded-3xl">
    <div class="max-w-7xl mx-auto px-4 ">

        <h1 class="text-4xl md:text-5xl font-bold mb-6">
            Tìm việc làm nhanh chóng & hiệu quả
        </h1>

        <p class="mb-8 text-emerald-100 text-lg">
            Hơn 40.000+ cơ hội việc làm đang chờ bạn
        </p>

        <!-- Search -->
        <div class="bg-white rounded-full overflow-hidden flex flex-col md:flex-row max-w-4xl mx-auto shadow-lg mb-32">

            <input type="text" id="jobSearch" placeholder="Vị trí tuyển dụng, tên công ty"
                   class="flex-1 px-6 py-4 text-gray-700 outline-none">

            <select id="locationFilter" class="px-4 py-4 text-gray-600 outline-none border-t md:border-t-0 md:border-l">

                <option value="">Địa điểm</option>

                @foreach (var location in ViewBag.Locations)
                {
                    <option value="@location.LocationID">
                        @location.LocationName
                    </option>
                }

            </select>

            <button onclick="searchJobs()"
                    class="bg-emerald-600 hover:bg-emerald-700 px-8 text-white font-semibold transition">
                Tìm kiếm
            </button>

        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
            <div>
                <h3 class="text-3xl font-bold">41.419+</h3>
                <p class="text-emerald-100">Việc làm đang tuyển</p>
            </div>
            <div>
                <h3 class="text-3xl font-bold">1.580+</h3>
                <p class="text-emerald-100">Việc làm mới hôm nay</p>
            </div>
            <div>
                <h3 class="text-3xl font-bold">5000+</h3>
                <p class="text-emerald-100">Doanh nghiệp uy tín</p>
            </div>
        </div>
    </div>
</section>


<!-- ================= JOB LIST ================= -->
<section class="max-w-7xl mx-auto py-16 px-4">

    <h2 class="text-2xl font-bold mb-8">
        🔥 Việc làm nổi bật
    </h2>

    <div id="jobList" class="grid md:grid-cols-3 gap-6">

        @foreach (var job in Model)
        {
            <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">

                <h3 class="font-semibold text-lg mb-2">
                    @job.Title
                </h3>

                <p class="text-gray-500 mb-2">
                    @job.CompanyName
                </p>

                <p class="text-emerald-600 font-semibold mb-3">
                    @job.Salary
                </p>

                <div class="flex gap-6 text-sm text-gray-400">

                    <span class="bg-emerald-100 px-2 py-1 text-xs rounded-full">
                        @job.Location.LocationName
                    </span>

                    <span class="bg-emerald-100 px-2 py-1 text-xs rounded-full">
                        @job.JobType
                    </span>

                </div>

            </div>
        }

    </div>

</section>

@section Scripts {
    <script src="~/js/search.js"></script>
    <script>
            function searchJobs() {
                var keyword = document.getElementById("jobSearch").value;
                var locationId = document.getElementById("locationFilter").value;
                if (keyword === "" && locationId === "") {
                        alert("Vui lòng nhập từ khóa hoặc chọn địa điểm");
                        return;
                    }
                var url = "/FindJobByID/Search?";

                if (keyword) {
                    url += "keyword=" + encodeURIComponent(keyword);
                }

                if (locationId) {
                    if (keyword) {
                    url += "&";
                    }
                    url += "locationId=" + locationId;
                    }
                    window.location.href = url;
                    } 
    </script>

}