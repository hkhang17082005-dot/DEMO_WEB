@{
   ViewData["Title"] = "Trang chủ";

   var savedJobs = ViewBag.SavedJobs as List<int> ?? new List<int>();
}

<style>
   .rounded-modern { border-radius: 1.25rem; }

   .glass-container {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.3);
   }

   .no-scrollbar::-webkit-scrollbar { display: none; }
   .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

   .nav-filter-btn {
      width: 44px; height: 44px;
      border-radius: 50%;
      border: 1px solid #e5e7eb;
      display: flex; align-items: center; justify-content: center;
      color: #10b981; transition: all 0.3s; flex-shrink: 0;
      background: white;
   }
   .nav-filter-btn:hover {
      background: #10b981; color: white;
      border-color: #10b981; box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.4);
   }

   .filter-pill {
      padding: 0.75rem 1.5rem;
      border-radius: 9999px;
      font-weight: 600;
      font-size: 0.875rem;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
   }
   .filter-pill:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 20px -5px rgba(16, 185, 129, 0.2);
   }

   .animate-pulse {
      animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      background: linear-gradient(90deg, #f3f4f6 25%, #e5e7eb 50%, #f3f4f6 75%);
      background-size: 200% 100%;
   }

   .no-scrollbar::-webkit-scrollbar { display: none; }
   .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<section class="relative py-16 px-4 overflow-hidden rounded-[2.5rem] mx-2 md:mx-4 mt-4 shadow-2xl shadow-green-900/20">
   <div class="absolute inset-0 bg-linear-to-br from-green-950 via-green-800 to-green-600 -z-10"></div>
   <div class="absolute -top-24 -right-24 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>

   <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10">
         <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight leading-tight">
            Tìm kiếm <span class="text-green-300">tương lai</span> của bạn
         </h1>
         <p class="text-green-100/80 mt-4 text-lg font-medium">Hàng ngàn cơ hội việc làm mới mỗi ngày đang chờ đợi</p>
      </div>

      <partial name="~/Views/Home/Components/_SearchBar.cshtml" />

      <div class="mt-6">
         <partial name="~/Views/Home/Components/_SuggestTags.cshtml" />
      </div>

      <div class="grid md:grid-cols-3 gap-8 mt-12">
         <div class="md:col-span-1 hidden md:block">
            <partial name="~/Views/Home/Components/_CategorySidebar.cshtml" />
         </div>
         <div class="md:col-span-2 rounded-2xl overflow-hidden shadow-xl border border-white/10">
            <partial name="~/Views/Home/Components/_BannerSlider.cshtml" />
         </div>
      </div>
   </div>
</section>

<section class="max-w-7xl mx-auto -mt-10 relative z-30 px-4">
   <partial name="~/Views/Home/Components/_Stats.cshtml" />
</section>

<section class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8 bg-gray-50/50">
   <!-- Header Section -->
   <div class="mb-10">
      <partial name="~/Views/Home/Components/_HeaderSection.cshtml" />
   </div>

   <partial name="~/Views/Home/Components/_FilterTags.cshtml" />

   <!-- Job List -->
   <div id="jobListContainer" class="grid grid-cols-1 gap-6 transition-all duration-500">
      @await Html.PartialAsync("_JobListPartial")
   </div>
</section>

<section class="py-10 bg-gray-50/50 overflow-hidden">
   <partial name="~/Views/Home/Components/_LogoPartner.cshtml" />
</section>

<section class="max-w-7xl mx-auto py-20 px-4 sm:px-6">
   <partial name="~/Views/Home/Components/_CareerHandbookPartial.cshtml" />
</section>

<section class="max-w-7xl mx-auto py-24 px-4">
   <partial name="~/Views/Home/Components/_JobExplorer.cshtml" />
</section>

@section Scripts {
   <script>
      const dbLocations = @Html.Raw(Json.Serialize(ViewBag.Locations));

      const filterData = {
         location: [
            { id: '', name: 'Tất cả địa điểm' },
            ...dbLocations.map(loc => ({
                id: loc.locationId,
                name: loc.locationName
            }))
         ],
         salary: [
            { id: 'all', name: 'Tất cả mức lương' },
            { id: '0-3', name: 'Dưới 3 triệu' },
            { id: '3-7', name: '3 - 7 triệu' },
            { id: '7-15', name: '7 - 15 triệu' },
            { id: '15-30', name: '15 - 30 triệu' },
            { id: '30+', name: 'Trên 30 triệu' },
         ]
      };

      // 3. LOGIC LỌC CHÍNH (Hợp nhất xử lý)
      async function applyQuickFilter(id, type, element) {
         // Highlight UI
         document.querySelectorAll('.filter-pill').forEach(btn => {
            btn.classList.remove('bg-green-500', 'text-white', 'border-green-500');
            btn.classList.add('bg-gray-50', 'text-gray-600', 'border-gray-100');
         });
         element.classList.replace('bg-gray-50', 'bg-green-500');
         element.classList.replace('text-gray-600', 'text-white');
         element.classList.replace('border-gray-100', 'border-green-500');

         // Lấy giá trị hiện tại từ các input khác (nếu có trong _SearchBar)
         const keyword = document.getElementById("jobSearch")?.value || "";

         // Ưu tiên giá trị vừa click, nếu không lấy giá trị cũ trong dropdown
         let locId = (type === 'location') ? id : (document.getElementById("locationFilter")?.value || "");
         let sal = (type === 'salary') ? id : "";

         await loadJobs(1, keyword, locId, sal);
      }

      // 4. HÀM LOAD AJAX (Duy nhất một hàm, không trùng lặp)
      async function loadJobs(page = 1, keyword = "", locationId = "", salary = "") {
         const container = document.getElementById("jobListContainer");

         // Hiệu ứng Skeleton Loading
         container.innerHTML = `
         <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
               ${Array(6).fill(0).map(() => `
                  <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm h-64 animate-pulse">
                     <div class="flex gap-4"><div class="w-16 h-16 bg-gray-200 rounded-xl"></div><div class="flex-1"><div class="h-4 bg-gray-200 w-3/4 mb-2"></div><div class="h-3 bg-gray-200 w-1/2"></div></div></div>
                     <div class="mt-10"><div class="h-6 bg-gray-200 w-1/3"></div></div>
                  </div>
               `).join('')}
         </div>`;

         try {
            const url = `/Home/GetJobs?page=${page}&keyword=${encodeURIComponent(keyword)}&locationId=${locationId}&salary=${salary}`;
            const response = await fetch(url);

            if (response.ok) {
               const html = await response.text();
               container.innerHTML = html;

               // Update History URL
               const queryParams = new URLSearchParams(window.location.search);
               if(page > 1) queryParams.set('page', page);
               if(keyword) queryParams.set('keyword', keyword);
               if(locationId) queryParams.set('locationId', locationId);
               if(salary) queryParams.set('salary', salary);

               const newPath = window.location.pathname + (queryParams.toString() ? '?' + queryParams.toString() : '');
               history.pushState(null, '', newPath);
            }
         } catch (err) {
            console.error("Lỗi tải dữ liệu:", err);
         }
      }

      // 5. GIỮ NGUYÊN LOGIC CŨ (Search, Suggest, Heart)
      function searchJobs() {
         const keyword = document.getElementById("jobSearch").value;
         const locationId = document.getElementById("locationFilter").value;

         window.location.href = `/FindJobByID/Search?keyword=${encodeURIComponent(keyword)}&locationId=${locationId}`;
      }

      function selectSuggestion(value) {
         document.getElementById("jobSearch").value = value;
         searchJobs();
      }

      async function toggleSave(event, btn, jobId) {
         event.preventDefault();
         event.stopPropagation();
         const heartIcon = btn.querySelector('i');
         heartIcon.classList.toggle('fa-solid');
         heartIcon.classList.toggle('fa-regular');
         heartIcon.classList.toggle('text-rose-500');
         btn.classList.toggle('bg-rose-50');

         try {
            const res = await fetch("/api/SavedJob/toggle", {
               method: "POST",
               headers: { "Content-Type": "application/json" },
               body: JSON.stringify({ jobId: jobId })
            });
            if (!res.ok) throw new Error();
         } catch (err) {
            // Hoàn tác nếu lỗi
            heartIcon.classList.toggle('fa-solid');
            heartIcon.classList.toggle('fa-regular');
            heartIcon.classList.toggle('text-rose-500');
            btn.classList.toggle('bg-rose-50');
            alert("Lỗi lưu trạng thái!");
         }
      }

      // 6. KHỞI TẠO KHI LOAD TRANG
      document.addEventListener("DOMContentLoaded", function() {
         updateFilterTags();

         new Swiper(".mySwiper", {
            loop: true,
            autoplay: { delay: 2500 },
            pagination: { el: ".swiper-pagination", clickable: true },
            navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" },
         });
      });
   </script>
}
