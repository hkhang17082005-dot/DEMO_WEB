@using SRB_WebPortal.Controllers.apis.post
@model List<JobPostDTO>
@{
   ViewData["Title"] = "Trang chủ";

   var savedJobs = ViewBag.SavedJobs as List<int> ?? new List<int>();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<section class="bg-linear-to-r from-green-900 via-green-700 to-green-500 py-12 text-white relative rounded-3xl">

   <div class="max-w-7xl mx-auto px-4">

      <!-- TITLE -->
      <div class="text-center mb-6">
         <h1 class="text-3xl font-bold">
            Tìm việc làm nhanh 24h, việc làm mới nhất trên toàn quốc
         </h1>
         <p class="text-green-100 mt-2">
            Tiếp cận hàng chục nghìn cơ hội việc làm mỗi ngày
         </p>
      </div>

      <div class="relative max-w-5xl mx-auto">
         <partial name="~/Views/Home/Components/_SearchBar.cshtml" />
      </div>

      <!-- SUGGEST -->
      <partial name="~/Views/Home/Components/_SuggestTags.cshtml" />

      <div class="grid md:grid-cols-3 gap-6 mt-8">
         <partial name="~/Views/Home/Components/_CategorySidebar.cshtml" />

         <partial name="~/Views/Home/Components/_BannerSlider.cshtml" />
      </div>
   </div>
</section>

<section class="max-w-7xl mx-auto py-12 px-4">
   <h2 class="text-2xl font-bold text-green-600 mb-6">Việc làm phù hợp nhất</h2>

   @await Html.PartialAsync("_JobListPartial")
</section>

@section Scripts {
   <script>
      new Swiper(".mySwiper", {
         loop: true,
         autoplay: {
            delay: 2500,
         },

         pagination: {
            el: ".swiper-pagination",
            clickable: true,
         },

         navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
         },
      });
   </script>
   <script>
      // Tự động tìm kiếm khi chọn gợi ý
      function selectSuggestion(value) {
         document.getElementById("jobSearch").value = value;
         loadJobs(1);
      }

      function selectSuggestion(value) {
         document.getElementById("jobSearch").value = value;
      }

      async function toggleSave(event, btn, jobId) {
         // Ngăn chặn sự kiện click lan ra thẻ cha
         event.preventDefault();
         event.stopPropagation();

         const heartIcon = btn.querySelector('i');
         const isSaved = heartIcon.classList.contains('fa-solid');

         // Hiệu ứng giao diện tức thì
         if (isSaved) {
            heartIcon.classList.replace('fa-solid', 'fa-regular');
            heartIcon.classList.remove('text-rose-500');
            heartIcon.classList.add('text-gray-400');
            btn.classList.remove('bg-rose-50');
         } else {
            heartIcon.classList.replace('fa-regular', 'fa-solid');
            heartIcon.classList.add('text-rose-500');
            heartIcon.classList.remove('text-gray-400');
            btn.classList.add('bg-rose-50');
            // Thêm hiệu ứng nảy nhẹ khi tim đỏ
            heartIcon.classList.add('animate-bounce-short');
            setTimeout(() => heartIcon.classList.remove('animate-bounce-short'), 500);
         }

         try {
            const res = await fetch("/api/SavedJob/toggle", {
               method: "POST",
               headers: { "Content-Type": "application/json" },
               body: JSON.stringify({ jobId: jobId })
            });

            if (!res.ok) {
               // Nếu lỗi (ví dụ 401 Unauthorized), yêu cầu đăng nhập và hoàn tác UI
               if (res.status === 401) {
                  alert("Vui lòng đăng nhập để lưu việc làm!");
                  window.location.href = "/Login"; // Đường dẫn login
               } else {
                  throw new Error("Lỗi hệ thống");
               }
               throw new Error();
            }
         } catch (err) {
            // Hoàn tác lại icon nếu gọi API thất bại
            heartIcon.classList.toggle('fa-solid');
            heartIcon.classList.toggle('fa-regular');
            heartIcon.classList.toggle('text-rose-500');
            heartIcon.classList.toggle('text-gray-400');
         }
      }
      // Thay thế hàm searchJobs cũ trong Index.cshtml
      function reloadjobs() {
         loadJobs(1); // Gọi hàm AJAX thay vì load lại trang
      }
   </script>
}
