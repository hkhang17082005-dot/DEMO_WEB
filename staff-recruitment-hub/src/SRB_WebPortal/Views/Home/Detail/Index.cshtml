<style>
    /* Làm mượt việc cuộn trang khi bấm vào mục lục */
    html { scroll-behavior: smooth; }

    /* Custom nội dung bài viết */
    .prose h2 { 
        color: #111827; 
        font-weight: 800; 
        margin-top: 3rem; 
        margin-bottom: 1.5rem; 
        font-style: italic;
        letter-spacing: -0.025em;
    }
    
    .prose p { 
        margin-bottom: 1.75rem; 
        line-height: 1.85; 
        color: #374151; 
        font-size: 1.1rem;
    }

    /* Hiệu ứng trích dẫn */
    .prose blockquote {
        position: relative;
        overflow: hidden;
    }

    /* Tối ưu mobile */
    @@media (max-width: 1024px) {
        aside { display: none; } /* Ẩn sidebar trên mobile để tập trung đọc */
    }
</style>

<script>
    // Copy link bài viết
    function copyLink() {
        navigator.clipboard.writeText(window.location.href);
        alert("Đã sao chép đường dẫn bài viết!");
    }

    // Scroll Progress & Active TOC
    window.onscroll = function() {
        let winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        let height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        let scrolled = (winScroll / height) * 100;
        document.getElementById("progressBar").style.width = scrolled + "%";
        
        // Làm nổi bật mục lục khi cuộn đến phần tương ứng
        const sections = document.querySelectorAll('h2');
        const navLinks = document.querySelectorAll('#toc a');
        
        sections.forEach((section, i) => {
            const top = section.offsetTop - 100;
            if (winScroll >= top) {
                navLinks.forEach(link => link.classList.remove('text-green-600', 'font-bold'));
                navLinks[i].classList.add('text-green-600', 'font-bold');
            }
        });
    };
</script>

