@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="min-h-screen bg-gray-50">
    @await Component.InvokeAsync("Header")

    <main class="container mx-auto py-10 max-w-3xl px-4">
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
            <div class="bg-blue-600 p-8 text-white">
                <h2 class="text-2xl font-bold">Quản lý CV</h2>
                <p class="opacity-80">Định dạng hỗ trợ: PDF, DOCX (Tối đa 5MB)</p>
            </div>

            <div class="p-8">
                <div class="border-4 border-dashed border-gray-100 rounded-2xl p-12 text-center">
                    <div class="mb-6">📁</div>
                    <label
                        class="bg-blue-600 text-white px-10 py-4 rounded-xl font-bold cursor-pointer hover:bg-blue-700 transition inline-block">
                        Tải lên CV mới
                        <input type="file" class="hidden" onchange="CandidateModule.handleUploadCV(event)"
                               accept=".pdf,.doc,.docx" />
                    </label>
                </div>
            </div>
        </div>
    </main>
</div>
@section Scripts {
    <script src="~/js/candidate.js"></script>
}