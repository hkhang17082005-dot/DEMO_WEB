@{
   ViewData["Title"] = "Hồ sơ của tôi";
}

<main class="container max-w-3xl px-4 pb-12 mx-auto">
   <div class="overflow-hidden bg-white border border-gray-200 shadow-sm rounded-3xl">
      <div class="p-8 text-white bg-blue-600">
         <h2 class="text-2xl font-bold">Quản lý CV của bạn</h2>
         <p class="mt-1 opacity-80">Định dạng hỗ trợ: PDF, DOCX (Tối đa 5MB)</p>
      </div>

      <div class="p-8">
         <div
            class="p-12 text-center transition border-4 border-gray-200 border-dashed rounded-2xl bg-gray-50 hover:bg-gray-100">
            <div class="mb-6 text-5xl">📁</div>
            <label
               class="inline-block px-10 py-4 font-bold text-white transition bg-blue-600 shadow-md cursor-pointer rounded-xl hover:bg-blue-700">
               Tải lên CV mới
               <input type="file" class="hidden" onchange="CandidateModule.handleUploadCV(event)"
                      accept=".pdf,.doc,.docx" />
            </label>
            <p class="mt-4 text-sm text-gray-500">Hoặc kéo thả file CV của bạn vào đây</p>
         </div>
      </div>
   </div>
</main>

@section Scripts {
   <script src="~/js/candidate.js"></script>
}
