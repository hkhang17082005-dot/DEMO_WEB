@{
   Layout = "~/Views/Shared/_CandidateLayout.cshtml";
   ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
   <div>
      <h1 class="text-2xl font-bold text-gray-800">Cài đặt hồ sơ cá nhân</h1>
      <p class="text-sm text-gray-500 mt-1">Hoàn thiện hồ sơ để thu hút nhà tuyển dụng</p>
   </div>
   <button id="btnSaveProfile"
           class="bg-green-600 hover:bg-green-700 text-white px-6 py-2.5 rounded-lg font-semibold transition shadow-sm flex items-center gap-2">
      <i class="fa-solid fa-floppy-disk"></i> Lưu hồ sơ
   </button>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
   <div class="lg:col-span-2 space-y-6">
      
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
         <h2 class="text-lg font-bold text-gray-800 mb-4 pb-3 border-b border-gray-100">Thông tin cá nhân</h2>
            
         <div class="flex flex-col sm:flex-row gap-8 mb-4">
            <div class="flex flex-col items-center gap-3">
               <div class="relative group cursor-pointer">
                  <img src="https://ui-avatars.com/api/?name=U&background=00b14f&color=fff&size=120" alt="Avatar"
                       class="h-28 w-28 rounded-full border-4 border-white shadow-md object-cover" id="imgAvatar" />
                  <div
                     class="absolute inset-0 bg-black bg-opacity-40 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-200">
                     <i class="fa-solid fa-camera text-white text-xl"></i>
                  </div>
               </div>
               <span class="text-xs text-gray-400">Cho phép định dạng JPG, PNG</span>
            </div>

            <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-5">
               <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">Họ và tên <span
                     class="text-red-500">*</span></label>
                     <input type="text" id="txtFullName" placeholder="Nhập họ và tên..."
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-green-600 focus:ring-1 focus:ring-green-600 transition" />
                  </div>
                  <div>
                     <label class="block text-sm font-medium text-gray-700 mb-1.5">Vị trí ứng tuyển <span
                        class="text-red-500">*</span></label>
                        <input type="text" id="txtJobTitle" placeholder="VD: Backend Developer, Kế toán..."
                               class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-green-600 focus:ring-1 focus:ring-green-600 transition" />
                     </div>
                     <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Số điện thoại</label>
                        <input type="tel" id="txtPhone" placeholder="Nhập số điện thoại..."
                               class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-green-600 focus:ring-1 focus:ring-green-600 transition" />
                     </div>
                     <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Email <span
                           class="text-red-500">*</span></label>
                           <input type="email" id="txtEmail" placeholder="Email của bạn..."
                                  class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm bg-gray-50 text-gray-500 cursor-not-allowed"
                                  readonly />
                        </div>
                     </div>
                  </div>
               </div>

               <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                  <h2 class="text-lg font-bold text-gray-800 mb-4 pb-3 border-b border-gray-100">Giới thiệu bản thân</h2>
                  <textarea rows="5" id="txtSummary"
                            placeholder="Viết một đoạn ngắn (khoảng 3-4 câu) giới thiệu về định hướng nghề nghiệp, điểm mạnh của bản thân để gây ấn tượng với nhà tuyển dụng..."
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-green-600 focus:ring-1 focus:ring-green-600 transition resize-none"></textarea>
                  <div class="flex justify-between mt-2">
                     <span class="text-xs text-green-600 cursor-pointer hover:underline"><i
                        class="fa-solid fa-wand-magic-sparkles mr-1"></i> Gợi ý bằng AI (Sắp ra mắt)</span>
                        <span class="text-xs text-gray-400">0 / 1000 ký tự</span>
                     </div>
                  </div>
               </div>

               <div class="lg:col-span-1 space-y-6">
                  <div class="bg-green-50 rounded-xl shadow-sm border border-green-100 p-6 text-center">
                     <div
                        class="inline-flex items-center justify-center w-14 h-14 bg-white rounded-full text-green-600 mb-4 shadow-sm border border-green-100">
                        <i class="fa-solid fa-satellite-dish text-2xl animate-pulse"></i>
                     </div>
                     <h3 class="font-bold text-gray-800 mb-1.5">Trạng thái tìm việc</h3>
                     <p class="text-sm text-gray-600 mb-5">Bật để nhận được nhiều cơ hội việc làm tốt nhất từ các công ty.</p>
         
                     <label class="relative inline-flex items-center cursor-pointer shrink-0"
                            style="min-width: 44px; height: 24px;">
                        <input type="checkbox" value="" class="sr-only peer" checked>
                        <div
                           class="w-11 h-6 bg-gray-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600">
                        </div>
                     </label>
                  </div>

                  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                     <h2 class="text-base font-bold text-gray-800 mb-4 pb-3 border-b border-gray-100">Mong muốn công việc</h2>
                     <div class="space-y-4">
                        <div>
                           <label class="block text-sm font-medium text-gray-700 mb-1.5">Mức lương mong muốn</label>
                           <select
                              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-green-600 cursor-pointer">
                              <option>Thỏa thuận</option>
                              <option>Dưới 10 triệu</option>
                              <option>10 - 15 triệu</option>
                              <option>15 - 20 triệu</option>
                              <option>20 - 30 triệu</option>
                              <option>Trên 30 triệu</option>
                           </select>
                        </div>
                        <div>
                           <label class="block text-sm font-medium text-gray-700 mb-1.5">Số năm kinh nghiệm</label>
                           <select
                              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-green-600 cursor-pointer">
                              <option>Chưa có kinh nghiệm</option>
                              <option selected>Dưới 1 năm</option>
                              <option>1 - 2 năm</option>
                              <option>2 - 5 năm</option>
                              <option>Trên 5 năm</option>
                           </select>
                        </div>
                        <div>
                           <label class="block text-sm font-medium text-gray-700 mb-3">Hình thức làm việc</label>
                           <div class="flex flex-col gap-3">
                              <label class="flex items-center gap-3 cursor-pointer group">
                                 <input type="checkbox" checked
                                        class="w-4 h-4 text-green-600 bg-gray-100 border-gray-300 rounded focus:ring-green-500 cursor-pointer" />
                                 <span class="text-sm text-gray-700 group-hover:text-green-600 transition">Toàn thời gian</span>
                              </label>
                              <label class="flex items-center gap-3 cursor-pointer group">
                                 <input type="checkbox"
                                        class="w-4 h-4 text-green-600 bg-gray-100 border-gray-300 rounded focus:ring-green-500 cursor-pointer" />
                                 <span class="text-sm text-gray-700 group-hover:text-green-600 transition">Bán thời gian</span>
                              </label>
                              <label class="flex items-center gap-3 cursor-pointer group">
                                 <input type="checkbox"
                                        class="w-4 h-4 text-green-600 bg-gray-100 border-gray-300 rounded focus:ring-green-500 cursor-pointer" />
                                 <span class="text-sm text-gray-700 group-hover:text-green-600 transition">Làm từ xa (Remote)</span>
                              </label>
                           </div>
                        </div>
                     </div>
                  </div>

                  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                     <h2 class="text-base font-bold text-gray-800 mb-4 pb-3 border-b border-gray-100">Kỹ năng (Skills)</h2>
                     <p class="text-xs text-gray-500 mb-4">Thêm các từ khóa kỹ năng để hệ thống gợi ý việc làm chính xác hơn.</p>
                     <div class="flex flex-wrap gap-2 mb-4">
                        <span
                           class="inline-flex items-center gap-2 px-3 py-1.5 bg-gray-100 text-gray-700 rounded-md text-sm border border-gray-200">
                           C# <i class="fa-solid fa-xmark text-gray-400 cursor-pointer hover:text-red-500 transition"></i>
                        </span>
                        <span
                           class="inline-flex items-center gap-2 px-3 py-1.5 bg-gray-100 text-gray-700 rounded-md text-sm border border-gray-200">
                           ASP.NET Core <i class="fa-solid fa-xmark text-gray-400 cursor-pointer hover:text-red-500 transition"></i>
                        </span>
                        <span
                           class="inline-flex items-center gap-2 px-3 py-1.5 bg-gray-100 text-gray-700 rounded-md text-sm border border-gray-200">
                           SQL Server <i class="fa-solid fa-xmark text-gray-400 cursor-pointer hover:text-red-500 transition"></i>
                        </span>
                     </div>
                     <div class="relative">
                        <input type="text" placeholder="Gõ kỹ năng (VD: Java) và Enter..."
                               class="w-full border border-gray-300 rounded-lg pl-4 pr-10 py-2.5 text-sm focus:outline-none focus:border-green-600" />
                        <button class="absolute right-2 top-2 text-gray-400 hover:text-green-600 p-1 transition">
                           <i class="fa-solid fa-plus"></i>
                        </button>
                     </div>
                  </div>
               </div>
            </div>

            @section Scripts {
               <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
               <script type="module">
                  import apiClient from '/js/services/apiClient.js';

                  const txtFullName = document.getElementById('txtFullName');
                  const txtPhone = document.getElementById('txtPhone');
                  const txtEmail = document.getElementById('txtEmail');
                  const txtSummary = document.getElementById('txtSummary');
                  const imgAvatar = document.getElementById('imgAvatar');
                  const btnSaveProfile = document.getElementById('btnSaveProfile');

                  // Hàm tải thông tin
                  async function loadProfile() {
                  try {
                  const response = await apiClient.get('/CandidateApi/profile');
                  const result = response?.isSuccess ? response : response?.data;

                  if (result?.isSuccess && result.data) {
                  const data = result.data;
                  if (txtFullName) txtFullName.value = data.fullName || '';
                  if (txtPhone) txtPhone.value = data.phoneNumber || '';
                  if (txtEmail) txtEmail.value = data.email || '';
                  if (txtSummary) txtSummary.value = data.summary || '';
                    
                  // Tự động load chữ cái đầu làm Avatar
                  if (imgAvatar && data.fullName) {
                  const nameParts = data.fullName.trim().split(' ');
                  let initials = "U";
                  if (nameParts.length > 1) {
                  initials = nameParts[0][0] + nameParts[nameParts.length - 1][0];
                  } else if (nameParts.length === 1 && nameParts[0].length > 0) {
                  initials = nameParts[0][0];
                  }
                  imgAvatar.src = `https://ui-avatars.com/api/?name=${initials}&background=00b14f&color=fff&size=120`;
                  }
                  }
                  } catch (error) {
                  console.error("Lỗi khi tải Profile:", error);
                  }
                  }

                  // Hàm cập nhật (PUT)
                  async function saveProfile() {
                  try {
                  const originalText = btnSaveProfile.innerHTML;
                  btnSaveProfile.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang lưu...';
                  btnSaveProfile.disabled = true;

                  const payload = {
                  fullName: txtFullName?.value || '',
                  phoneNumber: txtPhone?.value || '',
                  summary: txtSummary?.value || '',
                  email: txtEmail?.value || ''
                  };

                  const response = await apiClient.post('/CandidateApi/profile', payload);
                  const result = response?.isSuccess ? response : response?.data;

                  if (result?.isSuccess) {
                  Swal.fire({
                  icon: 'success',
                  title: 'Thành công',
                  text: 'Đã cập nhật hồ sơ cá nhân!',
                  confirmButtonColor: '#00b14f'
                  });
                    
                  if (imgAvatar && payload.fullName) {
                  const nameParts = payload.fullName.trim().split(' ');
                  let initials = "U";
                  if (nameParts.length > 1) {
                  initials = nameParts[0][0] + nameParts[nameParts.length - 1][0];
                  } else if (nameParts.length === 1 && nameParts[0].length > 0) {
                  initials = nameParts[0][0];
                  }
                  imgAvatar.src = `https://ui-avatars.com/api/?name=${initials}&background=00b14f&color=fff&size=120`;
                  }
                  } else {
                  throw new Error(result?.message || "Cập nhật thất bại");
                  }
                  } catch (error) {
                  Swal.fire({
                  icon: 'error',
                  title: 'Lỗi',
                  text: error.message,
                  confirmButtonColor: '#00b14f'
                  });
                  } finally {
                  btnSaveProfile.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Lưu hồ sơ';
                  btnSaveProfile.disabled = false;
                  }
                  }

                  document.addEventListener('DOMContentLoaded', () => {
                  loadProfile();
                  if (btnSaveProfile) {
                  btnSaveProfile.addEventListener('click', saveProfile);
                  }
                  });
               </script>
            }