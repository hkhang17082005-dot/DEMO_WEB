@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="bg-white border-b shadow-sm mb-6">
    <div class="container mx-auto px-4 flex gap-8">
        <a href="/Candidate/Index" class="py-4 font-semibold text-gray-500 hover:text-blue-600 transition">Tổng quan</a>
        <a href="/Candidate/Profile" class="py-4 font-bold border-b-2 border-blue-600 text-blue-600">Hồ sơ cá nhân</a>
        <a href="/Candidate/MyApplications" class="py-4 font-semibold text-gray-500 hover:text-blue-600 transition">Việc
            làm đã nộp</a>
        </div>
    </div>

    <main class="container mx-auto pb-12 max-w-3xl px-4">
        <div class="bg-white rounded-3xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="bg-blue-600 p-8 text-white">
                <h2 class="text-2xl font-bold">Quản lý CV của bạn</h2>
                <p class="opacity-80 mt-1">Định dạng hỗ trợ: PDF, DOCX (Tối đa 5MB)</p>
            </div>

            <div class="p-8">
                <div
                    class="border-4 border-dashed border-gray-200 rounded-2xl p-12 text-center bg-gray-50 hover:bg-gray-100 transition">
                    <div class="mb-6 text-5xl">📁</div>
                    <label
                        class="bg-blue-600 text-white px-10 py-4 rounded-xl font-bold cursor-pointer hover:bg-blue-700 shadow-md transition inline-block">
                        Tải lên CV mới
                        <input type="file" class="hidden" onchange="CandidateModule.handleUploadCV(event)"
                               accept=".pdf,.doc,.docx" />
                    </label>
                    <p class="mt-4 text-sm text-gray-500">Hoặc kéo thả file CV của bạn vào đây</p>
                </div>
            </div>
        </div>
    </main>

    @section Scripts {
        <script src="~/js/candidate.js"></script>
    }