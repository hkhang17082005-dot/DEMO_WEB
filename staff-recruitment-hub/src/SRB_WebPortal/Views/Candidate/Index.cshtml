@{
   ViewData["Title"] = "Candidate Dashboard";
}

<main class="container px-4 pb-12 mx-auto">
   <h1 class="mb-8 text-3xl font-extrabold text-gray-900">Xin chào, <span class="text-blue-600">Ứng viên</span>! 👋
   </h1>

   <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      <div
         class="flex flex-col justify-between p-6 transition bg-white border border-gray-100 shadow-sm rounded-2xl hover:shadow-md">
         <div>
            <div class="mb-4 text-3xl text-blue-600">🔍</div>
            <h3 class="mb-2 text-xl font-bold text-gray-800">Khám phá việc làm</h3>
            <p class="mb-6 text-sm text-gray-500">Tìm kiếm hàng ngàn cơ hội phù hợp với năng lực của bạn.</p>
         </div>
         <a href="/" class="flex items-center gap-1 font-bold text-blue-600 hover:underline w-max">
            Tìm việc ngay &rarr;
         </a>
      </div>

      <div
         class="flex flex-col justify-between p-6 transition bg-white border border-gray-100 shadow-sm rounded-2xl hover:shadow-md">
         <div>
            <div class="mb-4 text-3xl text-green-600">📄</div>
            <h3 class="mb-2 text-xl font-bold text-gray-800">Hồ sơ cá nhân</h3>
            <p class="mb-6 text-sm text-gray-500">Cập nhật thông tin và CV để nhà tuyển dụng dễ dàng tìm thấy bạn.
            </p>
         </div>
         <a href="/Candidate/Profile" class="flex items-center gap-1 font-bold text-green-600 hover:underline w-max">
            Quản lý hồ sơ &rarr;
         </a>
      </div>

      <div
         class="flex flex-col justify-between p-6 transition bg-white border border-gray-100 shadow-sm rounded-2xl hover:shadow-md">
         <div>
            <div class="mb-4 text-3xl text-purple-600">🕒</div>
            <h3 class="mb-2 text-xl font-bold text-gray-800">Việc làm đã nộp</h3>
            <p class="mb-6 text-sm text-gray-500">Theo dõi trạng thái các đơn ứng tuyển của bạn.</p>
         </div>
         <a href="/Candidate/MyApplications"
            class="flex items-center gap-1 font-bold text-purple-600 hover:underline w-max">
            Xem lịch sử &rarr;
         </a>
      </div>
   </div>
</main>


