 @{ ViewData["Title"] = "Candidate Dashboard"; }

<div class="min-h-screen bg-gray-50">
    @await Component.InvokeAsync("Header")

    <main class="container mx-auto py-10 px-4">
        <h1 class="text-3xl font-extrabold text-gray-900 mb-8">Xin chào, Ứng viên!</h1>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
                <div class="text-blue-600 mb-4">🔍</div>
                <h3 class="font-bold text-xl mb-2">Khám phá việc làm</h3>
                <p class="text-gray-500 text-sm mb-6">Tìm kiếm hàng ngàn cơ hội phù hợp với năng lực của bạn.</p>
                <a href="/" class="text-blue-600 font-bold hover:underline">Tìm việc ngay &rarr;</a>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
                <div class="text-green-600 mb-4">📄</div>
                <h3 class="font-bold text-xl mb-2">Hồ sơ cá nhân</h3>
                <p class="text-gray-500 text-sm mb-6">Cập nhật thông tin và CV để nhà tuyển dụng dễ dàng tìm thấy bạn.</p>
                <a href="/Candidate/Profile" class="text-green-600 font-bold hover:underline">Quản lý hồ sơ</a>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
                <div class="text-purple-600 mb-4">🕒</div>
                <h3 class="font-bold text-xl mb-2">Việc làm đã nộp</h3>
                <p class="text-gray-500 text-sm mb-6">Theo dõi trạng thái các đơn ứng tuyển của bạn.</p>
                <a href="/Candidate/MyApplications" class="text-purple-600 font-bold hover:underline">Xem lịch sử</a>
            </div>
        </div>
    </main>

    @await Component.InvokeAsync("Footer")
</div>
