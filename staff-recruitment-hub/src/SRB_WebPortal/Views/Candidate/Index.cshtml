@using SRB_WebPortal.Controllers.apis.post
@model CandidateDashboardVM
@{
   Layout = "~/Views/Shared/_CandidateLayout.cshtml";

   ViewData["Title"] = "Bảng điều khiển";
}

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

   <div class="lg:col-span-4 space-y-6">

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
         <div class="flex items-center gap-4">
            <img src="https://ui-avatars.com/api/?name=HHK&background=00b14f&color=fff&bold=true" alt="Avatar"
                 class="h-16 w-16 rounded-full border-2 border-topcv" />
            <div>
               <h2 class="text-lg font-bold text-gray-800">Xin chào, @Model.FullName!</h2>
               <p class="text-sm text-gray-500 mt-1">Tài khoản ứng viên</p>
            </div>
         </div>

         <div class="mt-6 pt-6 border-t border-gray-100">
            <p class="text-sm font-medium text-gray-700 mb-2">Mức độ hoàn thiện hồ sơ:</p>
            <div class="w-full bg-gray-200 rounded-full h-2.5">
               <div class="bg-topcv h-2.5 rounded-full" style="width: 75%"></div>
            </div>
            <p class="text-xs text-right text-gray-500 mt-1">75% - Khá tốt</p>
            <a href="/Candidate/Profile"
               class="mt-4 block w-full text-center text-sm font-semibold text-topcv bg-green-50 py-2 rounded-lg hover:bg-green-100 transition">
               Cập nhật hồ sơ
            </a>
         </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
         <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
            <h3 class="font-bold text-gray-800">Quản lý hồ sơ</h3>
         </div>
         <div class="p-2">
            <a href="/Candidate/MyApplications"
               class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 rounded-lg text-gray-700 transition">
               <i class="fa-solid fa-paper-plane text-gray-400 w-5"></i>
               <span class="font-medium text-sm">Việc làm đã nộp</span>
               <span
               class="ml-auto bg-gray-100 text-gray-600 text-xs py-0.5 px-2 rounded-full font-bold">@Model.TotalApplied</span>
            </a>
            <a href="/SavedJob"
               class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 rounded-lg text-gray-700 transition">
               <i class="fa-solid fa-heart text-gray-400 w-5"></i>
               <span class="font-medium text-sm">Việc làm đã lưu</span>
               <span
               class="ml-auto bg-gray-100 text-gray-600 text-xs py-0.5 px-2 rounded-full font-bold">@Model.TotalSaved</span>
            </a>
            <a href="/Create_CV/CV_Management"
               class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 rounded-lg text-gray-700 transition">
               <i class="fa-solid fa-file-pdf text-gray-400 w-5"></i>
               <span class="font-medium text-sm">Quản lý CV</span>
            </a>
            <button id="openChatbot"
                    class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 rounded-lg text-gray-700 transition">
               <i class="fa-solid fa-robot text-gray-400 w-5"></i>
               <span class="font-medium text-sm">ChatBot Online</span>
            </button>
         </div>
      </div>
   </div>

   <div class="lg:col-span-8 space-y-6">

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
         <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-2">
               <div class="h-10 w-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-500">
                  <i class="fa-solid fa-eye"></i>
               </div>
               <h4 class="text-2xl font-bold text-gray-800">@Model.TotalViews</h4>
            </div>
            <p class="text-sm font-medium text-gray-500">NTD xem hồ sơ</p>
         </div>
         <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-2">
               <div class="h-10 w-10 rounded-full bg-green-50 flex items-center justify-center text-topcv">
                  <i class="fa-solid fa-check-circle"></i>
               </div>
               <h4 class="text-2xl font-bold text-gray-800">@Model.TotalInterviews</h4>
            </div>
            <p class="text-sm font-medium text-gray-500">Lời mời phỏng vấn</p>
         </div>
         <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex flex-col justify-center md:flex">
            <div class="flex items-center gap-3 mb-2">
               <div class="h-10 w-10 rounded-full bg-purple-50 flex items-center justify-center text-purple-500">
                  <i class="fa-solid fa-briefcase"></i>
               </div>
               <h4 class="text-2xl font-bold text-gray-800">@Model.SuitableJobsCount</h4>
            </div>
            <p class="text-sm font-medium text-gray-500">Việc làm phù hợp</p>
         </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
         <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center">
            <h3 class="font-bold text-lg text-gray-800">Gợi ý việc làm phù hợp</h3>
            <a href="/FindJobByID/Search" class="text-sm font-medium text-topcv hover:underline">Xem tất cả</a>
         </div>

         <div class="p-6">
            <!-- EMPTY STATE -->
            <div id="emptyState" class="text-center py-10">
               <img src="https://cdn-icons-png.flaticon.com/512/3050/3050525.png"
                    class="h-20 w-20 mx-auto opacity-50 mb-4" />
               <h4 class="text-gray-800 font-semibold mb-1">Cập nhật CV để nhận gợi ý!</h4>
               <p class="text-sm text-gray-500">
                  Chúng tôi cần biết thêm về kỹ năng của bạn để tìm việc chính xác hơn.
               </p>
            </div>

            <!-- CHAT UI -->
            <div id="chatContainer" class="hidden flex-col h-100">

               <!-- Messages -->
               <div id="chatMessages" class="flex-1 overflow-y-auto space-y-3 mb-4"></div>

               <!-- Input -->
               <div class="flex gap-2">
                  <input id="chatInput" type="text"
                         class="flex-1 border rounded-lg px-3 py-2 text-sm focus:outline-none"
                         placeholder="Nhập tin nhắn..." />
                  <button id="sendBtn" class="bg-topcv text-white px-4 py-2 rounded-lg text-sm font-semibold">
                     Gửi
                  </button>
               </div>

               <!-- Thinking -->
               <p id="loadingText" class="text-xs text-gray-500 mt-2 hidden">
                  Đang suy nghĩ...
               </p>
            </div>

         </div>
      </div>
   </div>
</div>

<script>
   const openBtn = document.getElementById("openChatbot");
   const emptyState = document.getElementById("emptyState");
   const chatContainer = document.getElementById("chatContainer");

   const sendBtn = document.getElementById("sendBtn");
   const chatInput = document.getElementById("chatInput");
   const chatMessages = document.getElementById("chatMessages");
   const loadingText = document.getElementById("loadingText");

   let isLoading = false;

   // Mở chat
   openBtn.addEventListener("click", () => {
      emptyState.classList.add("hidden");
      chatContainer.classList.add("flex");
      chatContainer.classList.remove("hidden");

      loadChat();
   });

   // Render message
   function addMessage(content, isUser = true) {
      const div = document.createElement("div");

      const formatted = content.replace(/\n/g, "<br>");

      div.className = `flex ${isUser ? "justify-end" : "justify-start"} mb-2`;

      div.innerHTML = `
         <div class="max-w-[70%] px-4 py-2 rounded-2xl text-sm shadow
            ${isUser
            ? "bg-gray-200 text-black rounded-br-none"
            : "bg-blue-100 text-gray-800 rounded-bl-none"}">
            ${formatted}
         </div>
      `;

      chatMessages.appendChild(div);
      chatMessages.scrollTop = chatMessages.scrollHeight;

      saveChat();
   }

   // Gửi message
   async function sendMessage() {
      const message = chatInput.value.trim();
      if (!message || isLoading) return;

      addMessage(message, true);
      chatInput.value = "";

      isLoading = true;
      sendBtn.disabled = true;
      loadingText.classList.remove("hidden");

      try {
         const res = await fetch("http://localhost:8080/chat", {
            method: "POST",
            headers: {
               "Content-Type": "application/json"
            },
            body: JSON.stringify({ message })
         });

         const data = await res.json();

         if (data.status === "success") {
            addMessage(data.reply, false);
         } else {
            addMessage("Có lỗi xảy ra!", false);
         }
      } catch (err) {
         addMessage("Không kết nối được server!", false);
      }

      isLoading = false;
      sendBtn.disabled = false;
      loadingText.classList.add("hidden");
   }

   function saveChat() {
      localStorage.setItem("chat_history", chatMessages.innerHTML);
   }

   function loadChat() {
      const history = localStorage.getItem("chat_history");
      if (history) {
         chatMessages.innerHTML = history;
      }
   }

   // Click gửi
   sendBtn.addEventListener("click", sendMessage);

   // Enter gửi luôn
   chatInput.addEventListener("keypress", function (e) {
      if (e.key === "Enter") {
         sendMessage();
      }
   });
</script>
