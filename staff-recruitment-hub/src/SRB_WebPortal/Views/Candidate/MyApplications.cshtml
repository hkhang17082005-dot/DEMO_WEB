@{
   Layout = "~/Views/Shared/_CandidateLayout.cshtml";
   ViewData["Title"] = "Việc làm đã nộp";
}

<div class="mb-6">
   <h1 class="text-2xl font-bold text-gray-800">Việc làm đã ứng tuyển</h1>
   <p class="text-sm text-gray-500 mt-1">Theo dõi trạng thái hồ sơ và phản hồi từ nhà tuyển dụng.</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6 overflow-hidden">
   <div class="flex overflow-x-auto custom-scrollbar">
      <button class="px-6 py-4 text-sm font-bold text-topcv border-b-2 border-topcv whitespace-nowrap bg-green-50/30">
         Tất cả (4)
      </button>
      <button
         class="px-6 py-4 text-sm font-medium text-gray-600 border-b-2 border-transparent hover:text-topcv hover:border-gray-200 transition whitespace-nowrap">
         Đã nộp (1)
      </button>
      <button
         class="px-6 py-4 text-sm font-medium text-gray-600 border-b-2 border-transparent hover:text-topcv hover:border-gray-200 transition whitespace-nowrap">
         NTD đã xem (2)
      </button>
      <button
         class="px-6 py-4 text-sm font-medium text-gray-600 border-b-2 border-transparent hover:text-topcv hover:border-gray-200 transition whitespace-nowrap">
         Phỏng vấn (1)
      </button>
      <button
         class="px-6 py-4 text-sm font-medium text-gray-600 border-b-2 border-transparent hover:text-topcv hover:border-gray-200 transition whitespace-nowrap">
         Bị từ chối (0)
      </button>
   </div>
</div>

