@{
   ViewData["Title"] = "Lịch sử ứng tuyển";
}

<main class="container px-4 pb-12 mx-auto">
   <h2 class="mb-6 text-2xl font-bold text-gray-800">Việc làm bạn đã ứng tuyển</h2>

   <div class="overflow-hidden bg-white border border-gray-200 shadow-sm rounded-2xl">
      <div class="overflow-x-auto">
         <table class="w-full text-left border-collapse">
            <thead class="text-sm uppercase border-b border-gray-200 bg-gray-50">
               <tr>
                  <th class="p-4 font-semibold text-gray-600">Vị trí ứng tuyển</th>
                  <th class="p-4 font-semibold text-gray-600">Ngày nộp</th>
                  <th class="p-4 font-semibold text-gray-600">Trạng thái</th>
               </tr>
            </thead>
            <tbody id="applicationList" class="divide-y divide-gray-100">
               <tr class="transition hover:bg-gray-50">
                  <td class="p-4">
                     <p class="font-bold text-gray-800">Software Engineer</p>
                     <p class="text-sm text-gray-500">Công ty ABC</p>
                  </td>
                  <td class="p-4 font-medium text-gray-500">10/03/2026</td>
                  <td class="p-4">
                     <span
                        class="bg-yellow-50 border border-yellow-200 text-yellow-700 px-3 py-1.5 rounded-lg text-xs font-bold inline-block">
                        Đang chờ duyệt
                     </span>
                  </td>
               </tr>
            </tbody>
         </table>
      </div>
   </div>
</main>

@section Scripts {
   <script src="~/js/candidate.js"></script>
}
