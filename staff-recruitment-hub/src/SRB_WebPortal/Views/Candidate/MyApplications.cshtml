@using SRB_ViewModel.Entities
@using SRB_WebPortal.Controllers.apis.post
@model List<MyApplicationDTO>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6 overflow-hidden">
   <div class="flex overflow-x-auto custom-scrollbar">
      <button class="px-6 py-4 text-sm font-bold text-topcv border-b-2 border-topcv whitespace-nowrap bg-green-50/30">
         <a href="/Candidate/">Quay lại</a>
      </button>
      <button class="px-6 py-4 text-sm font-bold text-topcv border-b-2 border-topcv whitespace-nowrap bg-green-50/30">
         Tất cả (@Model.Count)
      </button>
   </div>
</div>

<div class="space-y-4">
   @foreach (var item in Model)
   {
      var statusConfig = item.Status switch
      {
         ApplicationStatus.Interviewing => new
         {
            Color = "bg-green-500",
            Bg = "bg-green-100",
            Text = "text-green-700",
            Label = "Hẹn phỏng vấn"
         },
         ApplicationStatus.UnderReview => new
         {
            Color = "bg-orange-400",
            Bg = "bg-orange-50",
            Text = "text-orange-600",
            Label = "NTD đã xem CV"
         },
         _ => new { Color = "bg-gray-300", Bg = "bg-gray-100", Text = "text-gray-600", Label = "Gửi thành công" }
      };

      <div
         class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:border-topcv transition relative overflow-hidden">
         <div class="absolute top-0 left-0 w-1.5 h-full @statusConfig.Color"></div>
         <div class="flex flex-col md:flex-row gap-5 items-start md:items-center">

            <div
               class="w-16 h-16 rounded-lg border border-gray-200 bg-white flex items-center justify-center p-1 shrink-0">
               <img src="@(string.IsNullOrEmpty(item.CompanyLogo) ? "/images/business-logo.png" : item.CompanyLogo)"
                    class="w-full h-full object-contain" onerror="this.src='/images/business-logo.png';" />
            </div>

            <div class="flex-1">
               <a href="#" class="font-bold text-gray-800 text-lg hover:text-topcv transition line-clamp-1 mb-1">
                  @item.JobTitle
               </a>
               <p class="text-sm text-gray-500 mb-2">@item.CompanyName</p>
               <div class="flex flex-wrap items-center gap-4 text-xs text-gray-500">
                  <span class="flex items-center gap-1">
                     <i class="fa-regular fa-clock"></i> Nộp lúc: @item.AppliedAt.ToString("HH:mm - dd/MM/yyyy")
                  </span>
                  <span class="flex items-center gap-1">
                     <i class="fa-regular fa-file-pdf"></i> CV: @item.CVFileName
                  </span>
               </div>
            </div>

            <div class="flex flex-col items-end gap-3 mt-4 md:mt-0 md:w-48 shrink-0">
               <span
                  class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold @statusConfig.Bg @statusConfig.Text border">
                  @if (item.Status == ApplicationStatus.Interviewing)
                  {
                     <span class="w-2 h-2 rounded-full @statusConfig.Color animate-pulse"></span>
                  }
                  @statusConfig.Label
               </span>
               @if (item.Status == ApplicationStatus.Submitted)
               {
                  <button class="text-xs text-red-500 hover:underline">Rút lại hồ sơ</button>
               }
            </div>
         </div>
      </div>
   }
</div>
