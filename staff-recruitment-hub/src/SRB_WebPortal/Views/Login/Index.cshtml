@{
   ViewData["Title"] = "Login";
}

<div class="min-h-screen bg-linear-to-br from-gray-50 to-gray-100 flex items-center justify-center p-4">
   <div class="max-w-md w-full space-y-8 bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
      <!-- Header -->
      <div class="text-center">
         <h2 class="text-3xl font-bold text-gray-800">Chào mừng trở lại</h2>
         <p class="mt-2 text-sm text-gray-500">Đăng nhập để tiếp tục</p>
      </div>

      <!-- Social Login Buttons -->
      <div class="space-y-3">
         <button class="w-full flex items-center justify-center
            gap-3 bg-white border border-gray-300 text-gray-700
            rounded-lg px-4 py-3 hover:bg-gray-50
            transition-all duration-200 group cursor-pointer
            ">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
               <path fill="#4285F4"
                     d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
               <path fill="#34A853"
                     d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
               <path fill="#FBBC05"
                     d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
               <path fill="#EA4335"
                     d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
            </svg>
            <span class="text-sm font-medium">Đăng nhập với Google</span>
         </button>

         <button class="w-full flex items-center justify-center
            gap-3 bg-gray-900 text-white rounded-lg
            px-4 py-3 hover:bg-gray-800 transition-all duration-200 group cursor-pointer
            ">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
               <path fill-rule="evenodd"
                     d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                     clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium">Đăng nhập với GitHub</span>
         </button>
      </div>

      <!-- Divider -->
      <div class="relative">
         <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200"></div>
         </div>
         <div class="relative flex justify-center text-sm">
            <span class="px-4 bg-white text-gray-400">Hoặc đăng nhập với</span>
         </div>
      </div>

      <!-- Login Form -->
      <form class="space-y-6" method="POST" id="loginForm">
         <div class="space-y-4">
            <!-- Username/Email Field -->
            <div>
               <label for="username" class="block text-sm font-medium text-gray-700 mb-1">
                  Tên đăng nhập / Email
               </label>
               <input type="text" id="username" name="username" required class="w-full px-4 py-3 border border-gray-200
               rounded-lg focus:outline-none focus:ring-2
               focus:ring-green-200 focus:border-green-400
               transition-all duration-200 placeholder:text-sm
               " placeholder="Nhập tên đăng nhập hoặc email">
            </div>

            <!-- Password Field -->
            <div>
               <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
                  Mật khẩu
               </label>
               <input type="password" id="password" name="password" required class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none
               focus:ring-2 focus:ring-green-200 focus:border-green-400 transition-all
               duration-200 placeholder:text-sm" placeholder="••••••••">
            </div>
         </div>

         <!-- Remember Me & Forgot Password -->
         <div class="flex items-center justify-between">
            <div class="flex items-center">
               <input type="checkbox" id="remember" name="remember"
                      class="w-4 h-4 text-green-500 border-gray-300 rounded focus:ring-green-200 transition-all duration-200">
               <label for="remember" class="ml-2 block text-sm text-gray-600">
                  Ghi nhớ đăng nhập
               </label>
            </div>
            <div class="text-sm">
               <a href="#" class="font-medium text-green-600 hover:text-green-500 transition-all duration-200">
                  Quên mật khẩu?
               </a>
            </div>
         </div>

         <!-- Login Button -->
         <button type="submit" class="w-full bg-gray-800 text-white rounded-lg
            px-4 py-3 font-medium hover:bg-gray-700 focus:outline-none
            focus:ring-2 focus:ring-gray-300 transform transition-all
            duration-200 hover:scale-[1.02] cursor-pointer">
            Đăng nhập
         </button>

         <!-- Terms -->
         <div class="text-center text-xs text-gray-400">
            Bằng cách đăng nhập, mặc định bạn đồng ý với
            <a href="#" class="text-gray-500 hover:text-green-500 transition-all duration-200">Điều khoản dịch vụ</a>
            <span class="mx-1">và</span>
            <a href="#" class="text-gray-500 hover:text-green-500 transition-all duration-200">Chính sách bảo mật</a>
         </div>
      </form>

      <!-- Register Link -->
      <div class="text-center pt-4 border-t border-gray-100">
         <p class="text-sm text-gray-500">
            Chưa có tài khoản?
            <a href="/register" class="font-medium text-green-600 hover:text-green-500 transition-all duration-200">
               Đăng ký ngay
            </a>
         </p>
      </div>
   </div>
</div>

<script>
   document.querySelectorAll('input').forEach(input => {
      input.addEventListener('focus', function () {
         this.parentElement.classList.add('focused');
      });

      input.addEventListener('blur', function () {
         if (!this.value) {
            this.parentElement.classList.remove('focused');
         }
      });
   });
</script>

<script type="module">
   import authService from '/js/services/authService.js';

   const loginForm = document.getElementById('loginForm');
   const submitBtn = loginForm.querySelector('button[type="submit"]');
   const originalBtnText = "Đăng nhập";

   loginForm.addEventListener('submit', async (e) => {
   e.preventDefault();

   submitBtn.disabled = true;
   submitBtn.innerHTML = `
   <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline-block" xmlns="http://www.w3.org" fill="none" viewBox="0 0 24 24">
   <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
   <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
   </svg>
   Đang đăng nhập...
   `;
   submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

   const formData = new FormData(loginForm);
   const data = Object.fromEntries(formData.entries());
   data.remember = data.remember === 'on';

   try {
   const result = await authService.login(data);
   // Nếu thành công thì chuyển trang
   window.location.href = "/";
   } catch (err) {
   console.error("Lỗi:", err.message);
   alert("Đăng nhập thất bại: " + err.message);

   submitBtn.disabled = false;
   submitBtn.innerHTML = originalBtnText;
   submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
   }
   });
</script>
