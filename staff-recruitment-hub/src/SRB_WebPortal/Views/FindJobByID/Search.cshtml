 @using SRB_ViewModel.Entities
@model List<JobPost>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="bg-[#f4f7f6] min-h-screen font-sans antialiased rounded-3xl">

    <div class="bg-linear-to-r from-emerald-800 to-emerald-600 pt-12 pb-24 px-4 relative overflow-hidden rounded-3xl">
        <div class="absolute top-0 right-0 -mt-20 -mr-20 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-80 h-80 bg-emerald-400/10 rounded-full blur-3xl"></div>

        <div class="max-w-6xl mx-auto relative z-10">
            <div class="text-center mb-10">
                <h2 class="text-white text-3xl md:text-4xl font-extrabold mb-3 tracking-tight">Cơ hội mới, sự nghiệp mới</h2>
                <p class="text-emerald-100 text-lg opacity-90">Hàng ngàn việc làm chất lượng đang chờ đón bạn</p>
            </div>

            <div class="bg-white rounded-2xl p-2 shadow-[0_20px_50px_rgba(0,0,0,0.15)] flex flex-col md:flex-row gap-2 max-w-5xl mx-auto">
                <div class="flex-[1.5] flex items-center px-5 py-3 border-b md:border-b-0 md:border-r border-gray-100 group">
                    <i class="fa-solid fa-magnifying-glass text-emerald-500 mr-3 group-focus-within:scale-110 transition-transform"></i>
                    <input type="text" id="jobSearch" value="@ViewBag.Keyword"
                           placeholder="Vị trí tuyển dụng, tên công ty..."
                           class="w-full text-gray-700 outline-none placeholder-gray-400 font-medium text-base">
                </div>

                <div class="flex-1 flex items-center px-5 py-3 group">
                    <i class="fa-solid fa-location-dot text-emerald-500 mr-3 group-focus-within:bounce transition-transform"></i>
                    <div class="relative w-full">
                        <select id="locationFilter" class="w-full text-gray-700 outline-none appearance-none font-medium bg-transparent cursor-pointer pr-8">
                            <option value="">Tất cả địa điểm</option>
                            @foreach (var location in ViewBag.Locations)
                            {
                                <option value="@location.LocationID" selected="@(ViewBag.CurrentLocation == location.LocationID)">
                                    @location.LocationName
                                </option>
                            }
                        </select>
                        <i class="fa-solid fa-chevron-down absolute right-0 top-1/2 -translate-y-1/2 text-[10px] text-gray-400 pointer-events-none"></i>
                    </div>
                </div>

                <button onclick="searchJobs()"
                        class="bg-orange-500 hover:bg-orange-600 px-12 py-4 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-orange-200 active:scale-95 flex items-center justify-center gap-2">
                    <i class="fa-solid fa-paper-plane"></i>
                    <span>TÌM KIẾM</span>
                </button>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 -mt-12 pb-20 relative z-20">
        <div class="grid grid-cols-12 gap-8">

            <div class="col-span-12 lg:col-span-3">
                <div class="sticky top-6 space-y-6">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <div class="flex items-center justify-between mb-6">
                            <h3 class="font-bold text-gray-800 text-lg flex items-center gap-2">
                                <i class="fa-solid fa-sliders text-emerald-600"></i> Bộ lọc
                            </h3>
                            <button class="text-xs text-emerald-600 font-bold hover:underline">Xóa tất cả</button>
                        </div>

                        <div class="space-y-6">
                            <div>
                                <p class="font-bold text-sm text-gray-800 mb-4 border-l-4 border-emerald-500 pl-3">Chế độ làm việc</p>
                                <div class="space-y-3">
                                    <label class="flex items-center group cursor-pointer">
                                        <div class="relative flex items-center">
                                            <input type="radio" name="sat" checked class="peer appearance-none w-5 h-5 border-2 border-gray-200 rounded-full checked:border-emerald-500 transition-all">
                                            <div class="absolute w-2.5 h-2.5 bg-emerald-500 rounded-full left-1.25 opacity-0 peer-checked:opacity-100 transition-opacity"></div>
                                        </div>
                                        <span class="ml-3 text-sm text-gray-600 font-medium group-hover:text-emerald-600 transition">Tất cả</span>
                                    </label>
                                    <label class="flex items-center group cursor-pointer">
                                        <div class="relative flex items-center">
                                            <input type="radio" name="sat" class="peer appearance-none w-5 h-5 border-2 border-gray-200 rounded-full checked:border-emerald-500 transition-all">
                                            <div class="absolute w-2.5 h-2.5 bg-emerald-500 rounded-full left-1.25 opacity-0 peer-checked:opacity-100 transition-opacity"></div>
                                        </div>
                                        <span class="ml-3 text-sm text-gray-600 font-medium group-hover:text-emerald-600 transition">Nghỉ thứ 7 & CN</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-emerald-900 rounded-2xl p-6 text-white relative overflow-hidden group shadow-xl">
                        <div class="relative z-10">
                            <i class="fa-solid fa-rocket text-orange-400 text-3xl mb-4 group-hover:animate-bounce"></i>
                            <h4 class="font-bold text-lg mb-2 leading-tight">Nâng cấp hồ sơ</h4>
                            <p class="text-emerald-200 text-xs leading-relaxed mb-4">Để CV của bạn tiếp cận nhà tuyển dụng nhanh hơn gấp 2 lần.</p>
                            <button onclick="window.location.href='/Create_CV/All_CV_Style'"
                                    class="w-full bg-orange-500 hover:bg-orange-600 py-2.5 rounded-xl text-sm font-bold transition-colors">
                                Cập nhật ngay
                            </button>
                        </div>
                        <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-emerald-800 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
                    </div>
                </div>
            </div>

            <div class="col-span-12 lg:col-span-9">
                <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div class="flex items-center gap-3">
                        <div class="bg-emerald-100 text-emerald-700 px-4 py-2 rounded-xl font-bold text-lg">
                            @Model.Count
                        </div>
                        <h1 class="text-gray-800 font-bold">
                            Việc làm @(ViewBag.Keyword ?? "") tại @(ViewBag.CurrentLocationName ?? "toàn quốc")
                        </h1>
                    </div>

                    <div class="flex items-center gap-2">
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Sắp xếp:</span>
                        <select class="bg-gray-50 border-none text-sm font-bold text-gray-700 rounded-lg px-4 py-2 outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                            <option>Mới nhất</option>
                            <option>Lương cao nhất</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-4">
                    @if (!Model.Any())
                    {
                        <div class="bg-white py-20 rounded-3xl shadow-sm border border-gray-100 text-center">
                            <div class="w-40 h-40 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                                <i class="fa-solid fa-briefcase text-5xl text-gray-200"></i>
                            </div>
                            <h3 class="text-xl font-bold text-gray-800 mb-2">Không tìm thấy kết quả</h3>
                            <p class="text-gray-500 max-w-sm mx-auto">Hãy thử thay đổi từ khóa hoặc bộ lọc để tìm kiếm thêm nhiều cơ hội khác.</p>
                            <button onclick="location.reload()" class="mt-6 text-emerald-600 font-bold hover:text-emerald-700">Làm mới trang</button>
                        </div>
                    }

                    @foreach (var job in Model)
                    {
                        <div class="group bg-white border border-transparent rounded-2xl p-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] hover:border-emerald-100 transition-all duration-300 relative">

                            <div class="flex gap-6">
                                <div class="w-20 h-20 bg-gray-50 border border-gray-100 rounded-2xl flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300 relative overflow-hidden">
                                    @*<img src="@job.LogoUrl" alt="logo" class="w-full h-full object-cover" />*@
                                    <div class="absolute top-0 left-0 bg-red-500 text-white text-[8px] font-bold px-1.5 py-0.5 rounded-br-lg uppercase">Hot</div>
                                </div>

                                <div class="space-y-2">
                                    <h3 class="font-bold text-xl text-gray-800 group-hover:text-emerald-600 transition-colors line-clamp-1">
                                        @job.Title
                                    </h3>
                                    <p class="text-gray-400 font-bold text-sm uppercase tracking-tight flex items-center gap-2">
                                        @job.Business.BusinessName
                                        <i class="fa-solid fa-circle-check text-blue-400 text-[10px]" title="Nhà tuyển dụng xác thực"></i>
                                    </p>

                                    <div class="flex flex-wrap gap-2 pt-2">
                                        <span class="bg-gray-100 text-gray-600 px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-1.5">
                                            <i class="fa-solid fa-location-dot"></i> @job.Location.LocationName
                                        </span>
                                        <span class="bg-blue-50 text-blue-600 px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-1.5">
                                            <i class="fa-solid fa-briefcase"></i> @job.JobType
                                        </span>
                                        <span class="bg-emerald-50 text-emerald-700 px-3 py-1.5 rounded-lg text-xs font-extrabold flex items-center gap-1.5">
                                            <i class="fa-solid fa-coins"></i> @job.SalaryRange
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="flex flex-row sm:flex-col items-center sm:items-end w-full sm:w-auto justify-between gap-4 border-t sm:border-t-0 pt-4 sm:pt-0">
                                <div class="text-right">
                                    <p class="text-[11px] text-gray-400 font-bold uppercase tracking-widest mb-1">Hạn ứng tuyển</p>
                                    <span class="text-sm text-gray-700 font-bold bg-gray-50 px-3 py-1 rounded-md border border-gray-100">
                                        15/10/2024
                                    </span>
                                </div>
                                <a href="/jobs/details/@job.JobPostID"
                                   class="bg-emerald-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-emerald-700 shadow-[0_4px_14px_0_rgba(16,185,129,0.39)] transition-all active:scale-95">
                                    Ứng tuyển
                                </a>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-12 flex justify-center gap-2">
                    <button class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-gray-200 text-gray-400 hover:bg-emerald-50 hover:text-emerald-600 transition-all"><i class="fa-solid fa-chevron-left"></i></button>
                    <button class="w-10 h-10 flex items-center justify-center rounded-xl bg-emerald-600 text-white font-bold shadow-lg shadow-emerald-200 transition-all">1</button>
                    <button class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-gray-200 text-gray-600 font-bold hover:bg-emerald-50 transition-all">2</button>
                    <button class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-gray-200 text-gray-400 hover:bg-emerald-50 hover:text-emerald-600 transition-all"><i class="fa-solid fa-chevron-right"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function searchJobs() {
    const keyword = document.getElementById("jobSearch").value;
    const locationId = document.getElementById("locationFilter").value;

    // Thêm hiệu ứng loading đơn giản vào nút tìm kiếm
    const btn = event.currentTarget;
    btn.innerHTML = '<i class="fa-solid fa-circle-notch animate-spin"></i> ĐANG TÌM...';
    btn.disabled = true;

    window.location.href =
        "/FindJobByID/Search?keyword=" + encodeURIComponent(keyword) +
        "&locationId=" + locationId;
}
</script>

<style>
    /* Custom Scrollbar cho trải nghiệm mượt mà */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #f1f1f1; }
    ::-webkit-scrollbar-thumb { background: #10b981; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #059669; }

    /* Animation cho Icon khi focus */
    .bounce { animation: bounce 1s infinite; }
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-3px); }
    }
</style> 
