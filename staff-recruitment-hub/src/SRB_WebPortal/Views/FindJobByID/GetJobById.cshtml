@using SRB_ViewModel.Entities
@model List<Job>

@{
    ViewData["Title"] = "Việc làm theo địa điểm";
}
<!-- SEARCH BAR -->
<div class="bg-white rounded-full overflow-hidden flex flex-col md:flex-row max-w-5xl mx-auto shadow-lg mb-10">

    <!-- Search job -->
    <input type="text" id="jobSearch" placeholder="Vị trí tuyển dụng, tên công ty"
           class="flex-1 px-6 py-4 text-gray-700 outline-none">

    <!-- Location -->
    <select id="locationFilter" class="px-4 py-4 text-gray-600 outline-none border-t md:border-t-0 md:border-l">

        <option value="">Địa điểm</option>
        @if (ViewBag.CurrentLocation != null)
        {
            @foreach (var location in ViewBag.Locations)
            {
                if (location.LocationID == ViewBag.CurrentLocation)
                {
                    <option value="@location.LocationID" selected>
                        @location.LocationName
                    </option>
                }
                else{
                    <option value="@location.LocationID">
                        @location.LocationName
                    </option>
                }
            }
        }

    </select>

    <!-- Button -->
    <button onclick="searchJobs()" class="bg-emerald-600 hover:bg-emerald-700 px-8 text-white font-semibold transition">
        Tìm kiếm
    </button>

</div>
<div class="max-w-7xl mx-auto px-4 py-10">

    <!-- Title -->
    <h1 class="text-2xl font-bold mb-2">
        Tuyển dụng @Model.Count việc làm tại @ViewBag.Location
    </h1>

    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-6">
        <span class="text-emerald-600">Trang chủ</span>
        >
        <span class="text-emerald-600">Việc làm</span>
        >
        <span>@ViewBag.Location</span>
    </div>

    <div class="grid grid-cols-12 gap-6">

        <!-- ============= FILTER SIDEBAR ============= -->
        <div class="col-span-3">

            <div class="bg-white p-5 rounded-xl shadow">

                <h3 class="font-semibold text-lg mb-4">
                    🔎 Lọc nâng cao
                </h3>

                <!-- Nghỉ thứ 7 -->
                <div class="mb-6">
                    <p class="font-semibold mb-2">Nghỉ thứ 7</p>

                    <label class="flex items-center mb-1">
                        <input type="radio" name="sat" class="mr-2">
                        Không lọc
                    </label>

                    <label class="flex items-center mb-1">
                        <input type="radio" name="sat" class="mr-2">
                        Làm thứ 7
                    </label>

                    <label class="flex items-center mb-1">
                        <input type="radio" name="sat" class="mr-2">
                        Nghỉ thứ 7
                    </label>
                </div>

                <!-- Lĩnh vực công ty -->
                <div class="mb-6">
                    <p class="font-semibold mb-2">Lĩnh vực công ty</p>

                    <select class="w-full border rounded-lg p-2">
                        <option>Tất cả lĩnh vực</option>
                    </select>
                </div>

                <!-- Lĩnh vực công việc -->
                <div class="mb-6">
                    <p class="font-semibold mb-2">Lĩnh vực công việc</p>

                    <select class="w-full border rounded-lg p-2">
                        <option>Tất cả lĩnh vực</option>
                    </select>
                </div>

            </div>

        </div>


        <!-- ============= JOB LIST ============= -->
        <div class="col-span-9 space-y-4">

            @foreach (var job in Model)
            {

                <div class="bg-white border border-emerald-200 rounded-xl p-5 flex justify-between items-center hover:shadow-md transition">

                    <div class="flex gap-4">

                        <!-- Logo -->
                        <div class="w-16 h-16 bg-gray-100 rounded-lg flex items-center justify-center">
                            <span class="text-gray-400 text-sm">
                                Logo
                            </span>
                        </div>

                        <!-- Job Info -->
                        <div>

                            <h3 class="font-semibold text-lg text-gray-800">
                                @job.Title
                            </h3>

                            <p class="text-gray-500 text-sm">
                                @job.CompanyName
                            </p>

                            <div class="flex gap-3 mt-2 text-sm">

                                <span class="bg-gray-100 px-3 py-1 rounded-full">
                                    @job.Location.LocationName
                                </span>

                                <span class="bg-gray-100 px-3 py-1 rounded-full">
                                    @job.JobType
                                </span>

                            </div>

                        </div>

                    </div>

                    <!-- Salary + Button -->
                    <div class="text-right">

                        <p class="text-emerald-600 font-semibold mb-2">
                            @job.Salary
                        </p>

                        <a href="/jobs/details/@job.JobID"
                               class="bg-emerald-600 text-white px-4 py-2 rounded-lg hover:bg-emerald-700">
                            Ứng tuyển
                        </a>

                    </div>

                </div>

            }

        </div>

    </div>
    <script>
            function searchJobs() {

                var keyword = document.getElementById("jobSearch").value;
                var locationId = document.getElementById("locationFilter").value;
                
                window.location.href =
                    "/FindJobByID/Search?keyword=" + encodeURIComponent(keyword) + "&locationId=" + locationId;
            }
    </script>
</div>