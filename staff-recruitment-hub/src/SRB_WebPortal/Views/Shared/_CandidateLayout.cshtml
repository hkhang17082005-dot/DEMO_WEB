@* @{
   Layout = "_Layout";
}

<div class="mb-6 bg-white border-b shadow-sm">
   <div class="container flex gap-8 px-4 mx-auto">
      <a href="/Candidate/Index"
         class="py-4 font-semibold @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "border-b-2 border-blue-600 text-blue-600 font-bold" : "text-gray-500 hover:text-blue-600")">
         Tổng quan
      </a>
      <a href="/Candidate/Profile"
         class="py-4 font-semibold @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "border-b-2 border-blue-600 text-blue-600 font-bold" : "text-gray-500 hover:text-blue-600")">
         Hồ sơ cá nhân
      </a>
      <a href="/Candidate/MyApplications"
         class="py-4 font-semibold @(ViewContext.RouteData.Values["Action"]?.ToString() == "MyApplications" ? "border-b-2 border-blue-600 text-blue-600 font-bold" : "text-gray-500 hover:text-blue-600")">
         Việc làm đã nộp
      </a>
   </div>
</div>

<main class="container px-4 pb-12 mx-auto">
   @RenderBody()
</main>

@RenderSection("Scripts", required: false) *@

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Candidate Portal</title>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        topcv: '#00b14f',
                    }
                }
            }
        }
    </script>
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f4f5f5; }
        .hover-text-topcv:hover { color: #00b14f; }
    </style>
</head>
<body class="text-gray-800 antialiased flex flex-col min-h-screen">

    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-[1340px] mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                
                <div class="flex items-center gap-8">
                    <a href="/Home" class="text-2xl font-bold text-topcv flex items-center gap-2">
                        <i class="fa-solid fa-briefcase"></i> Zeion Devloper
                    </a>
                    
                    <nav class="hidden md:flex space-x-1">
                        <a href="/FindJobByID/Search" class="px-4 py-2 text-sm font-semibold text-gray-700 hover-text-topcv transition-colors">
                            Việc làm
                        </a>
                        <a href="/Candidate/Profile" class="px-4 py-2 text-sm font-semibold text-gray-700 hover-text-topcv transition-colors">
                            Hồ sơ & CV
                        </a>
                        <a href="/Business" class="px-4 py-2 text-sm font-semibold text-gray-700 hover-text-topcv transition-colors">
                            Công ty
                        </a>
                    </nav>
                </div>

                <div class="flex items-center gap-6">
                    
                    <div class="hidden lg:flex items-center gap-2 bg-gray-50 border border-gray-200 px-3 py-1.5 rounded-full">
                        <span class="text-xs font-medium text-gray-600">Trạng thái tìm việc</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" value="" class="sr-only peer" checked>
                            <div class="w-8 h-4 bg-gray-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-[#00b14f]"></div>
                        </label>
                    </div>

                    <div class="flex items-center gap-4">
                        <button class="text-gray-500 hover-text-topcv relative bg-gray-100 p-2 rounded-full h-10 w-10 flex items-center justify-center transition">
                            <i class="fa-regular fa-comment-dots text-lg"></i>
                        </button>
                        <button class="text-gray-500 hover-text-topcv relative bg-gray-100 p-2 rounded-full h-10 w-10 flex items-center justify-center transition">
                            <i class="fa-regular fa-bell text-lg"></i>
                            <span class="absolute top-0 right-0 flex h-3 w-3 mt-1 mr-1">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500 border-2 border-white"></span>
                            </span>
                        </button>
                    </div>

                    <div class="relative group cursor-pointer pl-4 border-l border-gray-200">
                        <div class="flex items-center gap-2">
                            <img src="https://ui-avatars.com/api/?name=HHK&background=00b14f&color=fff&bold=true" alt="Avatar" class="h-10 w-10 rounded-full border border-gray-200 object-cover" />
                            <div class="hidden sm:block">
                                <p class="text-sm font-semibold text-gray-700 leading-none">Hoàng Khang</p>
                                <p class="text-xs text-gray-500 mt-1">Mã ứng viên: #12345</p>
                            </div>
                            <i class="fa-solid fa-chevron-down text-xs text-gray-400 ml-1"></i>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </header>

    <main class="flex-1 w-full max-w-[1340px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>
    
    <footer class="bg-white border-t border-gray-200 mt-auto">
        <div class="max-w-[1340px] mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-sm text-gray-500">&copy; @DateTime.Now.Year Staff Recruitment Hub.</p>
            <div class="flex space-x-4 text-sm text-gray-500">
                <a href="#" class="hover-text-topcv">Quy định bảo mật</a>
                <a href="#" class="hover-text-topcv">Thỏa thuận sử dụng</a>
                <a href="#" class="hover-text-topcv">Quy chế hoạt động</a>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>