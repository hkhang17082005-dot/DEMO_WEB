@using System.Security.Claims
@{
   var fullName = User.FindFirst(ClaimTypes.Name)?.Value ?? User.FindFirst("FullName")?.Value ?? User.Identity?.Name ??
"Ứng Viên";
   var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? User.FindFirst("Id")?.Value ?? "00000";

   var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
   var initials = nameParts.Length > 1
                  ? $"{nameParts.First()[0]}{nameParts.Last()[0]}"
                  : (fullName.Length > 0 ? fullName.Substring(0, 1).ToUpper() : "U");
   var shortId = userId.Length > 5 ? userId.Substring(0, 5).ToUpper() : userId;
}

<!DOCTYPE html>
<html lang="vi">

<head>
   <meta charset="utf-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <title>@ViewData["Title"] - Candidate Portal</title>

   <link rel="preconnect" href="https://fonts.googleapis.com">
   <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
   <link
   href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
   rel="stylesheet">

   <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
   <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

   <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-green-50 text-gray-800 antialiased font-sans flex flex-col min-h-screen">

   <header class="bg-white shadow-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
         <div class="flex justify-between items-center h-20">
         
            <div class="flex items-center gap-8">
            
               <a href="/Home" class="group flex items-center gap-3 shrink-0">
                  <div
                     class="relative w-10 h-10 flex items-center justify-center bg-green-600 rounded-xl shadow-lg shadow-green-100 group-hover:bg-green-500 group-hover:rotate-6 transition-all duration-500">
                     <span class="text-white text-xl font-black">S</span>
                     <div
                        class="absolute inset-0 rounded-xl bg-gradient-to-tr from-green-400 to-emerald-300 blur-md opacity-0 group-hover:opacity-40 group-hover:scale-150 transition-all duration-500 -z-10">
                     </div>
                     <div
                        class="absolute inset-0 rounded-xl border border-green-400/50 scale-100 group-hover:scale-125 opacity-0 group-hover:opacity-100 transition-all duration-500">
                     </div>
                  </div>

                  <div class="flex flex-col justify-center">
                     <div class="flex items-center gap-1">
                        <span
                           class="text-2xl font-black tracking-tight text-gray-600 group-hover:text-green-600 transition-colors">
                           RB
                        </span>
                        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                     </div>
                     <p
                        class="text-[8px] font-bold uppercase tracking-[0.25em] text-gray-400 group-hover:text-green-700 transition-colors">
                        Staff Recruitment Hub
                     </p>
                  </div>
               </a>

               <nav class="hidden md:flex space-x-2">
                  <a href="/FindJobByID/Search"
                     class="px-4 py-2 text-sm font-semibold text-gray-600 rounded-lg hover:bg-green-50 hover:text-green-600 transition-all">
                     Việc làm
                  </a>
                  <a href="/Candidate/Profile"
                     class="px-4 py-2 text-sm font-semibold text-gray-600 rounded-lg hover:bg-green-50 hover:text-green-600 transition-all">
                     Hồ sơ & CV
                  </a>
                  <a href="/Business"
                     class="px-4 py-2 text-sm font-semibold text-gray-600 rounded-lg hover:bg-green-50 hover:text-green-600 transition-all">
                     Công ty
                  </a>
               </nav>
            </div>

            <div class="flex items-center gap-6">
               <div class="flex items-center gap-3">
               
                  <button
                     class="text-gray-500 hover:text-green-600 hover:bg-green-50 relative bg-gray-100 p-2 rounded-full h-10 w-10 flex items-center justify-center transition-all">
                     <i class="fa-regular fa-comment-dots text-lg"></i>
                  </button>
               
                  <button
                     class="text-gray-500 hover:text-green-600 hover:bg-green-50 relative bg-gray-100 p-2 rounded-full h-10 w-10 flex items-center justify-center transition-all">
                     <i class="fa-regular fa-bell text-lg"></i>
                     <span class="absolute top-0 right-0 flex h-3 w-3 mt-1 mr-1">
                        <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500 border-2 border-white"></span>
                     </span>
                  </button>

               </div>
            </div>

         </div>
      </div>
   </header>

   <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      @RenderBody()
   </main>

   <footer class="bg-white border-t border-gray-200 mt-auto">
      <div
         class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
         <p class="text-sm text-gray-500">&copy; @DateTime.Now.Year Staff Recruitment Hub.</p>
         <div class="flex space-x-6 text-sm font-medium text-gray-500">
            <a href="#" class="hover:text-green-600 transition">Quy định bảo mật</a>
            <a href="#" class="hover:text-green-600 transition">Thỏa thuận sử dụng</a>
            <a href="#" class="hover:text-green-600 transition">Quy chế hoạt động</a>
         </div>
      </div>
   </footer>

   @await RenderSectionAsync("Scripts", required: false)
</body>

</html>