<!DOCTYPE html>
<html lang="vi">

<head>
   <meta charset="utf-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <title>@ViewData["Title"] - Nền tảng Tuyển dụng</title>
   <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>

<body class="bg-gray-50 flex h-screen overflow-hidden font-sans text-gray-800">

   <aside class="w-[260px] bg-white border-r border-gray-200 flex flex-col z-20 shadow-sm">
      <div class="h-16 flex items-center px-6 border-b border-gray-100">
         <a href="/Business" class="flex items-center gap-2">
            <div class="w-8 h-8 bg-green-600 text-white rounded flex items-center justify-center font-bold text-lg">Z
            </div>
            <span class="text-xl font-bold text-gray-800 tracking-tight">Zeion<span
               class="text-green-600">Developer</span></span>
            </a>
         </div>
        
         @* <nav class="flex-1 py-6 px-4 space-y-2 overflow-y-auto">
            <p class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Quản lý chung</p>
            
            <a href="/Business/Index"
               class="flex items-center gap-3 px-3 py-2.5 bg-green-50 text-green-700 rounded-lg font-medium transition">
               <i class="fa-solid fa-chart-pie w-5 text-center"></i> Bảng tin
            </a>
            
            <a href="/Business/MyJobs"
               class="flex items-center gap-3 px-3 py-2.5 text-gray-600 hover:bg-gray-50 hover:text-green-600 rounded-lg font-medium transition">
               <i class="fa-solid fa-briefcase w-5 text-center"></i> Chiến dịch tuyển dụng
            </a>
            
            <a href="/Business/CVList"
               class="flex items-center gap-3 px-3 py-2.5 text-gray-600 hover:bg-gray-50 hover:text-green-600 rounded-lg font-medium transition">
               <i class="fa-solid fa-file-lines w-5 text-center"></i> Quản lý CV
            </a>

            <div class="pt-6 mt-6 border-t border-gray-100">
               <p class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Cài đặt</p>
               <a href="/Business/Profile"
                  class="flex items-center gap-3 px-3 py-2.5 text-gray-600 hover:bg-gray-50 rounded-lg font-medium transition">
                  <i class="fa-solid fa-building w-5 text-center"></i> Hồ sơ công ty
               </a>
            </div>
         </nav> *@
                  @{
            // Lấy tên Action (Trang) hiện tại đang truy cập
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

            // Hàm tự động trả về Class CSS (Màu xanh nếu đúng trang, Màu xám nếu khác trang)
            string GetActiveClass(params string[] actions)
            {
               return actions.Contains(currentAction) 
                     ? "bg-green-50 text-green-700" 
                     : "text-gray-600 hover:bg-gray-50 hover:text-green-600";
            }
         }

         <nav class="flex-1 py-6 px-4 space-y-2 overflow-y-auto">
            <p class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Quản lý chung</p>
            
            <a href="/Business/Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium transition @GetActiveClass("Index")">
               <i class="fa-solid fa-chart-pie w-5 text-center"></i> Bảng tin
            </a>
            
            <a href="/Business/MyJobs" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium transition @GetActiveClass("MyJobs", "PostJob")">
               <i class="fa-solid fa-briefcase w-5 text-center"></i> Chiến dịch tuyển dụng
            </a>
            
            <a href="/Business/CVList" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium transition @GetActiveClass("CVList")">
               <i class="fa-solid fa-file-lines w-5 text-center"></i> Quản lý CV
            </a>

            <div class="pt-6 mt-6 border-t border-gray-100">
               <p class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Cài đặt</p>
               <a href="/Business/Profile" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium transition @GetActiveClass("Profile")">
                     <i class="fa-solid fa-building w-5 text-center"></i> Hồ sơ công ty
               </a>
            </div>
         </nav>
      </aside>

      <div class="flex-1 flex flex-col relative overflow-hidden">
         <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 z-10">
            <h2 class="text-lg font-bold text-gray-800">@ViewData["Title"]</h2>
            
            <div class="flex items-center gap-6">
               <button class="text-gray-400 hover:text-green-600 transition"><i
                  class="fa-solid fa-bell text-xl"></i></button>
                  <div class="flex items-center gap-3 pl-6 border-l border-gray-200 cursor-pointer">
                     <img src="https://ui-avatars.com/api/?name=HR&background=0D8ABC&color=fff" alt="Avatar"
                          class="w-9 h-9 rounded-full border border-gray-200 shadow-sm" />
                     <div>
                        <p class="text-sm font-bold text-gray-700 leading-tight">HR Manager</p>
                        <p class="text-xs text-gray-500">Mã: NTD-12345</p>
                     </div>
                     <i class="fa-solid fa-chevron-down text-gray-400 text-xs ml-1"></i>
                  </div>
               </div>
            </header>

            <main class="flex-1 overflow-y-auto bg-[#f4f5f5] p-8">
               <div class="max-w-6xl mx-auto">
                  @RenderBody()
               </div>
            </main>
         </div>

         <script src="~/lib/jquery/dist/jquery.min.js"></script>
         @await RenderSectionAsync("Scripts", required: false)
      </body>

   </html>