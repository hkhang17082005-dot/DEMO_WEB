<!DOCTYPE html>
<html lang="vi">
<head>
   <meta charset="utf-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <title>Admin Dashboard - SRB</title>
   <script src="https://cdn.tailwindcss.com"></script>
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com" />
   <style>
      body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
      .sidebar-item:hover { background-color: #334155; color: #38bdf8; transition: all 0.3s; }
      .sidebar-active { background-color: #1e293b; border-left: 4px solid #38bdf8; color: #38bdf8; }
   </style>
</head>
<body class="flex h-screen overflow-hidden">

   <aside class="w-64 bg-[#0f172a] text-slate-300 shrink-0 hidden md:flex flex-col">
      <div class="p-6 text-white text-2xl font-bold border-b border-slate-700 flex items-center gap-2">
         <i class="fa-solid fa-layer-group text-sky-400"></i> Dashboard
      </div>

      <nav class="flex-1 mt-4 px-2 space-y-1">
         <a href="/manager/system/ManagerSystem/Index" class="sidebar-item sidebar-active flex items-center px-4 py-3 rounded-lg">
               <i class="fa-solid fa-chart-line w-6"></i> <span>Tổng quan</span>
         </a>
         <a href="/manager/business/list" class="sidebar-item flex items-center px-4 py-3 rounded-lg">
               <i class="fa-solid fa-building w-6"></i> <span>Quản lý Doanh nghiệp</span>
         </a>
         <a href="/manager/users" class="sidebar-item flex items-center px-4 py-3 rounded-lg">
               <i class="fa-solid fa-users w-6"></i> <span>Quản lý Người dùng</span>
         </a>
         <a href="/manager/jobs" class="sidebar-item flex items-center px-4 py-3 rounded-lg">
               <i class="fa-solid fa-briefcase w-6"></i> <span>Quản lý Tin tuyển dụng</span>
         </a>
         <div class="pt-4 pb-2 px-4 text-xs font-semibold text-slate-500 uppercase">Cài đặt hệ thống</div>
         <a href="/manager/settings" class="sidebar-item flex items-center px-4 py-3 rounded-lg">
               <i class="fa-solid fa-gear w-6"></i> <span>Cấu hình</span>
         </a>
      </nav>

      <div class="p-4 border-t border-slate-700">
         <a href="/auth/logout" class="flex items-center gap-2 text-rose-400 hover:text-rose-300 p-2">
               <i class="fa-solid fa-right-from-bracket"></i> Thoát hệ thống
         </a>
      </div>
   </aside>

   <div class="flex-1 flex flex-col overflow-y-auto">

      <header class="h-16 bg-white shadow-sm flex items-center justify-between px-8 sticky top-0 z-10">
         <div class="text-slate-500 italic">Chào mừng trở lại, quản trị viên!</div>
         <div class="flex items-center gap-4">
               <div class="text-right">
                  <p class="text-sm font-bold text-slate-700">Nguyen Quang Hung Ne</p>
                  <p class="text-xs text-sky-500">Super Admin</p>
               </div>
               <img class="h-10 w-10 rounded-full border-2 border-sky-100" src="https://ui-avatars.com" alt="Avatar">
         </div>
      </header>

      <main class="p-8">
         @RenderBody()
      </main>

   </div>

</body>
</html>
