<!-- ① FONT (bỏ qua nếu site đã load Google Fonts) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<!-- ② SCOPED STYLES — an toàn 100% -->
<style>
/* ── RESET chỉ bên trong .zd-footer ── */
.zd-footer *, .zd-footer *::before, .zd-footer *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ── WRAPPER ── */
.zd-footer {
  background: #f8f9fb;
  border-top: 3px solid #00b14f;
  font-family: 'Be Vietnam Pro', sans-serif;
  color: #374151;
  line-height: 1.6;
}

/* ── MAIN GRID ── */
.zd-footer__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 48px 40px 40px;
  display: grid;
  grid-template-columns: 260px 1fr 1fr 1fr 1fr;
  gap: 36px;
}

/* ────────────────────────────────
   CỘT BRAND
──────────────────────────────── */
.zd-footer__brand {}

/* Logo */
.zd-footer__logo {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  margin-bottom: 6px;
}
.zd-footer__logo-icon {
  width: 38px; height: 38px;
  background: linear-gradient(135deg, #a855f7, #ec4899);
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Be Vietnam Pro', sans-serif;
  font-size: 20px; font-weight: 700;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 3px 12px rgba(168,85,247,.35);
}
.zd-footer__logo-name {
  font-size: 20px;
  font-weight: 700;
  line-height: 1;
}
.zd-footer__logo-name .zn-z { 
  background: linear-gradient(90deg,#a855f7,#ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.zd-footer__logo-name .zn-d { color: #0ea5e9; }
.zd-footer__logo-spark { font-size: 11px; color: #0ea5e9; align-self: flex-start; margin-top: 2px; }

.zd-footer__tagline {
  font-size: 13px;
  color: #6b7280;
  margin-bottom: 16px;
  font-style: italic;
}

/* Badges */
.zd-footer__badges {
  display: flex; gap: 8px; flex-wrap: wrap;
  margin-bottom: 20px;
}
.zd-footer__badge {
  padding: 4px 10px;
  border-radius: 99px;
  font-size: 11px; font-weight: 600;
  text-transform: uppercase; letter-spacing: .4px;
}
.zd-footer__badge--green { background:#e6f9ef; color:#00b14f; border:1px solid #b7e9cc; }
.zd-footer__badge--blue  { background:#e0f2fe; color:#0284c7; border:1px solid #bae6fd; }

/* Liên hệ */
.zd-footer__contact-title {
  font-size: 13px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .8px;
  color: #111827;
  margin-bottom: 8px;
}
.zd-footer__contact-body {
  font-size: 13px; color: #6b7280;
  line-height: 1.9;
  margin-bottom: 20px;
}
.zd-footer__contact-body strong { color: #111827; font-weight: 600; }
.zd-footer__contact-body a { color: #00b14f; text-decoration: none; }
.zd-footer__contact-body a:hover { text-decoration: underline; }

/* App buttons */
.zd-footer__apps {
  display: flex; gap: 8px; flex-wrap: wrap;
  margin-bottom: 20px;
}
.zd-footer__app-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 8px 14px;
  border: 1.5px solid #d1d5db;
  border-radius: 10px;
  background: #fff;
  text-decoration: none;
  color: #111827;
  font-family: 'Be Vietnam Pro', sans-serif;
  font-size: 11px;
  transition: border-color .2s, box-shadow .2s;
  cursor: pointer;
}
.zd-footer__app-btn:hover {
  border-color: #00b14f;
  box-shadow: 0 2px 8px rgba(0,177,79,.15);
}
.zd-footer__app-btn svg { width: 18px; height: 18px; flex-shrink: 0; }
.zd-footer__app-btn-text em  { display: block; font-style: normal; font-size: 9px; color: #9ca3af; line-height: 1; }
.zd-footer__app-btn-text strong { display: block; font-size: 12px; font-weight: 600; line-height: 1.4; }

/* Social label */
.zd-footer__soc-label {
  font-size: 13px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .8px;
  color: #111827;
  margin-bottom: 10px;
}
.zd-footer__socials {
  display: flex; gap: 8px;
}
.zd-footer__soc-btn {
  width: 34px; height: 34px;
  border-radius: 8px;
  border: 1.5px solid #e5e7eb;
  background: #fff;
  display: flex; align-items: center; justify-content: center;
  color: #6b7280;
  text-decoration: none;
  transition: all .2s;
  cursor: pointer;
}
.zd-footer__soc-btn svg { width: 15px; height: 15px; fill: currentColor; }
.zd-footer__soc-btn:hover { border-color: #00b14f; color: #00b14f; background: #e6f9ef; transform: translateY(-2px); }

/* ────────────────────────────────
   CỘT LINK
──────────────────────────────── */
.zd-footer__col {}

.zd-footer__col-title {
  font-size: 14px; font-weight: 700;
  color: #111827;
  text-transform: uppercase; letter-spacing: .6px;
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 2px solid #e5e7eb;
  position: relative;
}
.zd-footer__col-title::after {
  content: '';
  position: absolute;
  bottom: -2px; left: 0;
  width: 28px; height: 2px;
  background: #00b14f;
  border-radius: 2px;
}

.zd-footer__links {
  list-style: none;
  margin: 0; padding: 0;
}
.zd-footer__links li {
  margin-bottom: 8px;
}
.zd-footer__links li a {
  font-size: 13.5px;
  color: #4b5563;
  text-decoration: none;
  display: inline-block;
  transition: color .15s, padding-left .15s;
  font-family: 'Be Vietnam Pro', sans-serif;
}
.zd-footer__links li a:hover {
  color: #00b14f;
  padding-left: 4px;
}

.zd-footer__col-gap { margin-top: 22px; }

/* ────────────────────────────────
   BOTTOM BAR
──────────────────────────────── */
.zd-footer__bottom {
  background: #111827;
  padding: 18px 40px;
}
.zd-footer__bottom-inner {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
}
.zd-footer__copy {
  font-size: 12.5px;
  color: #9ca3af;
  font-family: 'Be Vietnam Pro', sans-serif;
}
.zd-footer__copy a { color: #9ca3af; text-decoration: none; }
.zd-footer__copy a:hover { color: #00b14f; }

.zd-footer__bottom-links {
  display: flex; gap: 18px; list-style: none;
  margin: 0; padding: 0;
}
.zd-footer__bottom-links li a {
  font-size: 12px;
  color: #6b7280;
  text-decoration: none;
  font-family: 'Be Vietnam Pro', sans-serif;
  transition: color .15s;
}
.zd-footer__bottom-links li a:hover { color: #00b14f; }

/* ────────────────────────────────
   RESPONSIVE
──────────────────────────────── */
@@media (max-width: 1024px) {
  .zd-footer__inner { grid-template-columns: 230px 1fr 1fr 1fr 1fr; }
}
@@media (max-width: 860px) {
  .zd-footer__inner { grid-template-columns: 1fr 1fr 1fr; }
  .zd-footer__brand { grid-column: 1 / -1; }
}
@@media (max-width: 580px) {
  .zd-footer__inner { grid-template-columns: 1fr 1fr; padding: 32px 20px 24px; }
  .zd-footer__bottom { padding: 14px 20px; }
}
</style>

