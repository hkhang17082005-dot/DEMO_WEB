@using SRB_ViewModel.Data
@using SRB_WebPortal.Consts
@using SRB_WebPortal.Controllers.apis.auth
@{
   TokenPayload? session = Context.Items[key: ServerKey.CONTEXT_ITEM_TOKEN_INFO] as TokenPayload;

   @* Todo: Thêm các Role liên quan để có thể thấy Button Tuyển dụng *@
   string[]? allowedRoles = new[] {
      Roles.ADMIN,
      Roles.BUSINESS_MANAGER,
      Roles.HIRING_MANAGER
   };

   bool canViewBusinessLink = session != null && !string.IsNullOrEmpty(session.User.BusinessID) &&
      session.User.RoleSlugs.Any(userRole => allowedRoles.Contains(userRole));
}

@if (canViewBusinessLink)
{
   <a href="/Business/Index"
      class="items-center hidden gap-1 px-4 py-2 mr-2 text-sm font-semibold text-blue-600 transition-all duration-200 border border-blue-200 rounded-lg md:flex hover:text-blue-700 hover:bg-blue-50">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
               d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
         </path>
      </svg>
      Nhà tuyển dụng
   </a>
}
else if (session != null)
{
   <a href="/Candidate/Index"
      class="items-center hidden gap-1 px-4 py-2 mr-2 text-sm font-semibold transition-all duration-200 border rounded-lg text-emerald-600 border-emerald-200 md:flex hover:text-emerald-700 hover:bg-emerald-50">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
               d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z">
         </path>
      </svg>
      Hồ sơ của tôi
   </a>
}
