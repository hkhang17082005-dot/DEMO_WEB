@using SRB_ViewModel.Data
@using SRB_WebPortal.Consts
@using SRB_WebPortal.Controllers.apis.auth
@{
   TokenPayload? session = Context.Items[key: ServerKey.CONTEXT_ITEM_TOKEN_INFO] as TokenPayload;

   string[]? allowedRoles = new[] {
      Roles.ADMIN,
      Roles.BUSINESS_MANAGER,
      Roles.HIRING_MANAGER
   };

   bool isManagerBusiness = session != null && !string.IsNullOrEmpty(session.User.BusinessID) &&
      session.User.RoleSlugs.Any(userRole => allowedRoles.Contains(userRole));
}

@if (session == null)
{
   <a href="/login"
      class="text-gray-600 hover:text-green-600 px-4 py-2 text-sm font-semibold transition-all duration-200 rounded-lg hover:bg-green-50">
      Đăng nhập
   </a>
   <a href="/register" class="
      bg-linear-to-r from-emerald-500 to-teal-600
      text-white px-6 py-2.5 text-sm font-bold rounded-xl
      shadow-md shadow-emerald-100
      hover:from-emerald-600 hover:to-teal-700
      hover:shadow-lg hover:shadow-emerald-200
      transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95
      ">
      Đăng ký
   </a>
}
else
{
   <div class="relative flex items-center gap-4 group">
      <button
         class="flex items-center gap-2 px-3 py-2 rounded-xl hover:bg-gray-100 transition-all duration-200 cursor-pointer">
         <div
            class="w-8 h-8 rounded-full bg-linear-to-tr from-purple-600 to-pink-500 flex items-center justify-center text-white text-xs font-bold shadow-sm">
            @session.User.Username.Substring(0, 1).ToUpper()
         </div>
         <div class="text-left hidden sm:block">
            <p class="text-xs text-gray-500 leading-none">Xin chào,</p>
            <p class="text-sm font-semibold text-gray-800">@session.User.Username</p>
         </div>
         <i
         class="fa-solid fa-chevron-down text-[10px] text-gray-400 group-hover:rotate-180 transition-transform duration-300"></i>
      </button>

      <div
         class="absolute right-0 top-full mt-2 w-56 bg-white border border-gray-100 rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 py-2">

         <div class="px-4 py-2 border-b border-gray-50 mb-1">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Tài khoản</p>
         </div>

         <a href="/candidate/profile"
            class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-600 transition-colors">
            <i class="fa-solid fa-circle-user w-4 text-center"></i> Hồ sơ cá nhân
         </a>

         @if (!string.IsNullOrEmpty(session.User.BusinessID) && isManagerBusiness)
         {
            <a href="/manager/ManageBusiness/index"
               class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-600 transition-colors">
               <i class="fa-solid fa-gauge-high w-4 text-center"></i> Dashboard Quản trị
            </a>
         }
         else if (string.IsNullOrEmpty(session.User.BusinessID))
         {
            <a href="/business/RegisterBusiness"
               class="flex items-center gap-3 px-4 py-2.5 text-sm text-purple-600 font-medium hover:bg-purple-50 transition-colors">
               <i class="fa-solid fa-plus-circle w-4 text-center"></i> Đăng ký Doanh nghiệp
            </a>
         }

         <a href="/settings"
            class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-600 transition-colors">
            <i class="fa-solid fa-key w-4 text-center"></i> Đổi mật khẩu
         </a>

         <div class="h-px bg-gray-100 my-1"></div>

         <button onclick="handleLogout()"
                 class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors cursor-pointer">
            <i class="fa-solid fa-right-from-bracket w-4 text-center"></i> Đăng xuất
         </button>
      </div>
   </div>
}

<script type="module">
   import authService from '/js/services/authService.js';

   async function handleLogout() {
   try {
   await authService.logout();

   window.location.href = '/';

   } catch (error) {
   console.error("Logout Error:", error.message);

   window.location.href = '/';

   }
   }

   window.handleLogout = handleLogout;
</script>

