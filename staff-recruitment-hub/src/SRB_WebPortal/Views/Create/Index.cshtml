@{
    ViewData["Title"] = "CV Builder Pro";
}

<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); }
        /* Tỉ lệ A4 chuẩn */
        #cv { width: 210mm; min-height: 297mm; background: white; margin: 0 auto; overflow: hidden; }
        /* Ẩn thanh cuộn nhưng vẫn cuộn được */
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-100 to-blue-100">

    <div class="max-w-[1600px] mx-auto p-4 lg:p-8">
        <header class="flex items-center justify-between mb-8">
            <h1 class="text-3xl font-extrabold tracking-tight text-indigo-900">CV<span class="text-indigo-600">BUILDER</span></h1>
            <div class="flex gap-4">
                <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-full shadow-sm">
                    <spans class="text-sm font-medium">Màu chủ đạo:</spans>
                    <input type="color" id="themeColor" value="#4f46e5" class="w-8 h-8 border-none cursor-pointer">
                </div>
                <button onclick="downloadPDF()" class="px-6 py-2 font-bold text-white transition bg-indigo-600 rounded-full shadow-lg hover:bg-indigo-700 hover:scale-105">
                    Tải PDF
                </button>
            </div>
        </header>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
            
            <div class="space-y-6 lg:col-span-4 max-h-[85vh] overflow-y-auto pr-2 no-scrollbar">
                
                <div class="p-6 shadow-sm glass rounded-3xl border border-white/50">
                    <h2 class="mb-4 text-xl font-bold text-gray-800">Thông tin cá nhân</h2>
                    <div class="space-y-4">
                        <div class="flex items-center gap-4">
                            <label class="flex flex-col items-center justify-center w-20 h-20 border-2 border-dashed border-gray-300 rounded-full cursor-pointer hover:border-indigo-400">
                                <span class="text-[10px] text-center">Ảnh 3x4</span>
                                <input type="file" id="avatar" accept="image/*" class="hidden">
                            </label>
                            <div class="flex-1">
                                <input id="name" type="text" placeholder="Họ và tên" class="w-full p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">
                            </div>
                        </div>
                        <input id="job" type="text" placeholder="Vị trí ứng tuyển" class="w-full p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">
                        <div class="grid grid-cols-2 gap-3">
                            <input id="email" type="email" placeholder="Email" class="w-full p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">
                            <input id="phone" type="text" placeholder="Số điện thoại" class="w-full p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">
                        </div>
                        <textarea id="about" placeholder="Giới thiệu bản thân..." class="w-full p-3 border rounded-xl h-28 focus:ring-2 focus:ring-indigo-400 outline-none"></textarea>
                    </div>
                </div>

                <div class="p-6 shadow-sm glass rounded-3xl border border-white/50">
                    <h2 class="mb-2 text-lg font-bold text-gray-800">Kỹ năng & Học vấn</h2>
                    <p class="mb-4 text-xs text-gray-500 italic">* Nhấn Enter để xuống dòng cho mỗi mục</p>
                    <textarea id="skills" placeholder="Kỹ năng (Ví dụ: HTML, CSS, C#)" class="w-full p-3 mb-4 border rounded-xl h-24 focus:ring-2 focus:ring-indigo-400 outline-none"></textarea>
                    <textarea id="education" placeholder="Học vấn (Trường - Ngành - Năm)" class="w-full p-3 border rounded-xl h-24 focus:ring-2 focus:ring-indigo-400 outline-none"></textarea>
                </div>

                <div class="p-6 shadow-sm glass rounded-3xl border border-white/50">
                    <h2 class="mb-4 text-lg font-bold text-gray-800">Kinh nghiệm làm việc</h2>
                    <textarea id="experience" placeholder="Mô tả kinh nghiệm của bạn..." class="w-full p-3 border rounded-xl h-40 focus:ring-2 focus:ring-indigo-400 outline-none"></textarea>
                </div>

            </div>

            <div class="lg:col-span-8 bg-slate-300/30 rounded-3xl p-4 lg:p-8 flex justify-center overflow-x-auto border border-gray-200">
                
                <div id="cv" class="shadow-2xl shadow-indigo-200/50">
                    <div id="cvHeader" class="p-10 text-white flex items-center gap-8 transition-colors duration-300" style="background-color: #4f46e5;">
                        <img id="cvAvatar" src="https://via.placeholder.com/150" class="w-32 h-32 object-cover border-4 border-white/30 rounded-full shadow-inner">
                        <div>
                            <h2 id="cvNameDisplay" class="text-4xl font-bold uppercase tracking-wide">Họ tên của bạn</h2>
                            <p id="cvJobDisplay" class="text-xl opacity-90 font-medium mt-1">Vị trí ứng tuyển</p>
                            <div class="mt-4 flex flex-wrap gap-4 text-sm opacity-80">
                                <span id="cvEmailDisplay">Email: ---</span>
                                <span id="cvPhoneDisplay">SĐT: ---</span>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-12 min-h-[200mm]">
                        <div class="col-span-4 bg-slate-50 p-8 space-y-8 border-r border-gray-100">
                            <div>
                                <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Kỹ năng</h3>
                                <div id="cvSkillsList" class="flex flex-wrap gap-2">
                                    </div>
                            </div>
                            <div>
                                <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Học vấn</h3>
                                <div id="cvEduList" class="space-y-4 text-gray-700 text-sm leading-relaxed">
                                    </div>
                            </div>
                        </div>

                        <div class="col-span-8 p-10 space-y-10">
                            <div>
                                <h3 class="text-lg font-bold mb-3 flex items-center gap-2">
                                    <span class="w-8 h-[2px] bg-indigo-600 theme-bg"></span> Giới thiệu
                                </h3>
                                <p id="cvAboutDisplay" class="text-gray-600 leading-relaxed text-sm"></p>
                            </div>
                            <div>
                                <h3 class="text-lg font-bold mb-3 flex items-center gap-2">
                                    <span class="w-8 h-[2px] bg-indigo-600 theme-bg"></span> Kinh nghiệm làm việc
                                </h3>
                                <div id="cvExpList" class="space-y-6 text-gray-700 text-sm leading-relaxed">
                                    </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        // Lắng nghe thay đổi Input để cập nhật Real-time
        const inputs = ['name', 'job', 'email', 'phone', 'about', 'skills', 'education', 'experience'];
        inputs.forEach(id => {
            document.getElementById(id).addEventListener('input', updateCV);
        });

        // Xử lý ảnh đại diện
        document.getElementById('avatar').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (event) => document.getElementById('cvAvatar').src = event.target.result;
                reader.readAsDataURL(file);
            }
        });

        // Xử lý đổi màu Theme
        document.getElementById('themeColor').addEventListener('input', function(e) {
            const color = e.target.value;
            document.getElementById('cvHeader').style.backgroundColor = color;
            document.querySelectorAll('.theme-bg').forEach(el => el.style.backgroundColor = color);
        });

        function updateCV() {
            // Update Text đơn giản
            document.getElementById('cvNameDisplay').innerText = document.getElementById('name').value || "HỌ TÊN CỦA BẠN";
            document.getElementById('cvJobDisplay').innerText = document.getElementById('job').value || "Vị trí ứng tuyển";
            document.getElementById('cvEmailDisplay').innerText = "Email: " + (document.getElementById('email').value || "---");
            document.getElementById('cvPhoneDisplay').innerText = "SĐT: " + (document.getElementById('phone').value || "---");
            document.getElementById('cvAboutDisplay').innerText = document.getElementById('about').value;

            // Update Skills (Dạng tag)
            const skillLines = document.getElementById('skills').value.split('\n');
            const skillContainer = document.getElementById('cvSkillsList');
            skillContainer.innerHTML = '';
            skillLines.forEach(s => {
                if(s.trim()) {
                    const span = document.createElement('span');
                    span.className = "px-3 py-1 bg-white border border-gray-200 rounded text-xs font-medium shadow-sm";
                    span.innerText = s;
                    skillContainer.appendChild(span);
                }
            });

            // Update Lists (Học vấn & Kinh nghiệm)
            renderList('education', 'cvEduList');
            renderList('experience', 'cvExpList');
        }

        function renderList(inputId, outputId) {
            const lines = document.getElementById(inputId).value.split('\n');
            const container = document.getElementById(outputId);
            container.innerHTML = '';
            lines.forEach(line => {
                if(line.trim()) {
                    const p = document.createElement('p');
                    p.className = "relative pl-4 before:content-['•'] before:absolute before:left-0 before:text-indigo-500";
                    p.innerText = line;
                    container.appendChild(p);
                }
            });
        }

        function downloadPDF() {
            const element = document.getElementById('cv');
            const opt = {
                margin: 0,
                filename: 'My_Professional_CV.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };
            html2pdf().set(opt).from(element).save();
        }

        // Khởi tạo ban đầu
        updateCV();
    </script>
</body>