@{
   ViewData["Title"] = "Tạo CV";
}

<body class="min-h-screen bg-linear-to-br from-indigo-100 via-purple-100 to-pink-100">

   <div class="p-6 mx-auto max-w-7xl">

      <h1
         class="mb-10 text-4xl font-bold text-center text-transparent bg-linear-to-r from-indigo-600 to-purple-600 bg-clip-text">
         CV BUILDER PRO
      </h1>

      <div class="grid gap-8 lg:grid-cols-2">

         <!-- FORM -->
         <div class="p-6 shadow-xl glass rounded-3xl">

            <h2 class="mb-4 text-lg font-semibold">Thông tin cá nhân</h2>

            <input id="name" class="w-full p-3 mb-3 border rounded-xl focus:ring-2 focus:ring-indigo-400"
                   placeholder="Họ và tên">
            <input id="job" class="w-full p-3 mb-3 border rounded-xl focus:ring-2 focus:ring-indigo-400"
                   placeholder="Vị trí">
            <input id="email" class="w-full p-3 mb-3 border rounded-xl focus:ring-2 focus:ring-indigo-400"
                   placeholder="Email">
            <input id="phone" class="w-full p-3 mb-3 border rounded-xl focus:ring-2 focus:ring-indigo-400"
                   placeholder="SĐT">

            <textarea id="about" class="w-full p-3 mb-3 border rounded-xl focus:ring-2 focus:ring-indigo-400"
                      placeholder="Giới thiệu"></textarea>

            <h2 class="mt-4 mb-2 font-semibold">Kỹ năng</h2>
            <textarea id="skills" class="w-full p-3 mb-3 border rounded-xl focus:ring-2 focus:ring-indigo-400"
                      placeholder="Mỗi kỹ năng 1 dòng"></textarea>

            <h2 class="mt-4 mb-2 font-semibold">Kinh nghiệm</h2>
            <textarea id="experience" class="w-full p-3 mb-3 border rounded-xl focus:ring-2 focus:ring-indigo-400"
                      placeholder="Mỗi kinh nghiệm 1 dòng"></textarea>

            <h2 class="mt-4 mb-2 font-semibold">Học vấn</h2>
            <textarea id="education" class="w-full p-3 mb-3 border rounded-xl focus:ring-2 focus:ring-indigo-400"
                      placeholder="Mỗi học vấn 1 dòng"></textarea>

            <h2 class="mt-4 mb-2 font-semibold">Ảnh đại diện</h2>
            <input type="file" id="avatar" accept="image/*" class="mb-4">

            <button onclick="downloadPDF()"
                    class="w-full py-3 text-white transition shadow-lg bg-linear-to-r from-indigo-600 to-purple-600 rounded-xl hover:scale-105">
               Xuất PDF
            </button>

         </div>

         <!-- CV PREVIEW -->
         <div id="cv" class="mx-auto bg-white shadow-2xl" style="width:210mm; min-height:297mm;">

            <!-- HEADER -->
            <div class="p-8 text-white bg-linear-to-r from-indigo-600 to-purple-600">

               <div class="flex items-center gap-6">
                  <img id="cvAvatar" src="https://via.placeholder.com/120"
                       class="object-cover border-4 border-white rounded-full shadow-lg w-28 h-28">

                  <div>
                     <h2 id="cvName" class="text-3xl font-bold">Họ tên</h2>
                     <p id="cvJob" class="text-lg text-indigo-200">Vị trí ứng tuyển</p>
                  </div>
               </div>

               <div class="mt-6 space-y-1 text-sm">
                  <p>Email: <span id="cvEmail"></span></p>
                  <p>Phone: <span id="cvPhone"></span></p>
               </div>

            </div>

            <!-- BODY -->
            <div class="grid md:grid-cols-3">

               <!-- LEFT COLUMN -->
               <div class="p-6 space-y-6 bg-gray-50">

                  <div>
                     <h3 class="mb-2 font-semibold text-indigo-600">Kỹ năng</h3>
                     <div id="cvSkills" class="flex flex-wrap gap-2"></div>
                  </div>

                  <div>
                     <h3 class="mb-2 font-semibold text-indigo-600">Học vấn</h3>
                     <ul id="cvEducation" class="space-y-1 text-gray-700 list-disc list-inside"></ul>
                  </div>

               </div>

               <!-- RIGHT COLUMN -->
               <div class="p-6 space-y-6 md:col-span-2">

                  <div>
                     <h3 class="mb-2 font-semibold text-indigo-600">Giới thiệu</h3>
                     <p id="cvAbout" class="leading-relaxed text-gray-700"></p>
                  </div>

                  <div>
                     <h3 class="mb-2 font-semibold text-indigo-600">Kinh nghiệm</h3>
                     <ul id="cvExperience" class="space-y-1 text-gray-700 list-disc list-inside"></ul>
                  </div>

               </div>

            </div>

         </div>

      </div>
   </div>

   <script>

         // REALTIME UPDATE
         document.querySelectorAll("input, textarea").forEach(el => {
            el.addEventListener("input", updateCV);
         });

         function updateList(inputId, outputId) {
            let lines = document.getElementById(inputId).value.split("\n");
            let ul = document.getElementById(outputId);
            ul.innerHTML = "";
            lines.forEach(line => {
               if (line.trim() !== "") {
                  let li = document.createElement("li");
                  li.textContent = line;
                  ul.appendChild(li);
               }
            });
         }

         function updateSkills() {
            let lines = document.getElementById("skills").value.split("\n");
            let container = document.getElementById("cvSkills");
            container.innerHTML = "";
            lines.forEach(line => {
               if (line.trim() !== "") {
                  let span = document.createElement("span");
                  span.textContent = line;
                  span.className = "bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-sm";
                  container.appendChild(span);
               }
            });
         }

         function updateCV() {

            document.getElementById("cvName").innerText =
               document.getElementById("name").value;

            document.getElementById("cvJob").innerText =
               document.getElementById("job").value;

            document.getElementById("cvEmail").innerText =
               document.getElementById("email").value;

            document.getElementById("cvPhone").innerText =
               document.getElementById("phone").value;

            document.getElementById("cvAbout").innerText =
               document.getElementById("about").value;

            updateSkills();
            updateList("experience", "cvExperience");
            updateList("education", "cvEducation");

            let file = document.getElementById("avatar").files[0];
            if (file) {
               let reader = new FileReader();
               reader.onload = e => {
                  document.getElementById("cvAvatar").src = e.target.result;
               }
               reader.readAsDataURL(file);
            }

         }
         function downloadPDF() {

            const element = document.getElementById("cv");

            const opt = {
               margin: 0,
               filename: 'CV.pdf',
               image: { type: 'jpeg', quality: 1 },
               html2canvas: { scale: 2, useCORS: true },
               jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
               pagebreak: { mode: ['avoid-all', 'css', 'legacy'] }
            };

            html2pdf().set(opt).from(element).save();
         }

   </script>

</body>
