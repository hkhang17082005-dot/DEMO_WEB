<!-- Cập nhật x-data để bao gồm cả trạng thái loading -->
<div x-data="{ open: false, loading: false }" @@open-modal.window="if($event.detail.id === '@Model') open = true"
     x-show="open" style="display: none;" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">

   <!-- Modal Content -->
   <div @@click.away="open = false" class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden">
      <div class="p-6">
         <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-bold text-gray-800">Ứng tuyển công việc</h3>
            <button @@click="open = false" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
         </div>

         <form x-on:submit.prevent="submitForm($event, $data)">
            <input type="hidden" name="JobPostID" value="@Model" />

            <div class="space-y-4">
               <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên</label>
                  <input type="text" name="FullName" required
                         class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none">
               </div>

               <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Tải lên CV (PDF/Docx)</label>
                  <input type="file" name="CVFile" required
                         class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100">
               </div>
            </div>

            <button type="submit" :disabled="loading"
                    class="w-full mt-6 bg-emerald-600 text-white font-bold py-3 rounded-xl hover:bg-emerald-700 transition-colors disabled:opacity-50">
               <span x-show="!loading">GỬI HỒ SƠ NGAY</span>
               <span x-show="loading">ĐANG XỬ LÝ...</span>
            </button>
         </form>
      </div>
   </div>
</div>

<script type="module">
   import postService from '/js/services/postService.js';

   window.submitForm = async function (e, state) {
   if (e) e.preventDefault();

   const formData = new FormData(e.target);

   state.loading = true;

   try {
   const response = await postService.applyJobPost(formData);

   if (response.isSuccess) {
   alert("Gửi thành công!");
   state.open = false;
   e.target.reset();
   window.location.href = '/';
   } else {
   const err = await response.text();
   console.error(err);
   alert("Lỗi API");
   }
   } catch (err) {
   console.error(err);
   alert("Lỗi kết nối");
   } finally {
   state.loading = false;
   }
   }
</script>

