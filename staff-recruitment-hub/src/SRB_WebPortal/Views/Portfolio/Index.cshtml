@{
    ViewData["Title"] = "Dự án";
}

<div class="min-h-screen bg-gray-50">

    <!-- Hero -->
    <section class="bg-gradient-to-br from-green-600 to-emerald-700 py-16">
        <div class="max-w-6xl mx-auto px-6 text-center">
            <span class="inline-block bg-white/20 text-white text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-4">
                🚀 Dự án & Thành tựu
            </span>
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4">Những gì chúng tôi đã xây dựng</h1>
            <p class="text-green-100 text-lg max-w-xl mx-auto">
                Khám phá các dự án và tính năng nổi bật mà chúng tôi đã phát triển để giúp hàng triệu ứng viên tìm được việc làm phù hợp.
            </p>
        </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 py-14">

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-14">
            <div class="bg-white rounded-2xl p-6 text-center shadow-sm border border-gray-100 hover:shadow-md transition">
                <div class="text-3xl font-black text-green-600 mb-1">41K+</div>
                <div class="text-gray-500 text-sm">Việc làm đăng tải</div>
            </div>
            <div class="bg-white rounded-2xl p-6 text-center shadow-sm border border-gray-100 hover:shadow-md transition">
                <div class="text-3xl font-black text-blue-600 mb-1">5K+</div>
                <div class="text-gray-500 text-sm">Doanh nghiệp</div>
            </div>
            <div class="bg-white rounded-2xl p-6 text-center shadow-sm border border-gray-100 hover:shadow-md transition">
                <div class="text-3xl font-black text-purple-600 mb-1">100K+</div>
                <div class="text-gray-500 text-sm">Ứng viên đăng ký</div>
            </div>
            <div class="bg-white rounded-2xl p-6 text-center shadow-sm border border-gray-100 hover:shadow-md transition">
                <div class="text-3xl font-black text-orange-600 mb-1">98%</div>
                <div class="text-gray-500 text-sm">Hài lòng</div>
            </div>
        </div>

        <!-- Projects -->
        <div class="text-center mb-10">
            <h2 class="text-3xl font-black text-gray-900 mb-3">Dự án nổi bật</h2>
            <p class="text-gray-500">Các tính năng và module chúng tôi đã phát triển</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-14">

            <!-- Project 1 -->
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="h-48 bg-gradient-to-br from-green-500 to-emerald-400 flex items-center justify-center text-6xl">🔍</div>
                <div class="p-7">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="bg-green-100 text-green-700 text-xs font-bold px-3 py-1 rounded-full">Web App</span>
                        <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full">ASP.NET MVC</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Hệ thống tìm kiếm việc làm</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-5">Nền tảng tìm việc thông minh với khả năng lọc theo kỹ năng, địa điểm, mức lương và gợi ý việc làm phù hợp.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">C#</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">SQL Server</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">Tailwind CSS</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">Redis</span>
                    </div>
                </div>
            </div>

            <!-- Project 2 -->
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="h-48 bg-gradient-to-br from-blue-500 to-indigo-400 flex items-center justify-center text-6xl">📄</div>
                <div class="p-7">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="bg-green-100 text-green-700 text-xs font-bold px-3 py-1 rounded-full">Web App</span>
                        <span class="bg-purple-100 text-purple-700 text-xs font-bold px-3 py-1 rounded-full">PDF Export</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Công cụ tạo CV trực tuyến</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-5">Tạo CV chuyên nghiệp với nhiều mẫu đẹp, hỗ trợ xuất PDF chất lượng cao và lưu trữ trên cloud.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">C#</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">Cloudinary</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">JavaScript</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">HTML/CSS</span>
                    </div>
                </div>
            </div>

            <!-- Project 3 -->
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="h-48 bg-gradient-to-br from-purple-500 to-pink-400 flex items-center justify-center text-6xl">💳</div>
                <div class="p-7">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="bg-green-100 text-green-700 text-xs font-bold px-3 py-1 rounded-full">Payment</span>
                        <span class="bg-orange-100 text-orange-700 text-xs font-bold px-3 py-1 rounded-full">Integration</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Hệ thống thanh toán tích hợp</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-5">Tích hợp cổng thanh toán MoMo và VNPay, hỗ trợ nâng cấp gói dịch vụ Premium an toàn và bảo mật.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">MoMo API</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">VNPay</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">HMAC-SHA256</span>
                    </div>
                </div>
            </div>

            <!-- Project 4 -->
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="h-48 bg-gradient-to-br from-orange-500 to-yellow-400 flex items-center justify-center text-6xl">🔐</div>
                <div class="p-7">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="bg-green-100 text-green-700 text-xs font-bold px-3 py-1 rounded-full">Security</span>
                        <span class="bg-red-100 text-red-700 text-xs font-bold px-3 py-1 rounded-full">Auth</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Hệ thống xác thực & bảo mật</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-5">Xác thực JWT, phân quyền theo vai trò (ứng viên/nhà tuyển dụng), đăng nhập Google & GitHub OAuth.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">JWT</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">OAuth 2.0</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-lg">Redis Cache</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Team -->
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-10 text-center">
            <h2 class="text-3xl font-black text-gray-900 mb-3">Đội ngũ phát triển</h2>
            <p class="text-gray-500 mb-10">Những người đã xây dựng nên Zeion Developer</p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                <div class="group">
                    <div class="w-20 h-20 bg-gradient-to-br from-green-400 to-emerald-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3 group-hover:scale-110 transition-transform">👨‍💻</div>
                    <p class="font-bold text-gray-900 text-sm">Thành viên 1</p>
                    <p class="text-gray-400 text-xs">Backend Developer</p>
                </div>
                <div class="group">
                    <div class="w-20 h-20 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3 group-hover:scale-110 transition-transform">👨‍🎨</div>
                    <p class="font-bold text-gray-900 text-sm">Thành viên 2</p>
                    <p class="text-gray-400 text-xs">Frontend Developer</p>
                </div>
                <div class="group">
                    <div class="w-20 h-20 bg-gradient-to-br from-purple-400 to-pink-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3 group-hover:scale-110 transition-transform">👩‍💻</div>
                    <p class="font-bold text-gray-900 text-sm">Thành viên 3</p>
                    <p class="text-gray-400 text-xs">Full Stack Developer</p>
                </div>
                <div class="group">
                    <div class="w-20 h-20 bg-gradient-to-br from-orange-400 to-yellow-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3 group-hover:scale-110 transition-transform">👨‍💼</div>
                    <p class="font-bold text-gray-900 text-sm">Thành viên 4</p>
                    <p class="text-gray-400 text-xs">Project Manager</p>
                </div>
            </div>
        </div>

    </div>
</div>
