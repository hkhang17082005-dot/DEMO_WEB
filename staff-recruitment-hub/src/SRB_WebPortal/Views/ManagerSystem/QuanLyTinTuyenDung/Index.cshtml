@model IEnumerable<SRB_ViewModel.Entities.JobPost>
@{
    Layout = "_DashboardLayout";
}

<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Quản lý Tin tuyển dụng</h1>
        <p class="text-slate-500 mt-1">Theo dõi, phê duyệt và quản lý các cơ hội việc làm trên hệ thống.</p>
    </div>
    <div class="flex items-center gap-3">
        <span class="px-3 py-1 bg-sky-50 text-sky-700 rounded-full text-sm font-medium border border-sky-100">
            Tổng cộng: @Model.Count() tin
        </span>
    </div>
</div>

<div class="bg-white border border-slate-200 shadow-sm rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50/50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">Thông tin tin đăng</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">Doanh nghiệp</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">Hạn chót</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">Trạng thái</th>
                    <th class="px-6 py-4 text-right text-xs font-bold text-slate-500 uppercase tracking-wider">Thao tác</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-slate-200">
                @foreach (var post in Model)
                {
                    <tr class="hover:bg-slate-50/80 transition-colors duration-150 group">
                        <td class="px-6 py-4">
                            <div class="font-semibold text-slate-800 group-hover:text-sky-600 transition-colors">@post.Title</div>
                            <div class="text-xs text-slate-400 mt-0.5">ID: #@post.JobPostID.ToString().Substring(0,8)</div>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600">
                            <div class="flex items-center">
                                <span class="w-8 h-8 rounded bg-slate-100 flex items-center justify-center mr-3 text-slate-400">
                                    <i class="fa-regular fa-building"></i>
                                </span>
                                @(post.Business?.BusinessName ?? "N/A")
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600">
                            <span class="inline-flex items-center">
                                <i class="fa-regular fa-calendar-alt mr-2 opacity-50"></i>
                                @post.ExpiryDate.ToString("dd/MM/yyyy")
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            @if (post.IsActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 border border-emerald-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5"></span>
                                    Đã duyệt
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 border border-amber-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mr-1.5"></span>
                                    Chờ duyệt
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 text-right text-sm font-medium">
                            <div class="flex justify-end gap-2">
                                <form asp-controller="JobPosts" asp-action="ToggleApproval" asp-route-id="@post.JobPostID" method="post" onsubmit="return confirm('Xác nhận thay đổi trạng thái?')">
                                    <button type="submit" class="inline-flex items-center px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-700 hover:bg-sky-50 hover:text-sky-700 hover:border-sky-200 transition-all shadow-sm">
                                        <i class="fa-solid @(post.IsActive ? "fa-xmark" : "fa-check") mr-1.5"></i>
                                        @(post.IsActive ? "Gỡ tin" : "Duyệt ngay")
                                    </button>
                                </form>
                                
                                <form asp-controller="JobPosts" asp-action="Delete" asp-route-id="@post.JobPostID" method="post" onsubmit="return confirm('Hành động này không thể hoàn tác. Xóa tin này?')">
                                    <button type="submit" class="inline-flex items-center px-3 py-1.5 rounded-lg bg-white border border-slate-200 text-rose-600 hover:bg-rose-50 hover:border-rose-200 transition-all shadow-sm">
                                        <i class="fa-regular fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center">
                            <div class="text-slate-400 mb-2 text-3xl"><i class="fa-regular fa-folder-open"></i></div>
                            <div class="text-slate-500 font-medium">Không tìm thấy tin tuyển dụng nào.</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />