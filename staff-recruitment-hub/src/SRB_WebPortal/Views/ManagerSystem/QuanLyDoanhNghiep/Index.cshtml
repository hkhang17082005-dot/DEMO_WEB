@{
    Layout = "_DashboardLayout";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Quản lý Doanh nghiệp</h1>
    <p class="text-slate-500">Danh sách các doanh nghiệp đã đăng ký trong hệ thống.</p>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-600">Tên doanh nghiệp</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-600">Ngành nghề</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-600">Email liên hệ</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-600">Trạng thái</th>
                <th class="px-6 py-3 text-right text-xs font-semibold text-slate-600">Hành động</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            <tr>
                <td class="px-6 py-4">Công ty ABC</td>
                <td class="px-6 py-4">Công nghệ</td>
                <td class="px-6 py-4">contact@abc.com</td>
                <td class="px-6 py-4"><span class="text-emerald-600 font-medium">Đã xác minh</span></td>
                <td class="px-6 py-4 text-right">
                    <button class="text-sky-600 hover:text-sky-800">Chi tiết</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
