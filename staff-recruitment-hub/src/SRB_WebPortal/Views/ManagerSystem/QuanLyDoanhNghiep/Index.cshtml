@model List<SRB_ViewModel.Entities.Business>
@{
    Layout = "_DashboardLayout";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Quản lý Doanh nghiệp</h1>
    <p class="text-slate-500">Danh sách các doanh nghiệp đã đăng ký trong hệ thống.</p>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-600">Tên doanh nghiệp</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-600">Mã số thuế</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-600">Email liên hệ</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-600">Trạng thái</th>
                <th class="px-6 py-3 text-right text-xs font-semibold text-slate-600">Hành động</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @if(Model != null && Model.Count > 0)
            {
                foreach(var business in Model)
                {
                    <tr>
                        <td class="px-6 py-4">@business.BusinessName</td>
                        @if(string.IsNullOrEmpty(business.TaxCode))
                        {
                            <td class="px-6 py-4 text-slate-500 italic">Chưa cập nhật</td>
                        }
                        else
                        {
                            <td class="px-6 py-4">@business.TaxCode</td>
                        }
                        <td class="px-6 py-4">@business.ContactEmail</td>
                        <td class="px-6 py-4">
                            @if(business.IsVerified)
                            {
                                <span class="text-emerald-600 font-medium">Đã xác minh</span>
                            }
                            else
                            {
                                <span class="text-red-600 font-medium">Chưa xác minh</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="text-sky-600 hover:text-sky-800">Chi tiết</button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="px-6 py-4 text-center text-slate-500">Không có doanh nghiệp nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
