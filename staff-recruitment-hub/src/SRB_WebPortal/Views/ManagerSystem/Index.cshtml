@{
    ViewData["Title"] = "Quản trị hệ thống";
    Layout = "_DashboardLayout";
}

<div class="mb-8 flex justify-between items-end">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-800">Quản trị Hệ thống</h1>
        <p class="text-slate-500 mt-1">Dưới đây là báo cáo nhanh và danh sách phân quyền người dùng.</p>
    </div>
    <button class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-medium shadow-sm transition flex items-center gap-2">
        <i class="fa-solid fa-user-plus"></i> Thêm tài khoản
    </button>
</div>

@await Html.PartialAsync("./_StatsCards.cshtml")

<div class="bg-white rounded-xl shadow-sm border border-slate-200 mt-8 overflow-hidden">
    
    <div class="p-5 border-b border-slate-200 flex flex-col sm:flex-row justify-between items-center bg-slate-50/50 gap-4">
        <h2 class="text-lg font-bold text-slate-800">Danh sách Người dùng</h2>
        <div class="flex gap-3">
            <select class="border border-slate-300 bg-white text-slate-700 py-2 px-3 rounded-lg outline-none text-sm focus:ring-2 focus:ring-blue-500">
                <option>Tất cả trạng thái</option>
                <option>Hoạt động</option>
                <option>Đã khóa</option>
            </select>
            <div class="relative">
                <i class="fa-solid fa-search absolute left-3 top-2.5 text-slate-400"></i>
                <input type="text" placeholder="Tìm tên, email..." 
                       class="pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-full sm:w-64">
            </div>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wider border-b border-slate-200">
                <tr>
                    <th class="py-4 px-6 font-semibold">Tài khoản / Email</th>
                    <th class="py-4 px-6 font-semibold">Trạng thái</th>
                    <th class="py-4 px-6 font-semibold">Vai trò (Roles)</th>
                    <th class="py-4 px-6 font-semibold text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm divide-y divide-slate-100">
                
                <tr class="hover:bg-slate-50/80 transition group">
                    <td class="py-4 px-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center font-bold shadow-sm">
                                H
                            </div>
                            <div>
                                <p class="font-bold text-slate-800">hungnq.admin</p>
                                <p class="text-slate-500 text-xs mt-0.5">hung.nguyen@zeion.com</p>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <span class="bg-green-100 text-green-700 border border-green-200 px-3 py-1 rounded-full text-[11px] font-bold tracking-wide">HOẠT ĐỘNG</span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex flex-wrap gap-1.5">
                            <span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded text-xs font-semibold">ADMIN</span>
                            <span class="bg-slate-100 text-slate-700 px-2 py-1 rounded text-xs font-semibold border border-slate-200">SYSTEM_MANAGER</span>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-right">
                        <button class="text-blue-600 hover:text-blue-800 font-medium text-sm mr-4 transition" onclick="openRoleModal('hungnq.admin')">
                            <i class="fa-solid fa-shield-halved mr-1"></i> Phân quyền
                        </button>
                        <button class="text-red-500 hover:text-red-700 transition" title="Khóa tài khoản">
                            <i class="fa-solid fa-lock"></i>
                        </button>
                    </td>
                </tr>

                <tr class="hover:bg-slate-50/80 transition group">
                    <td class="py-4 px-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center font-bold shadow-sm">
                                V
                            </div>
                            <div>
                                <p class="font-bold text-slate-800">hr.vinamilk</p>
                                <p class="text-slate-500 text-xs mt-0.5">tuyendung@vinamilk.com.vn</p>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <span class="bg-green-100 text-green-700 border border-green-200 px-3 py-1 rounded-full text-[11px] font-bold tracking-wide">HOẠT ĐỘNG</span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex flex-wrap gap-1.5">
                            <span class="bg-amber-100 text-amber-700 px-2 py-1 rounded text-xs font-semibold">BUSINESS_MANAGER</span>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-right">
                        <button class="text-blue-600 hover:text-blue-800 font-medium text-sm mr-4 transition" onclick="openRoleModal('hr.vinamilk')">
                            <i class="fa-solid fa-shield-halved mr-1"></i> Phân quyền
                        </button>
                        <button class="text-red-500 hover:text-red-700 transition" title="Khóa tài khoản">
                            <i class="fa-solid fa-lock"></i>
                        </button>
                    </td>
                </tr>

            </tbody>
        </table>
    </div>

    <div class="p-4 border-t border-slate-200 flex flex-col sm:flex-row justify-between items-center bg-slate-50 text-sm text-slate-500 gap-4">
        <span>Hiển thị <span class="font-bold text-slate-700">1 - 10</span> trong số <span class="font-bold text-slate-700">45</span> người dùng</span>
        <div class="flex gap-1">
            <button class="px-3 py-1.5 border border-slate-300 rounded-md hover:bg-slate-200 transition bg-white">Trước</button>
            <button class="px-3 py-1.5 bg-blue-600 text-white rounded-md font-medium shadow-sm">1</button>
            <button class="px-3 py-1.5 border border-slate-300 rounded-md hover:bg-slate-200 transition bg-white">2</button>
            <button class="px-3 py-1.5 border border-slate-300 rounded-md hover:bg-slate-200 transition bg-white">Sau</button>
        </div>
    </div>
</div>

<div id="roleModal" class="fixed inset-0 z-50 bg-slate-900/50 hidden flex items-center justify-center backdrop-blur-sm transition-opacity">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
            <h3 class="font-bold text-lg text-slate-800">Cập nhật quyền truy cập</h3>
            <button onclick="closeRoleModal()" class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
        </div>
        <div class="p-6">
            <p class="text-sm text-slate-600 mb-4">Chọn vai trò cho tài khoản <strong id="modalUsername" class="text-blue-600"></strong>:</p>
            
            <div class="space-y-3">
                <label class="flex items-center gap-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 transition">
                    <input type="checkbox" class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500">
                    <div>
                        <p class="font-bold text-sm text-slate-800">ADMIN</p>
                        <p class="text-xs text-slate-500">Toàn quyền hệ thống</p>
                    </div>
                </label>
                <label class="flex items-center gap-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 transition">
                    <input type="checkbox" class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500">
                    <div>
                        <p class="font-bold text-sm text-slate-800">SYSTEM_MANAGER</p>
                        <p class="text-xs text-slate-500">Quản lý người dùng & cài đặt</p>
                    </div>
                </label>
            </div>
        </div>
        <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex justify-end gap-3">
            <button onclick="closeRoleModal()" class="px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-100 transition font-medium">Hủy</button>
            <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition shadow-sm font-medium">Lưu thay đổi</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // JS đơn giản để mở/đóng Modal phân quyền
        function openRoleModal(username) {
            document.getElementById('modalUsername').innerText = username;
            document.getElementById('roleModal').classList.remove('hidden');
        }

        function closeRoleModal() {
            document.getElementById('roleModal').classList.add('hidden');
        }
    </script>
}