{
   "SystemSettings": {
      "HostServer": "localhost",
      "PortServer": 8000,
      "Environment": "Development",
      "AdminUsername": "yourAdminUsername",
      "AdminPassword": "yourAdminPassword"
   },
   "ConnectionStrings": {
      "ConnectionDatabase": "Server=localhost,1433;Database=yourDatabase;User Id=yourUser;Password=yourPassword;MultipleActiveResultSets=True;TrustServerCertificate=True",
      "RedisConnection": "localhost:6379,abortConnect=false,connectTimeout=5000"
   },
   "ServiceSettings": {
      "HashSecret": "YourHashSecret"
   },
   "Logging": {
      "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning"
      }
   },
   "AllowedHosts": "*",
   "JwtSettings": {
      "SecretKey": "YourSecretKey",
      "Issuer": "YourApp",
      "Audience": "YourUsers",
      "EXP_ACCESS_TOKEN": "15m",
      "EXP_REFRESH_TOKEN": "12h"
   },
   "CloudinarySettings": {
      "CloudName": "yourCloudName",
      "APIKey": "yourAPIKey",
      "APISecret": "yourAPISecret"
   },
   "BunnySettings": {
      "StorageZoneName": "yourStorageZoneName",
      "Hostname": "https://yourHostname",
      "BaseCdnUrl": "https://yourBaseURL",
      "AccessKey": "yourAccessKey"
   },
   "ResendSettings": {
      "ApiToken": "yourAPIKey"
   },
   "PaymentSettings": {
      "MomoPartnerCode": "YourPartnerCode",
      "MomoAccessKey": "YourAccessKey",
      "MomoSecretKey": "YourSecretKey",
      "MomoEndpoint": "https://test-payment.momo.vn/v2/gateway/api/create",
      "VNPayTmnCode": "YourTmnCode",
      "VNPayHashSecret": "YourHashSecret",
      "VNPayBaseUrl": "YourBaseURL",
      "VNPayReturnUrl": "YourReturnURL"
   }
}
